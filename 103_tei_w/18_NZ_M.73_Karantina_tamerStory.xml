                  <w xml:id="_xTok_000173" xml:lang="ar-acm-x-shawi-vicav">čila</w>
                  <w join="right"
                     xml:id="_xTok_000174"
                     xml:lang="ar-acm-x-shawi-vicav"
                     rendition="rend:dashAfter">l</w>
                  <w xml:id="_xTok_000176" join="right" xml:lang="ar-acm-x-shawi-vicav">ḥalāwa</w>
                  <pc xml:id="xTok_000177">?</pc>
               </u>
               <spanGrp type="Translation">
                  <span xml:lang="en" target="#_a24" xml:id="a36">and his robe hit the robe of the man who ate the halawa!</span>
               </spanGrp>
            </div>
         </div>
