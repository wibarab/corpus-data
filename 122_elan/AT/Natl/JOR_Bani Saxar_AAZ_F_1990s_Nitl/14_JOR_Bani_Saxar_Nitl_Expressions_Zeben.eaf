    <TIER ANNOTATOR="Antonella" LINGUISTIC_TYPE_REF="Phrases "
        PARTICIPANT="JOR_Bani Saxar_IAZ_F_1990s_Nitl" TIER_ID="JOR_Bani Saxar_IAZ_F_1990s_Nitl_Transcription">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts5">
                <ANNOTATION_VALUE>gām ytaʕazaz aw gām ataʕazaz</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>hassa miš gām gām, yaʕni, gām yitʕazaz aw gāmt ataʕazaz yaʕni ṣārat keyf yaʕni maṯalan ana kān widd-i kān widd-i šaġla w kān dāyman agūl maṯalan ana widd-i</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts11">
                <ANNOTATION_VALUE>hāy š-šaġla widd-i hāy š-šaġla kamma ṣaru widd-aham ysawwū-li hāḏi š-šaġla ṣirt agūl lā mā widd-i fa aḥna ngūl ṣārt tʕazaz gāmt tʕazaz  </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ā bass, yṣīru widd-hum yǧībū-l-ik illi widd-ik iyya tṣīri tgūli xalaṣ mā widd-i</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>tṣīr ngūl gāmat tatʕazaz</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>šaġla hilūa, taʕaǧb-ik šaġla kṯīr hilūa aw waḥda ḥilūa tgūl aḷḷa ḏićr-ak ʕalē-_́</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>zayy mašaḷḷa ʕalē-_́</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>fa tgūli yāḷḷa ḏićr-ak ʕalī-ah yaʕni ḏikr aḷḷa alli hū mašaḷḷa, yāḷḷa ḏićr-ak  ʕalī-ah, yaʕni maṯalan ṣāliḥ ʕind-u bint tḥil ʕan ḥibal al-mašnaga inno ḥilūa yaʕani   </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>yā aḷḷa ḏićr-ak ʕalī-ah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>Aywa mazyūna, aḥana ngūl fi taʕabīr ṯāni tḥil ʕan ḥibal al-mašnaga yaʕni ḥilūa ḥilūa ḥilūa kṯīr fa tḥil ʕan ḥibal l-mašnaga</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts47">
                <ANNOTATION_VALUE>mašaḷḷa, ḏićr aḷḷa ʕalī-ah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts51">
                <ANNOTATION_VALUE>aw maṯalan ana sawwēt šaġla, ḏićr aḷḷa ʕalē-ć</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts52" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>ḏićr aḷḷa ʕalē-ć,ḏićr aḷḷa ʕalē-ć, sawwēt šaġla, aw beyt ḥilū aw sayyāra ḥilūa aw ayy, šū ma kān al-iši ḥilu w inta widd-ak ḏikr aḷḷa ʕalē-_́, mū šarṭ waḥida aw wāḥid ḏićr aḷḷa ʕalē-_́, ḏićr aḷḷa ʕa hā-s-sayyāra zayy hēk yaʕni mašaḷḷa ʕa hā-s-sayyāra mašaḷḷa ʕa hā-l-beyt ḥilu zayy hēk</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>mant ṣari, aw mu-hū ṣari, aw mi-hī ṣariyya, yaʕni mū ʕāgla, fi ʕind-u muškila, waḷḷa inn-ah flāna mi-hī ṣariyya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>mi-hī ṣariyya, yaʕni hibla, waḷḷa ma-hī ṣariyya, waḷḷa manta ṣari, w hū? ma-hū ṣari</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>bass keyf al-lahǧa? keyf al-muṣṭalaḥāt?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts80" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>gūlīl-ha ma tḥadr-u š-maʕana-h</ANNOTATION_VALUE>
