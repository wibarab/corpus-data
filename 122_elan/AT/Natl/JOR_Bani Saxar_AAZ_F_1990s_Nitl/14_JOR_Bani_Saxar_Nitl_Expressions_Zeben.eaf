        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a58" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>هسا مش قام(نهض) قام يعني  يعني صارت كيف يعني مثلاً انا كان ودي شغلة وكنت دايما اقول مثلا انا ودي</ANNOTATION_VALUE>
