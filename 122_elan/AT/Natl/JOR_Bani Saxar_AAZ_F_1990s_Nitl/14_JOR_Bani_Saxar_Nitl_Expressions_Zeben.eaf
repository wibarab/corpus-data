    <TIER ANNOTATOR="Antonella" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="JOR_Bani Saxar_AAZ_F_1990s_Nitl_Transcription"
        PARTICIPANT="JOR_Bani Saxar_AAZ_F_1990s_Nitl" TIER_ID="JOR_Bani Saxar_AAZ_F_1990s_Nitl_Translation">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a67" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>نقول صارت تعزز.. مثلاً شوفي إسلام تقولي يلا عرين خلينا نروح</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a68" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>يلا يلا انا اقوله لا بعدين لما أنا وافقت هي تقولي لأ خلص ما ودي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a69" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>يعني انه انا قاعد اذكر الله </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a70" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>هسا احنا عنا مثلاً يعني بالإسلام مثلاً نشوف اشي حلو لازم نقول ما شاء الله </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a71" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>لانه إذا ما قلت ما شاء الله يمكن الاشي هذا يخرب، ينضر، او يروح او اشي او ينكسر فهمتي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a89" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>لازم يعني لما انا شفت اشي حلو اقول ما شاء الله </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a91" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>هي من الموقر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a92" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>عبدالله تعرف عبدالله؟.. عبدالله اللي جيتي معه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a93" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>من الموقر تقرب لعبدالله هم يحكوا بالاتش</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>هي هاي البنت كثير تضحّك، عليها كلمات يعني جدتي تقولهن قبل كانت تقولهن هاذي تطلع تقولي هيك، اقوله ايش هذا؟ عاد ايش بعدين تفهمني ايش شو معناه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>اه انه يعني، اقوله انتي دقّة قديمة </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>.. اه انتي قديمة كثير هي مواليد قديش يا اسلام؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a97" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>٢٠٠١ مزاليد ٢٠٠١ اصغر مني ب ٨ (ثمن) سنين اقوله انتي دقة قديمة يعني مثل جدتي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a98" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>بس يا حرام هي هسا امها .. اسلام الله يلعن شيطانك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a99" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>ما تحدره يعني مثلاً </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a100" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>انا أكون مخبية اشي اكل او شرب إلي </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a101" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>اجا حدا ياخذه بدون ما يطلب شو اقوله! ما تحدّره .. يعني بعيد الشر تموت قبل لا انه .. هسا ما تحدره يعني ما تنزله يعني انه لما يروح ع الحمام، فهمتي كيف! انه ما تحدره يعني انت تموت قبل لا تروح ع الحمام</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a102" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>علينا لهجة.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a103" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>ما تحدره وايش كمان ما تصرّفه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>ما تروح انه.. يعني انت ان شاء الله تموت قبل لا تروح ع الحمام فهمتي كيف؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a105" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>انداري عنا، اصبلك شاي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>قهوة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
