        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a59" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>هاي الشغلة ودي هاذي الشغلة لما صروا ودهم يسوولي هاذي الشغلة صرت أقول لا ما ودي ف احنا نقول صارت تعزز قامت تعزز</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a60" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>اه بس يصيروا بدهم يجيبولك اللي انتي ودك اياه تصيري تقولي خلص ما ودي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a61" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>تصير تقول قامت تتعزز</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a62" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>شغلة حلوة تعجبك، شغلة كثير حلوة او وحدة حلوة تقول يالله ذتسرك (ذكرك) عليه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a63" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>زي ما شاء الله عليه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a78" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>ف تقول يا الله ذتسرك عليه يعني ذكر الله اللي هو ما شاء الله.. ياالله ذتسرك عليه .. يعني مثلاً صالح عنده بنت تحل عن حبل المشنقة انه حلوة يعني</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a79" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>يالله ذتسرك عليه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a80" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>ايوا مزيونة احنا نقول في تعبير ثاني تحل عن حبل المشنقة يعني حلوة حلوة حلوة كثير ف تحل عن حبل المشنقة قد مهي حلوة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a81" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>حلوة نقول يالله ذتسرك عليه يالله ما شاء الله عليتس،ذتسر الله عليه، اه هيك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a82" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>او مثلاً انا سويت شغله ... ذتسر الله عليتش </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a83" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>ذتسر الله عليتس ، سويت شغلة، او بيت حلو او سيارة حلوة او اي ، شو ما كان الاشي حلو وانت ودك تذكر الله عليه مو شرط وحده او واحد ذتسر الله عليه، ذتسر الله ع هالسيارة زي هيك يعني ما شاء الله ع هالسيارة ما شتء الله ع هالبيت حلو زي هيك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a84" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>منت صري او مهو صري او مهي صريّه يعني مو عاقله في عنده مشكله .. و الله انه فلانه مهي صريه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a85" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>مهي صريه يعني هبله و الله مهي صريه ، و الله منت(ما انت(لست)) صري، مهو صري </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a86" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>بس كيف اللهجة كيف المصطلحات ؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a87" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE> قوليلها ما تحدره وش معناها </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
