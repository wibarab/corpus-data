                <ANNOTATION_VALUE>it is fizz</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>fizz means to stand up quickly </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>get up, come to me</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>I mean stand up, come, get up and come to me</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
