            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a488" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>beautiful, at Abū Tāyh's, he is far due to his good qualities, he honors them (the women) when they come around.. (meaning&gt; Abu tayh he cherished women when they went to him)
they sang about her when she was at his</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
