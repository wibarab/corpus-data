            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a377" ANNOTATION_REF="a220">
                <ANNOTATION_VALUE>من الجفور مدري الجفر غاد بلاد بعيدة </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a378" ANNOTATION_REF="a221">
                <ANNOTATION_VALUE>... وتقول مثل السراب</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a379" ANNOTATION_REF="a222">
                <ANNOTATION_VALUE>ذلول </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a380" ANNOTATION_REF="a223">
                <ANNOTATION_VALUE>تقول مثل السراب وهي عارفة اهلها البنت هذيتش </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a381" ANNOTATION_REF="a224">
                <ANNOTATION_VALUE>اردفتها يوم </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a382" ANNOTATION_REF="a225">
                <ANNOTATION_VALUE>يوم طلعت بزّت الشمس بعدها ما بزّت بزّت ما بزّت .. اه ... الشمس </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
