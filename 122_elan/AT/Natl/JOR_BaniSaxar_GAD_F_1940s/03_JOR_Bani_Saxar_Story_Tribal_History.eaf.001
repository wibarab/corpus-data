                <ANNOTATION_VALUE>you say his paternal uncle</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a492" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>Mḥammad is the son of ʕAwda</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a493" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>Mḥammad is the son of ʕAwda, who took her</ANNOTATION_VALUE>
            </REF_ANNOTATION>
