        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>وعندهم ودللها وش ودها تشتري هذاك الحين الناس ما لبست الذهب... معرّيات اللون بالجريد </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>سوّاهن لها ولبسها اياهن اللي يقولون يا نوره.. يهيجننون عنها : يا نوره العمر لا عبرت وسيرهن ما يفوتن.... </ANNOTATION_VALUE>
