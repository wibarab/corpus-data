        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>والله ما ادري تشان في عاد قالوا لنا قرايب بس هم يقولوا حنا الاصل منا يقولوا من خان يونس </ANNOTATION_VALUE>
            </REF_ANNOTATION>
