            <REF_ANNOTATION ANNOTATION_ID="a553" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>I do not know the poem about her</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a554" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>I do not know, it's now on the tip of my tongue; I've forgotten it.

)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a555" ANNOTATION_REF="a232">
                <ANNOTATION_VALUE>when they stopped her camel, when they stopped her camel, (they said) you are welcome, you are welcome




</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a597" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>she said...I do not know, what was it? I am Ṭifla on Ǧraybān</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a598" ANNOTATION_REF="a234">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a599" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>I am Ṭifla on Ǧraybān, that goes fast like the running of the water in the valley</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a600" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>it is going to the dīra of the Ḥiyān, Oh Turki, good morning to you, and she hits his neck and he goes down</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a601" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>Oh Turki, good morning to you, CHECK TRANSCRIPTION + TRANSLATION</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a602" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>they knew Abu Tāyh had horses</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a603" ANNOTATION_REF="a239">
                <ANNOTATION_VALUE>when they came, he said slaughter the ship! slaughter and make them breakfast, make them breakfast</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a604" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>and they made them breakfast, this is Ṭifla, the daughter of their brother from..., her mother was from the ḥwēṭāṭ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a605" ANNOTATION_REF="a241">
                <ANNOTATION_VALUE>her mother was a Bani Ṣaxar, a Bani Ṣaxar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a606" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>she is the daughter of Abu Tāyh</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a607" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>the one who said I am the Ṭifla on Ǧraybān ****? the small river</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a608" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>we are far away from the dīra of the Ḥyān, good morning to you</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a609" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a610" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a611" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>G: what did they say? I am the girl of this Ǧraybān, ***? the small river  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a612" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>we are far away from the dīra of the Ḥyān, good morning to you. You are wecome, good morning to you</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a556" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>yes, he slaughtered them some ships</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a557" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>make them (f.) breakfast, quickly</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a613" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>They taught (told) him and sent a messenger to the ḥwēṭi, saying, 'They are with us.'

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a614" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>since she was with him, he had nothing to worry about</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a615" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>they say she was manliness</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a616" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>a Ḥwaṭiyya and a person who speaks </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a617" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>I am Ṭifla on Ǧraybān that walks  like the valley water runs
 </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
