        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>I swear I do not know, there was.. then they told us we're relatives, but they claim they are the origin (of us). They say they are from Xān Yunis</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>ok ... G: our origins are from Xān Yunis/ć (we are from Xān Yunis/ć)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>because I heard them saying it... even Saʕūd, may his souls rest in peace, used to say it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a349" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>when he lived here, he would multiply, and he had him, as-Saṭil Dərwīš, Dərwīš adopted the customs of the bedouins and adopted our ways (of BṢ).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>and they put him in this castle (of Ḏ̣abaʕa)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a263" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>a castle, these are ruins on the route of the pilgrims</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a351" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>their route</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a433" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>from it (the castle)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a434" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>he might have taken from them (money for protection or service)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a435" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>who? no one from the ḥwēṭāṭ took his daughter</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a436" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>no one</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a437" ANNOTATION_REF="a180">
                <ANNOTATION_VALUE>no one from the al-ḥwēṭāṭ, this is from the Fāyiz, Nūra</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>from the Fāyiz</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>she took from, she took Abu Tāyih  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a438" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>he becomes his paternal uncle, ʕŌda Abu Tāyh</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a439" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>the paternal uncle of Muḥammad</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a440" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>the paternal uncle of Muḥammad</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a441" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>when he gave her to ʕawād, her father had already passed away.

</ANNOTATION_VALUE>
