        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>مزيونة هي ... الله ...مزيونة..  وعند ابو تايه بعيد الصيات يعزهن يوم يلفن ...يغنون عنه ويغنوا  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
