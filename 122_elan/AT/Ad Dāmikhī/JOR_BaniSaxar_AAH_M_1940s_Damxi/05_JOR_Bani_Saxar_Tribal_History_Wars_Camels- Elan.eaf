            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1577" ANNOTATION_REF="a291">
                <ANNOTATION_VALUE>and they come to him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1578" ANNOTATION_REF="a292">
                <ANNOTATION_VALUE>and heal him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1579" ANNOTATION_REF="a293">
                <ANNOTATION_VALUE>there was a medicine at that time, the Bedouins hide the medicine, before there was no doctor no anything</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
