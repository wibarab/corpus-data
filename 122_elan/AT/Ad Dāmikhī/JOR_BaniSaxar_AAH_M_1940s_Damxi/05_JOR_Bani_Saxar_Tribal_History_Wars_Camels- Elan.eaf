            <REF_ANNOTATION ANNOTATION_ID="a1652" ANNOTATION_REF="a366">
                <ANNOTATION_VALUE>Yes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1653" ANNOTATION_REF="a367">
                <ANNOTATION_VALUE>he says the owner of Šarhah (name of the horse), oh strong fighter,  we started to fight at the early morning, with him all the Ṣxūr of the Ġōr and al-Ḥaǧǧāya and the Ḥwēṭāh, the owner of Šarhah Ṭrād ibn Zabin</ANNOTATION_VALUE>
            </REF_ANNOTATION>
