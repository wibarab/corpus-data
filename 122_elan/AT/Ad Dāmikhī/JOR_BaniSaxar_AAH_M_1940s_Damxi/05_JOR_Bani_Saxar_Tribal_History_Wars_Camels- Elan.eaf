    <TIER LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="JOR_BaniSaxar_AAH_M_1940s_Damxi_Transcription"
        PARTICIPANT="JOR_BaniSaxar_AAH_M_1940s_Damxi" TIER_ID="JOR_BaniSaxar_AAH_M_1940s_Damxi_Translation">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1307" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1310" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>yes...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1311" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Bani ṣaxar... bani ṣaxar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1312" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>they came from, they came from al-ʕUla </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1313" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>The Ṭwaga became, the Ṭwaga alone, this (are) from the Fāyz and came...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1314" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>to the Zabin, to the Ḥgēš, Bani Ṣaxar call this the Ṭwaga</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1315" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>yes, and (those) from this Ḥəršā​n, this is not called  called Ṭwaga but Ǧbūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1316" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>the Čaʕābna</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1317" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>A: Kaʕābna, and the Ǧbūr these are alone, the ǧbūr on their own. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1323" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>I swear brother, the Wahhabi battle, I do not know about it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1324" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>Old stories... simple... the "what's-it-called" kind... old ones, maybe the ones written down on paper, someone who reads papers might know. Me? I neither read papers nor anything else.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1327" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1329" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>No, no the Xwēn were on their own.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1330" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>those, the Xwēn on their own and the Mdayyne on their own too.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1331" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>The Mdīne on their own</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1332" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Those Axwān</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1333" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Ibn Inhayyir was their chief</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1334" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Ibn Inhayyir is the leader of the Xwān, the ones who arrived to Al-Balga, here.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1335" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>and the leader of the Mdayne was Farḥān Ibn Mašhūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1336" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>He was a Rwāla.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1337" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>No, Ibn Hayyir is the one who brought this (Farḥān)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1338" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>The one who says, "Oh Ibn Heyyar, what brought you to Dardāḥ







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1339" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>(it is like Dardāḥ speaks to Farḥān) you will shit like the shit of the ḥibbāra, 90 batallions , you have low chances </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1340" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Everyone witnessed the fire from Umm al-ʕAmad</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1341" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>They arrived to Ḥəsbān, man, to Ḥəsbān...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1342" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>and when...they were defeated</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1343" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>and when they were defeated, Ibn Inhayyir began slaughtering their mounts (of his people), even those behind them, 
Bani Ṣaxar, those who were behind them,  would make them loose time, would have been slaughtered </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1344" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>and began slaughtering among them.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1345" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>and there was one who said Oh Ibn Inhayyar?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1346" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>By God, I don't remember anything behind me except...







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1347" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>women (in their homeland), and those to whom you slaughtered their mounts </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1348" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>the men killed them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1349" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>but do not kill it (my mount), and he left it, did not kill it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1350" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>When he said, there are women behid me</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2691" ANNOTATION_REF="a2686">
                <ANNOTATION_VALUE>I swear, they said I saw this valley, the one in Mwaggar, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1351" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>they say it was running (was full with) blood</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1352" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>they say was running (was full with) blood,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1353" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>on the western and eastern side, they say it spilled blood,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1354" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>And my father said, mercy be upon him , I remember nails filled the roots of the tree.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1355" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE> the roots of the tree, nails filled the roots of the tree.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1356" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>This was the Axwān.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1357" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>and be careful, Ibn Hayyir was from the Šammar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2692" ANNOTATION_REF="a2688">
                <ANNOTATION_VALUE>Yes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2694" ANNOTATION_REF="a2690">
                <ANNOTATION_VALUE>No, there was a Ṣxari between the Rwala, the Ǧlūy (the exiled)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1360" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>and they hosted them other Rwala from the region of Ġarāys</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1361" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>Ġarāys in Saudi Arabia</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1362" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>The hosts asked them? They said, "what did your camels find (to eat)?"







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1363" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE> they replied (the camels) ate to the bones the bones of these Ṣxūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1364" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>In the day of the battle, al-Madayyine, (broke the peace) fought by surprise the Bani Ṣaxar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1365" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Ibn Mašhur fought by surprise Bani Ṣaxar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1366" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>There was an elder man, looked like he wanted / was to sleep. He said I hear, meaning I hear you</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1367" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>I hear you, you are telling an unpleasant stories</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1368" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>he said, these are our guests, these  camels ate to the bones the bones of the Ṣxūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1369" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>he said</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1370" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>we raided against them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1371" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>the old man said we raided them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1372" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>we came from the area between the valley and the mountain, they call it al-Ḥabb, 






</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1373" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Turns out they descended by a small water source, which we call Xrayyim.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1374" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>We decided (to attack) on them at dawn.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1375" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>And when we raided, there she was, the girl in front of us gathering firewood.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1376" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Oh girl, why are you gathering the firewood? The tribe has been taken.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1377" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>She said, "By God, I’ll make you dinner or maybe lunch with it."
</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1378" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>with the firewood he said, we raid onto the group of camels and we take it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1379" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>we take it, he says when they checked, there he followed us (the group of camel), from behind, he called out and the one coming from there called out</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1380" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>the one coming from there called out, he said (narrative) and they took us out from the middle of the camels







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1381" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>he said (narrative) and they took us out from the middle of the camels</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1382" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>He said, there those she camels were visible</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1383" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>we throw the horse on them, I want to win but my friends were without resources (camels)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1384" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>He said and then</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1385" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>the horseman came to me, he said, then he called for help on Zarga (name of the horse)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1386" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Hāmid bin Idhayṯim of the ʕIṯmān</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1387" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>he said then he hit me and (then) I was at the pawns (of the horse)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1388" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>he said, I swear, he</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1389" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>he surpassed (me)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1390" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>he said, a moment, and then he  came back to me</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1391" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>he said, and I am hurt, he did not kill (me), yes hurt,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1392" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>he said and took him at his place </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1393" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>he healed me until my wound healed </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1394" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>May God make his face white (may God forgive him), 40 nights I stayed with him and he cured me until I was healing</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1396" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>I swear this is what they tell about it the guests, they (the camels) were stripping the flesh off the bones of the Ṣxūr </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1397" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Ibn Mašhūr attacked them (by surprise)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1398" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Yes, he attacked them (by surprise), the day of the killing of Ḥātmal and his son</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1399" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1400" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>the one who went east is Jordanian, he is a Ṣxari, from here</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1401" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>in that time, Saudi was poor, they were going West and search for a living in Jordan</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1402" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>yes in Jordan, he was alien to wheat, the wheat was with the Ṣxari</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1403" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>he was alien, they said, he said, this was with a Jordanian</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1404" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>he came from Jordan this one, it was alien to him, and he was Ibn Saʕūd</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1405" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1406" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>he asked you did not raid it, he asked and he was Ibn Saʕūd, he (the one to whom he asked to) replied I swear we could not raid it, because its people defended it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1407" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>its people defended it, he said if there were not Bani Ṣaxar, I would have taken it up to the Jordan Valley -River</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1408" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE> if there were not Bani Ṣaxar, I would have taken it up to the Jordan Valley, meaning controlling till this side of the Jordan Valley and rule it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1409" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>Ibn Mašhūr told this</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1410" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>There was a ṣxari saying there was a camp next  to our borders (besides us)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1411" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>next to the borders of (besides) the Bedouins there were tents, there were the Bedouins,  there was a camp next  to our borders (beside us)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1412" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>at our borders they came, and said we want you to pass (your territory)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1413" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>and to come down to the emir, the emir Farḥān Ibn Mašhūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1414" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>he said it was raining</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1415" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>he said I swea, it was raining, I do not, he said, if you don´t come..., you do not pass, you men, come</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1416" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>you men are coming</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1417" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>they said we come as guests</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1418" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>to them, he said</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1419" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>he said there was a mufti with him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1420" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>what do you say about this (person)...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1421" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>he said to the mufti</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1422" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>meaning, what do you say about these men</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1423" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>he said, God willing, they will cut their mustaches, may God guide them,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1424" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>he said, we cut a little our mustaches, he said no no no, he said in the end (as a result) he left no mustache</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1425" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>we walked on all the mustaches</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1426" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>he said, he says them say "We swear by God"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1427" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>he says "We swear by God", the disbeliever</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1428" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>indeed the disbeliever, the black dog, the black dog Ibn Šaʕalān</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1429" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>he faced Ibn Šaʕalān</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1430" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>he faced Ibn Šaʕalā​n</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1431" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>he said at...at the sunset, they say to him "May your life be long"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1432" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>there are donkeys, he followed (runs behind to catch them) them, the camel shepards call the camels</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1433" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>he said bring them, they walk and they gather the camel shepards and bring them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1434" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>he said</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1435" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>what do you think of it? he says it to the mufti, he said they cut their mustaches, God willing, God will guide them, the camel shepards, the owners in front of them had no mustaches</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1436" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>there were no mustaches, he said in the ebd</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1437" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>cut the mustaches of the camel shepards</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1438" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>yes </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3135" ANNOTATION_REF="a3134">
                <ANNOTATION_VALUE>they cut them the mistaches, yes the religious practice is to not keep the mustaches </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1439" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>he said we leave at night and escape</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1440" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Ibn Šaʕlān the stories reached them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1441" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>that he is a black dog, and a disbeliever, the stories reached him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1442" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>the day they came to him, look they had no mustaches</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1443" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>they said by God, you may live long, look that was an imposition on us</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1444" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>he says him, their mustaches were cut, he said hey you made it like the sleeping female rabbit whose eyes have popped out (of the face)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1445" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>why did not you do like those who left, he could not command them,  and they came with their mustaches on them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1446" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>and Ibn Saʕūd escaped him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1447" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>he escaped from Ibn Saʕūd to in Sirya </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1448" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>and he came to Ibn Šaʕalān </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1449" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>and he arrived to Ibn Šaʕalān </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1450" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>and Ibn Šaʕalān forgave him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1451" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE>he gave him many people, and put him in charge of them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1454" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3567" ANNOTATION_REF="a3139">
                <ANNOTATION_VALUE>how were the customs and traditions, how the wedding happened</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3568" ANNOTATION_REF="a2822">
                <ANNOTATION_VALUE>it happened that they were walking to the wedding at night</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1456" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>they attended the wedding, they danced, recited poems, this was their tradition</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1457" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>The bride, the bride, they bring her on a camel</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3570" ANNOTATION_REF="a3004">
                <ANNOTATION_VALUE>yes, her baggage and all her belongings, they brought it on a camel</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1459" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>they build her a tent, I mean it is not big, and put her in it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1460" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>there were no buildings in that time, no buildings</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1461" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>the buildings were the tents, the tents, they brought the bride to the tent</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1462" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>brought the bride in the tent</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3007" ANNOTATION_REF="a3005">
                <ANNOTATION_VALUE>they made sacrifices</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3008" ANNOTATION_REF="a3006">
                <ANNOTATION_VALUE>what?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1464" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>the wedding had no limit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1465" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>it had no limit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3009" ANNOTATION_REF="a2823">
                <ANNOTATION_VALUE>they bring the bride, and the night she is brought,they dance.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1467" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>and recite poems, it had no precise end</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1468" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>whatever they want to dance or recite, as they please</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1469" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>there is no limit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3571" ANNOTATION_REF="a3442">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1470" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>yes, or still, (if) their enjoyment from dancing and poem did not stop, they (still) recite </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3602" ANNOTATION_REF="a3450">
                <ANNOTATION_VALUE>in that time there was not funeral gathering</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3603" ANNOTATION_REF="a3451">
                <ANNOTATION_VALUE>no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3604" ANNOTATION_REF="a3452">
                <ANNOTATION_VALUE>No, I swear</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3605" ANNOTATION_REF="a3453">
                <ANNOTATION_VALUE>no, there was not</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1532" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>they made a dinner in the name of the dead person, they made sacrifices </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1533" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>indeed we asked the wage for the dead (for the other life)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1534" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>they made sacrifices, there was nothing like today, funerals,people gathered, then every Bedouin in a wadi, no one is close to another, in this desert</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3613" ANNOTATION_REF="a3472">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1537" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>the dead</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1538" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>There was not funeral ceremony like now, people change and time changes, like now</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1541" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>when he dies, they bury him, even anywhere  they bury him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1542" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>wherever they buried, in the land they were, they bury him in it and made sacrifices cfor him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3480" ANNOTATION_REF="a3473">
