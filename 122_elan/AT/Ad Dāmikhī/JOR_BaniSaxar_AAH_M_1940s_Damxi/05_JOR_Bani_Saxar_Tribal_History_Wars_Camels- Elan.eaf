            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3614" ANNOTATION_REF="a3474">
                <ANNOTATION_VALUE>no no, this is not correct</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3596" ANNOTATION_REF="a3475">
                <ANNOTATION_VALUE>no, another thing I heard, they said, when the dead dies, they do not take it from the front of th tent, they take it from the back, is this right?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3420" ANNOTATION_REF="a3418">
                <ANNOTATION_VALUE>No!  I do not know</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3597" ANNOTATION_REF="a3419">
                <ANNOTATION_VALUE>no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1547" ANNOTATION_REF="a261">
                <ANNOTATION_VALUE>When a sickness comes...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1548" ANNOTATION_REF="a262">
                <ANNOTATION_VALUE>it made sense to avoid the sickness </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1549" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>it made sense to avoid the sickness </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1550" ANNOTATION_REF="a264">
                <ANNOTATION_VALUE>By God, see</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1551" ANNOTATION_REF="a265">
                <ANNOTATION_VALUE>the small pox struck the Bedouins </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1552" ANNOTATION_REF="a266">
                <ANNOTATION_VALUE>Yes, the small pox struck them and killed one </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1553" ANNOTATION_REF="a267">
                <ANNOTATION_VALUE>one died, and the Bedouins escaped from it, the one who died, they escaped from it </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1555" ANNOTATION_REF="a269">
                <ANNOTATION_VALUE>and it come to him, come to him, a ṣxari, his name was ʕAṭuwi al-Imnāḥi from the Ḥgēš</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1556" ANNOTATION_REF="a270">
                <ANNOTATION_VALUE>he digged for him and buried him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1557" ANNOTATION_REF="a271">
                <ANNOTATION_VALUE>they said, his relatives that came to them, in the tents, in the time of the tents, they said, his relatives at where he was, in which ʕAṭuwi was</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1558" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>they said course your father, Aʕṭuwi buried Abu Mraggaʕa, by God he will transmit the sickness to you, so they went away and left him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1559" ANNOTATION_REF="a273">
                <ANNOTATION_VALUE>those scared from the sickness and those who escaped died, but Aʕṭwawi was fine, I swear, he did not die</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3618" ANNOTATION_REF="a3435">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1562" ANNOTATION_REF="a276">
                <ANNOTATION_VALUE>no no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1564" ANNOTATION_REF="a278">
                <ANNOTATION_VALUE>I teach you, some of them, some time, when a sickness comes to a family </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1565" ANNOTATION_REF="a279">
                <ANNOTATION_VALUE>I heard a story from the Ḥwēṭāt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1566" ANNOTATION_REF="a280">
                <ANNOTATION_VALUE>a sickness stroke and they went away from one tent</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1567" ANNOTATION_REF="a281">
                <ANNOTATION_VALUE>and left him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1568" ANNOTATION_REF="a282">
                <ANNOTATION_VALUE>and ʕAbeyd Abu Šāma Bluwi came to him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1569" ANNOTATION_REF="a283">
                <ANNOTATION_VALUE>every time he looks at this tent, it was alone</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1570" ANNOTATION_REF="a284">
                <ANNOTATION_VALUE>no Bedouins were left </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1571" ANNOTATION_REF="a285">
                <ANNOTATION_VALUE>and he walks/goes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1572" ANNOTATION_REF="a286">
                <ANNOTATION_VALUE>and the woman met him before he arrives</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1573" ANNOTATION_REF="a287">
                <ANNOTATION_VALUE>before he arrives</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1574" ANNOTATION_REF="a288">
                <ANNOTATION_VALUE>she said oh my brother, the man in it, a sickness stroke him, this and that, I do not know what it is</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1575" ANNOTATION_REF="a289">
                <ANNOTATION_VALUE>they call him in that moment, he said I want to see him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1576" ANNOTATION_REF="a290">
