        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3352" ANNOTATION_REF="a2426">
                <ANNOTATION_VALUE>لا إنت خربطت .. خربطت أم السالفة .. ها الصفرا وشنهي؟ .. أنت</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3353" ANNOTATION_REF="a2427">
