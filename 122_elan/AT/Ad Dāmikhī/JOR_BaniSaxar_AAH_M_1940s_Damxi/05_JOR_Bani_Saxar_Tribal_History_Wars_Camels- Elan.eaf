            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1646" ANNOTATION_REF="a360">
                <ANNOTATION_VALUE>he recited a peom, but I did not keep (memorize) the poem</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1647" ANNOTATION_REF="a361">
                <ANNOTATION_VALUE>even a poet from the Tuwāyha</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1648" ANNOTATION_REF="a362">
