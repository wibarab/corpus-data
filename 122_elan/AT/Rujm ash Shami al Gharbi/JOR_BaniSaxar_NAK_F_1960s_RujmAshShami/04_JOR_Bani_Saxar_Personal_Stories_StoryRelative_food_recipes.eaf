        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a670" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>ما شفت شكله شلون</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a671" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>بس حبينا بعض مدري عاد قبل هيك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a672" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>حب شنو هو زي هيك لا تلفون ولا مقابلات ولا قعدات ولا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a673" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>لا.. يجي ناس مثلا والله فلان وده اياتش معجب بتش(بكِ) يحبتش(يحبكِ) وده اياتش</ANNOTATION_VALUE>
