            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a724" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>لا لا لا ما في كراسي .. يلمون والصحون والطوس تبعات الطبخ وشي يلمونهن من الجيران </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a725" ANNOTATION_REF="a157">
