    <TIER ANNOTATOR="Antonella" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="JOR_BaniSaxar_AAK_M_1990s_RujmAshShami-txt"
        PARTICIPANT="Translation_JOR_BaniSaxar_AAK_M_1990s_RujmAshShami" TIER_ID="JOR_BaniSaxar_AAK_M_1990s_RujmAshShami">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>Let's start</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a462" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>First thing, tell us your name</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a464" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>From which branch of the Bani Ṣaxar?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a483" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>al-Gnūa, now this is the branch, first thing tell us how old are you</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a484" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>My you have a long life</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a485" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>During your life did you go out of Ruǧm?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>Did you live outside, go out or come, or not during your life?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a487" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>All your life in Ruǧm aš-Šāmi</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a488" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>It means you were born and lived in Ruǧm aš-Šāmi</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a489" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>az-zabāra</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a490" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>I mean close</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a491" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>Fine</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a509" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>now, tell us, prayers upon our prophet Moḥammad</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a510" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>You are 58 y.o.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a492" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>From which year are you married?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a511" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>How old were you?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a512" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>20</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a519" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>and the man you got married to? Abū Ḏ̣eyf aḷḷa, may God have merci of him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a520" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>How old was he when married you?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a521" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>five years older than you</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a522" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>How did you get married and get to know each other?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a465" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>The truth! the truth!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a466" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>Ok</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a467" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>I mean, there was...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a468" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Fine, but why? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a921" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>ok</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a922" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>and they come to propose</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a923" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>May Allah bless our Prophet Muḥammad, what else can I ask you?







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a924" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>fine, tell us how was the engagement, how were the costumes?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a925" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>dressed in the attire</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a926" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>one month, the engagement did not last long</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a927" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>Abū Ḏ̣eyfaḷḷa was from the Xaḏ̣īr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a928" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>but from another branch?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a929" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>noow the Xaḏ̣īr have different branches (or are divided in branches)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a930" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>it is to say 6</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a931" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>the Ḥaṣāmiyye</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a932" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>we mention it? (so) 6</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a949" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>Fine, now they are divided in six branches, they are a part of the tribe</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a950" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>And these six are divided in families.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a951" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Fine</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a952" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>So tell as how was life in the past days?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a953" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>How was before, there was no electricity, there was nothing</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a954" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>Way better</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a523" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>In the livestock courtyard</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a524" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>God has willed it, I have seven maternal aunts and five maternal uncles.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a964" ANNOTATION_REF="a518">
                <ANNOTATION_VALUE>God willing, but you read the Qurān</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a965" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Thank God but only simple reading and writing.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a975" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Anyway, how was life after you got married to Abu Ḏ̣eyfaḷḷa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a976" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>fine</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a979" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a980" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>The daughter-in-law was the the woman...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a986" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>she was I mean...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a987" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a988" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>All together</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a989" ANNOTATION_REF="a106">
