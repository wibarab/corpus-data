        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a697" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>عندي خوات و خوان كانوا يوم انهم ما في محل بالغرفتين عندنا ما في محل .. يروحون وين</ANNOTATION_VALUE>
