        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a667" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>الصح والله كنا نحب بعضنا ما شافني ولا شفته</ANNOTATION_VALUE>
