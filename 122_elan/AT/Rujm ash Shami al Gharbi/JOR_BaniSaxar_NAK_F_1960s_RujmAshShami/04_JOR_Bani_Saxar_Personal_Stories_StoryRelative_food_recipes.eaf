    </TIER>
    <TIER ANNOTATOR="Antonella" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="Transcription_JOR_BaniSaxar_NAK_F_1960s_RujmAshShami"
        PARTICIPANT="JOR_BaniSaxar_NAK_F_1960s_RujmAshShami" TIER_ID="JOR_BaniSaxar_NAK_F_1960s_RujmAshShami_Words-txt"/>
    <TIER ANNOTATOR="Antonella" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="Transcription_JOR_BaniSaxar_NAK_F_1960s_RujmAshShami"
        PARTICIPANT="Translation_JOR_BaniSaxar_NAK_F_1960s_RujmAshShami" TIER_ID="JOR_BaniSaxar_NAK_F_1960s_RujmAshShami">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a498" ANNOTATION_REF="a497">
                <ANNOTATION_VALUE>My name is Naʕama Ḥamūd al-Ḥaǧǧāǧ al-Xaḏ̣īr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a470" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>From Bani Ṣaxar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a499" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>From the branch Xaḏ̣īr,a branch, Fraʕ of the Fruʕ the al-Gnūa branch (family)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a500" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>I am 58 y.o.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a501" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>No, I spent my whole life in Ruǧm</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a502" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Yes, but we keep going out during the harvest, we go to an area called az-zabāra</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a503" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>az-zabāra is...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a471" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Close, yes, there is....</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a504" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>One hours by car</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a515" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a516" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>I married...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a517" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>I was 20 when I married</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a652" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>He got married at 25</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a653" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>Yes, 5 years older</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a654" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>I mean</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a472" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>he knew, I mean a family...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a473" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>I tell you the truth or ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a474" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>The truth...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a475" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>The truth is that we loved each other but he did not see me nor I saw him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a476" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Letters... he sent letters and I sent letters.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a477" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>I mean, there was... there was, yeah, but we didn’t see each other. By God, I didn’t see him. I was stuck on the balcony on the day of the engagement. By God, I didn’t see him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a478" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>I did not see anything, not even how he looked like</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a479" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>but we loved each other, I do not know, before it was like this</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a933" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>love, was not like this, there were no phones, no dates (meetings and sittings), nothing</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a934" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>no... people come, (telling) someone wants you, likes you, loves you and wants you </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a935" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>If you accept, you accept. If you don’t, that’s it.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a936" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>yes he comes and proposes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a937" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>the engagement, its costumes were that at first his brother came, or someone else and asked for me</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a938" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>and they accepted and next time they came with a bigger group and read the fātḥa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a939" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>and they prepared lunch with slaughtered animals and







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a940" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>and a party after they had lunch... the people ate, and then he came in, dressed in the attire. This was the engagement.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a655" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>yes and then after a month passed, he got ready and we celebrated, that´s all</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a941" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>no it did not last long</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a942" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>yes from the Xaḏ̣īr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a943" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>yes, from the Barādʕa family</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a944" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>yes, divided, May Allah bless our Prophet Muḥammad, the Gnuwa, the Barādʕa, the Mazāhīf</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a945" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>the Ḥaṣāmiyye, Ġleyyil</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a946" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>the Daġāmīn, that is it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a947" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>they were 6</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a948" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>we mentioned the Ḥaṣāmiyye</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a955" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Yes, in families, yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a956" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a957" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Life was better than this (now)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a958" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Because we were all equals, no one would prevaricate on the other</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a959" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>For example, I harvest and my neighbour harvests</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a960" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>For example I do not have a fridge and my neighbour neither</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a961" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>I do not have a washing machine and my neighbour neither</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a962" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>I do not have a tv, my neighbour neither, I mean we were equals, all at the same level</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a963" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Yes, for example, the boys were studying ...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a967" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>I had sisters and brothers, in that time (?) there was no space, in the two rooms we had, there was no space, where did they go?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a968" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>they studied in the livestock courtyard</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a969" ANNOTATION_REF="a651">
                <ANNOTATION_VALUE>They studied with the animals</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a970" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>They took their books and studied.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a971" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>God has willed it, they all studied, except me, I left</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a972" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>God willing, I will have memorized the Qurān.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a973" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Thank God</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a974" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>I can read but not write.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a977" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>After I got married to Abu Ḏ̣eyfaḷḷa I lived with his brothers and mother</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a978" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>in the same house, in the same what is called, together</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a981" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>I lived together with his brothers for 17 years</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a982" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>not like now (when) I want to take my freedom/independece</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a480" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>I took my freedom and more; we were sleeping together in one room.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a481" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>We ate together, drank together, 17 years.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a482" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>When they get married, may God make things easy for them, they left.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a983" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Our life was different, me and them. I have never told them for example...







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a984" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>bothering, I lived my live, we were like this before, I mean the daughter in law remained with the family</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a985" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>eat with them, now no.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a991" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>She is like me, for example, I came to the boys and my aunt, and stayed with them.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a992" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>And I lived with my brothers-in-law.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a993" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>And I had another sister-in-law. It was like I would do the chores one day, and the next day it was her turn.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a994" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Yes and we ate and drank together</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a995" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Together</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a996" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>The wedding, ah my child, the wedding...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a997" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Slaughthered/Roasted animals and evening gathering, they sang from Sunday to Thursday</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1001" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Then they celebrate the bride on Thursday, make a dinner, and the next day they do the ǧrā́</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1002" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>The next day they slaughter somw animals, make a lunch and my God make thignss easy for them all.  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1005" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>No no, how?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1023" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>For example, with traditional tents, if you have mattresses and cushions, they take them and arrange them inside the tent.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1024" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>No, no, no, there are no chairs... They gather the plates, bowls, and cooking utensils, and some of these they borrow from the neighbors.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1025" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>And the women bake, knead the dough, and prepare šrāk bread</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1026" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>and men slaughthered animals</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1027" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>and they prepare marīs (a type of traditional dish) instead of yogurt, as there wasn't any







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1028" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>They cooked manāsif</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1029" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>Men cooked the manāsif, while women cooked rice and made bread.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1030" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>yes there were no cooks or anything</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1031" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>As for me, it was Abu Deif Allah, may God have mercy on him, who took charge of organizing more than one wedding.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1032" ANNOTATION_REF="a164">
                <ANNOTATION_VALUE>No no no.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1033" ANNOTATION_REF="a165">
                <ANNOTATION_VALUE> For example, if a guest from outside the community arrived, they would slaughter an animal for him and serve him dinner</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1034" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>No no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1035" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>only the ǧrā́ day and the night of the celebration</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1036" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>On Thursday</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1037" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>Yes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1038" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>They tell you that now, they celebrate in halls and that's it... But before, they used to say that before a man enters his wife [house], he must slaughter an animal</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1039" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>They used to slaughther, before entering his wife [house], he slaughters [an animal]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1040" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Before, he had to.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1041" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>The customs of Bani Saker are generosity and hospitality.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1042" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>No, they are not gone, still now Bani Ṣaxare are different</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1043" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>Meaning we are different from all the other clans; we are still holding on to our customs.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1044" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>With our customs, even if, for example, young people have become </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1045" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>educated, they don't, they still consider/think about the (our) culture</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a656" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>But we still have our customs, like neighbors [being/staying] together and helping each other







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1068" ANNOTATION_REF="a179">
                <ANNOTATION_VALUE>we are still, up until now, holding on to many of our customs.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a657" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>The best customs are generosity, kindness, and manhood,







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1069" ANNOTATION_REF="a228">
                <ANNOTATION_VALUE>chivalry, I mean, as much as I said, you hear people say, he fears nothing, not even death!







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1070" ANNOTATION_REF="a229">
                <ANNOTATION_VALUE>I mean the Ṣxari keeps being different.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1071" ANNOTATION_REF="a230">
                <ANNOTATION_VALUE>The Ṣxari are different from all the other tribes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1072" ANNOTATION_REF="a231">
                <ANNOTATION_VALUE>You go...?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1073" ANNOTATION_REF="a232">
                <ANNOTATION_VALUE>No problem ..you go...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1074" ANNOTATION_REF="a233">
                <ANNOTATION_VALUE>I swear in my mind I had a Ṣxari no...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1075" ANNOTATION_REF="a234">
                <ANNOTATION_VALUE>Yes, I was not thinking to take someone from outside [the tribe]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1076" ANNOTATION_REF="a235">
                <ANNOTATION_VALUE>Yes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1077" ANNOTATION_REF="a236">
                <ANNOTATION_VALUE>Until now, every girl's ambition is to marry a Ṣxari.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1078" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>Meaning, most girls, the majority of them, I was sitting with them,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1079" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>one says, By God, I hope my fate is to marry a Ṣxari, not anyone else.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1080" ANNOTATION_REF="a239">
                <ANNOTATION_VALUE>Because the customs of the Sakhri people are different, they are noble and respectful, they honor women, and in their traditions, it's shameful for a woman </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1081" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>to be beated, humiliated/mistreated, unlike</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1082" ANNOTATION_REF="a241">
                <ANNOTATION_VALUE>For other tribes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1083" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>Yes, the traditions are dsifferent. For us, for example, if a woman sins, it's for/because those behind her (her family)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1084" ANNOTATION_REF="a1067">
                <ANNOTATION_VALUE>it is to say one has to </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1085" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>for/because of her family, one takes it into account, I don't want to hit you, I don't want to humiliate you







so that her family considers, 'I don't want to hit you, I don't want to humiliate you; I’m taking your family into account.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1086" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>he takes your family into account because they are respectable... Yes.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1087" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>Meaning, when the father, for example, goes... the husband goes and complain to the father







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1088" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>and the mother would say, causeyour daughter is this and that, he would side with the husband because you sinned</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1089" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>Meaning, it's not like... we find it shameful, for example, for a woman to go to court to file a complaint</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1090" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>[when] problems happen, for us, it's shameful... We have customs that consider it a shame.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1091" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>We have many customs, like a woman...







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1092" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>the man should not walk ahead of her, and she should not pass him.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1093" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>She must walk behind him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a658" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>she has... for us it is shameful to raise her voice.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1094" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>We have many costums we Ṣxūr people, we consider shameful this thing.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1095" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>or to come and sit among a group of men</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1096" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>and to argue or speak, it’s considered shameful for us.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1097" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>Meaning, even if he's younger than you, the man must always remain a man.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1098" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>Meaning, we sit and listen, but we don’t respond unless we are asked.




</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1099" ANNOTATION_REF="a258">
                <ANNOTATION_VALUE>because he is a man</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1100" ANNOTATION_REF="a259">
                <ANNOTATION_VALUE>We welcome guests, and up until now, we continue to do so. Personally, I welcome them, may God bless the guest</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1101" ANNOTATION_REF="a260">
                <ANNOTATION_VALUE>Even if there are no men in the house, we still welcome the guest/he is still welcomed, and he will have dinner or lunch.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1102" ANNOTATION_REF="a261">
                <ANNOTATION_VALUE>we  honor him, may God bless him, and even if he wants to sleep, he can sleep.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1118" ANNOTATION_REF="a262">
                <ANNOTATION_VALUE>Ah, like, for example, we prepare a place for him somewhere else

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1119" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>for example, in another room, and we honor him.

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1120" ANNOTATION_REF="a264">
                <ANNOTATION_VALUE>We don’t let him leave without lunch, or we tell him it’s not possible here /he is not here (? referrinmg to the man)

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1121" ANNOTATION_REF="a265">
                <ANNOTATION_VALUE>Like, for example, one day a woman steps out, and he asks her, "Where is the head of your household? Where is your husband?"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1122" ANNOTATION_REF="a266">
                <ANNOTATION_VALUE>You say "he is not here". We do not say he is not here, we say "Welcome to the guest", come in, he will come soon</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1123" ANNOTATION_REF="a267">
                <ANNOTATION_VALUE>It means we let the guest in; this is one of the traditions of the Ṣxūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1124" ANNOTATION_REF="a269">
                <ANNOTATION_VALUE>Do I tell about my paternal uncle?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1125" ANNOTATION_REF="a270">
                <ANNOTATION_VALUE>I tell you about a story that happened</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1126" ANNOTATION_REF="a271">
                <ANNOTATION_VALUE>There was a big tent and a šēx. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1127" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>I don't remember his name, may God remember him with goodness.

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1128" ANNOTATION_REF="a273">
                <ANNOTATION_VALUE>They were coming from Maʕān for example</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1129" ANNOTATION_REF="a274">
                <ANNOTATION_VALUE>He was a Ṣxari, coming form Maʕān, I do not want to tell his name.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1130" ANNOTATION_REF="a275">
                <ANNOTATION_VALUE>He came from, they came from...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1131" ANNOTATION_REF="a276">
                <ANNOTATION_VALUE>From...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1132" ANNOTATION_REF="a277">
                <ANNOTATION_VALUE>He was from Aḥǧa... Ḥaǧāya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a659" ANNOTATION_REF="a278">
                <ANNOTATION_VALUE>Yes, they were coming from the North and wanted to go to their land, to the Ḥaǧāya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a279">
                <ANNOTATION_VALUE>They passed by at the Ṭnayyib, from here, and there was this tent, a mxawmas (a five rooms tent)

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1133" ANNOTATION_REF="a280">
                <ANNOTATION_VALUE>they entered</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1103" ANNOTATION_REF="a281">
                <ANNOTATION_VALUE>Big!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1104" ANNOTATION_REF="a282">
                <ANNOTATION_VALUE>Like 5 rooms.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1134" ANNOTATION_REF="a283">
                <ANNOTATION_VALUE>They entered, and said we want [shelter], it was raining, snowing</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1155" ANNOTATION_REF="a284">
                <ANNOTATION_VALUE>He said " God be with you! By the Altimighty, is the host here, in the house?" The woman replied " We do not know"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1156" ANNOTATION_REF="a285">
                <ANNOTATION_VALUE>He asked " Are there relatives?"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1157" ANNOTATION_REF="a286">
                <ANNOTATION_VALUE>He even said relatives not Bedouins</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1158" ANNOTATION_REF="a287">
                <ANNOTATION_VALUE>These lived between the Ṭnayyib, who were Xaḏ̣īr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1159" ANNOTATION_REF="a288">
                <ANNOTATION_VALUE>who was Ḏ̣eyfaḷḷa al-əGṭēṭ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1160" ANNOTATION_REF="a289">
                <ANNOTATION_VALUE>it was his house, and the women present there, I mean between them there was more than one from the Xaḏ̣ēr </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1161" ANNOTATION_REF="a290">
                <ANNOTATION_VALUE>He entered the tent, and, lo and behold, it was  not a big tent, like the one of the šēx</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1162" ANNOTATION_REF="a291">
                <ANNOTATION_VALUE>and he welcomed (him)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1163" ANNOTATION_REF="a292">
                <ANNOTATION_VALUE>and told the women to prepare the sitting area</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1164" ANNOTATION_REF="a293">
                <ANNOTATION_VALUE>The Qṭēṭ yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1165" ANNOTATION_REF="a294">
                <ANNOTATION_VALUE>yes from the Barādʕe, he prepared for them at his place</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1166" ANNOTATION_REF="a295">
                <ANNOTATION_VALUE>and they slaughthered, in this night, a sheep for them that night and made them dinner</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1167" ANNOTATION_REF="a296">
                <ANNOTATION_VALUE>The day he left, asked him, from which tribe are you? He replied from the Xaḏ̣īr.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1168" ANNOTATION_REF="a297">
                <ANNOTATION_VALUE>he said this poem, I want to recite but I can´t remember</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1169" ANNOTATION_REF="a298">
                <ANNOTATION_VALUE>He called on us from the highlands climbing from the tent of ʕAbṭāni</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1170" ANNOTATION_REF="a299">
                <ANNOTATION_VALUE>the big tent, that honored me, truly it is one that the guest cannot surpass</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1171" ANNOTATION_REF="a300">
                <ANNOTATION_VALUE>and it stood for me next to the two groups, Xaḏ̣īr and an-Niʕēm, my children.

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1172" ANNOTATION_REF="a301">
                <ANNOTATION_VALUE>Ḏ̣eyfaḷḷa the one with the good reputation, who prepared a place for me and sheltered me</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1173" ANNOTATION_REF="a302">
                <ANNOTATION_VALUE>He prepared a place for me between the two sleeping areas, and as for the guest, may he be honored to be with me.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1174" ANNOTATION_REF="a303">
                <ANNOTATION_VALUE>This is the poem he chanted.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1175" ANNOTATION_REF="a304">
                <ANNOTATION_VALUE>Yes from the Ḥaǧāyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1176" ANNOTATION_REF="a305">
                <ANNOTATION_VALUE>Yes because by God, He knows better, the host was a Xaḏ̣ēr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1177" ANNOTATION_REF="a306">
                <ANNOTATION_VALUE>And what happened? No one knows.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1178" ANNOTATION_REF="a307">
                <ANNOTATION_VALUE>He wanted to visit, he came</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1179" ANNOTATION_REF="a308">
                <ANNOTATION_VALUE>from another place, it was winter, and he was a wanderer</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1180" ANNOTATION_REF="a309">
                <ANNOTATION_VALUE>a wanderer... he said, let me go to these Bedouins, sleep with them, away from the snow and the winter..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1181" ANNOTATION_REF="a310">
                <ANNOTATION_VALUE>So they did not host him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1182" ANNOTATION_REF="a311">
                <ANNOTATION_VALUE>Yes, he came  to him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1183" ANNOTATION_REF="a312">
                <ANNOTATION_VALUE>yes Abu Manṣūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1184" ANNOTATION_REF="a313">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1185" ANNOTATION_REF="a314">
                <ANNOTATION_VALUE>May God have mercy ofd him, yes he died</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1186" ANNOTATION_REF="a315">
                <ANNOTATION_VALUE>He had Hāyil</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1187" ANNOTATION_REF="a316">
                <ANNOTATION_VALUE>Before the Bedouins used to make the garaʕ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1188" ANNOTATION_REF="a317">
                <ANNOTATION_VALUE>The garaʕ is the pumpkin that people call yagṭīn</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a660" ANNOTATION_REF="a366">
                <ANNOTATION_VALUE>The big one that is yellow </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1189" ANNOTATION_REF="a367">
                <ANNOTATION_VALUE>For example, he might have been in the army before, where they would lengthen the service.

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1190" ANNOTATION_REF="a368">
                <ANNOTATION_VALUE>He would stay when he came on leave one or 2 months</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1191" ANNOTATION_REF="a369">
                <ANNOTATION_VALUE>When he comes from there, then one chopps a pumpkin, before they made a bowl of rušūf and put pupkin in it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1192" ANNOTATION_REF="a370">
                <ANNOTATION_VALUE>He invites the entire neighborhood...

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1193" ANNOTATION_REF="a371">
                <ANNOTATION_VALUE>All the neighbours, everyone was coming, afterwards they grind the coffee</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1200" ANNOTATION_REF="a372">
                <ANNOTATION_VALUE>He strucks the mortar when a guest arrives to him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1207" ANNOTATION_REF="a373">
                <ANNOTATION_VALUE>one strucks the mortar and grinds the coffee</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1208" ANNOTATION_REF="a374">
                <ANNOTATION_VALUE>the neighbours hear that that person has coffee, has a guest at his place, they go to him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1209" ANNOTATION_REF="a375">
                <ANNOTATION_VALUE>to have lunch, meaning without invitation</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1210" ANNOTATION_REF="a376">
                <ANNOTATION_VALUE>since he has a guest.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1211" ANNOTATION_REF="a377">
                <ANNOTATION_VALUE>Still, when the soldier used to come from there, these children would line up 
</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1212" ANNOTATION_REF="a378">
                <ANNOTATION_VALUE>for example 50, 60 one after the other </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1213" ANNOTATION_REF="a379">
                <ANNOTATION_VALUE>he brings with him bags with candies, and distributes to them </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1214" ANNOTATION_REF="a380">
                <ANNOTATION_VALUE>he gives them candies</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1215" ANNOTATION_REF="a381">
                <ANNOTATION_VALUE>To the small children, yes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1216" ANNOTATION_REF="a382">
                <ANNOTATION_VALUE>yes, the life of the Bedouins was different, the life of the Ṣxūr was different.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1217" ANNOTATION_REF="a383">
                <ANNOTATION_VALUE>There are some people whose traditions are almost like ours, but not exactly like ours

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1218" ANNOTATION_REF="a384">
                <ANNOTATION_VALUE>No, no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1219" ANNOTATION_REF="a385">
                <ANNOTATION_VALUE>I chant, what do you want me to chant about?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1224" ANNOTATION_REF="a386">
                <ANNOTATION_VALUE>I swear I do not know, I forgot, the chants I learned were not about the Ṣxūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1225" ANNOTATION_REF="a387">
                <ANNOTATION_VALUE>Everything</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1226" ANNOTATION_REF="a388">
                <ANNOTATION_VALUE>I have this...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1227" ANNOTATION_REF="a389">
                <ANNOTATION_VALUE>[As for] the prisoner, they locked the door on him; he’s not coming out today, he’s imprisoned

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1228" ANNOTATION_REF="a390">
                <ANNOTATION_VALUE>The chant on us...  May God send blessings upon our Prophet Moḥammad</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1243" ANNOTATION_REF="a391">
                <ANNOTATION_VALUE>they ascended to the territories of the Nʕēmāt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1244" ANNOTATION_REF="a392">
                <ANNOTATION_VALUE>I sweat I forgot it now, I forgot, I was about the Nʕēmāt.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1245" ANNOTATION_REF="a393">
                <ANNOTATION_VALUE>The Nʕēmāt have the same traditions as the Ṣxūr.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1246" ANNOTATION_REF="a394">
                <ANNOTATION_VALUE>Those in the South, they are like the Ṣxūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1247" ANNOTATION_REF="a395">
                <ANNOTATION_VALUE>and there are the Bani Xālid and the Bani ʕAṭiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1248" ANNOTATION_REF="a396">
                <ANNOTATION_VALUE>They still have traditions, they are the Northern Bedu</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1194" ANNOTATION_REF="a397">
                <ANNOTATION_VALUE>Their costumes are like the ones of the Bedouins</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1195" ANNOTATION_REF="a398">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1196" ANNOTATION_REF="a399">
                <ANNOTATION_VALUE>No, they are Bedouins but from the Northern Tribes not Ṣxūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1197" ANNOTATION_REF="a400">
                <ANNOTATION_VALUE>No not paysants, no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1198" ANNOTATION_REF="a401">
                <ANNOTATION_VALUE>No no, they are Bedouins, but not Ṣxur. These are the Bani Xālid, Bani ʕAṭiyya, al-Gāḏ̣i, these yes. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1199" ANNOTATION_REF="a402">
                <ANNOTATION_VALUE>I mean, a branch, branches, branches</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1249" ANNOTATION_REF="a403">
                <ANNOTATION_VALUE>the mansaf and the rušūf</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1250" ANNOTATION_REF="a404">
                <ANNOTATION_VALUE>and the ʕīš</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1251" ANNOTATION_REF="a405">
                <ANNOTATION_VALUE>The ʕīš is wheat</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1252" ANNOTATION_REF="a406">
                <ANNOTATION_VALUE>Grinded but crushed, they cook it on the stove</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1253" ANNOTATION_REF="a407">
                <ANNOTATION_VALUE>and they put a little yogurt with it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1254" ANNOTATION_REF="a408">
                <ANNOTATION_VALUE>they bring it in the morning and pour on it milk</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1255" ANNOTATION_REF="a409">
                <ANNOTATION_VALUE>they milk from the cattle</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1256" ANNOTATION_REF="a410">
                <ANNOTATION_VALUE>They made it...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1257" ANNOTATION_REF="a411">
                <ANNOTATION_VALUE>During the ʕīd, accorind to the Ṣxūr traditions the ʕīd lasted 3 days</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1258" ANNOTATION_REF="a412">
                <ANNOTATION_VALUE>they used to do the ʕīdiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1259" ANNOTATION_REF="a413">
                <ANNOTATION_VALUE>Everyone, for example every neighbour, for example I go out, they go out. from thi house and go to this (other) house</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1260" ANNOTATION_REF="a414">
                <ANNOTATION_VALUE>people did the naggāziyya, what is the naggāziyya? Rice dressed with sugar and ghee</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1261" ANNOTATION_REF="a415">
                <ANNOTATION_VALUE>yes, they ate it. They used to make fawwīr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1262" ANNOTATION_REF="a416">
                <ANNOTATION_VALUE>What is the fuwwīr? Sauce and xamʕūn????</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1263" ANNOTATION_REF="a417">
                <ANNOTATION_VALUE>They made a sauce like a soup, they stirred it, and you ate it... that’s how it used to be, for example</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1264" ANNOTATION_REF="a418">
                <ANNOTATION_VALUE>they did ʕīdiyye in every house</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1265" ANNOTATION_REF="a419">
                <ANNOTATION_VALUE>maybe they ate 20 plates in one day</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1266" ANNOTATION_REF="a420">
                <ANNOTATION_VALUE>it was like this, the day the Bedouins churned </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1267" ANNOTATION_REF="a421">
                <ANNOTATION_VALUE>buttermilk, three days, three churnings.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1268" ANNOTATION_REF="a422">
                <ANNOTATION_VALUE>they distributed it, they did not sell or eat it, or anything</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1269" ANNOTATION_REF="a423">
                <ANNOTATION_VALUE>they distribute it to the neighbors.







</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1270" ANNOTATION_REF="a424">
                <ANNOTATION_VALUE>To those who had and those who didn't, they distribute the churned butter, three churnings, they distrubuted it to the neighbors</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1271" ANNOTATION_REF="a425">
                <ANNOTATION_VALUE>then they mix together, its name was grāniyye</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1272" ANNOTATION_REF="a426">
                <ANNOTATION_VALUE>The grāniyye, mixes together and invites the neighbors for milk and butter, and they slaughter a sheep and something else</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1273" ANNOTATION_REF="a427">
                <ANNOTATION_VALUE>And the people eat, and then it becomes normal. If one wants to sell the milk, sells it; if one wants to sell the butter, before the three churnings, they don't sell; they wait until they mix it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1274" ANNOTATION_REF="a428">
                <ANNOTATION_VALUE>It means mixing, slaughtering</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1296" ANNOTATION_REF="a429">
                <ANNOTATION_VALUE>One would not sell yogurt or from the other before slaughtering (making a sacrifice)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1297" ANNOTATION_REF="a430">
                <ANNOTATION_VALUE>ant then there is the xamīsiyya, I mean in April</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1298" ANNOTATION_REF="a431">
                <ANNOTATION_VALUE>people would slaughter a xamīsiyya, and invite people, its name is xaməsiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1299" ANNOTATION_REF="a432">
                <ANNOTATION_VALUE>one would slaughter an animal and invite </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1300" ANNOTATION_REF="a433">
                <ANNOTATION_VALUE>invite the neighbours, people, he would host the xamīsiyya that night</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1301" ANNOTATION_REF="a434">
                <ANNOTATION_VALUE>No, there were no streets, nor electricity</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1302" ANNOTATION_REF="a435">
                <ANNOTATION_VALUE>It was different, better than this.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1303" ANNOTATION_REF="a436">
                <ANNOTATION_VALUE>There was fine night gathering!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1304" ANNOTATION_REF="a437">
                <ANNOTATION_VALUE>I swear I used to place cuscins</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1305" ANNOTATION_REF="a438">
                <ANNOTATION_VALUE>And the heating stoves are placed there, along with the decorations, and the young men and people are chatting.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1306" ANNOTATION_REF="a439">
                <ANNOTATION_VALUE>We sit and chat, and there are some people who are pissed off/bored, when one gets annoyed by them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1307" ANNOTATION_REF="a440">
                <ANNOTATION_VALUE>he opens now, he puts rāyb (skimmed milk) and pours tea on it.

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1308" ANNOTATION_REF="a441">
                <ANNOTATION_VALUE>meaning he takes their shoes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1309" ANNOTATION_REF="a442">
                <ANNOTATION_VALUE>I hated two from Ruǧm... ah... they used to come and I hated them.

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1310" ANNOTATION_REF="a443">
                <ANNOTATION_VALUE>they were both cold</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1311" ANNOTATION_REF="a1295">
                <ANNOTATION_VALUE>I was like, what should I do? We want to sleep.

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1312" ANNOTATION_REF="a444">
                <ANNOTATION_VALUE>my dear, I made tea and pured in it fat and skimmed milkt and gave it to them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1313" ANNOTATION_REF="a445">
                <ANNOTATION_VALUE>but once they drink it, they look for their shoes. The next day, they don't come to the house of the people. They force their way and immediately.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1314" ANNOTATION_REF="a446">
                <ANNOTATION_VALUE>We used to wear everything covered before, everyone wore madārig

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1315" ANNOTATION_REF="a447">
                <ANNOTATION_VALUE>Those who wear a headscarf wear a headscarf, those who wear a scarf wear a scarf, and those who wear a shawl wear a shawl. There were no skirts, no dresses, no pants</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1316" ANNOTATION_REF="a448">
                <ANNOTATION_VALUE>absolutely, it is shameful.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1317" ANNOTATION_REF="a449">
                <ANNOTATION_VALUE>We all, the tailors sewed it. Both the young and the old wear this clothing.

</ANNOTATION_VALUE>
