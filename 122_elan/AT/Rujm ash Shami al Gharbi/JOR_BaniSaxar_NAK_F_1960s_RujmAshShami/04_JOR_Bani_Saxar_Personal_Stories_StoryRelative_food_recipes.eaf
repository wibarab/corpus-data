                <ANNOTATION_VALUE>اه يجي يخطب</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a676" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>الخطبه عاداتها اول ما اجى(أتى) اخوه و واحد ثاني و اطلبوني </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a677" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>و ردّوا(عادوا الكرّة) جو(أتوا) ثاني مرة جاهه وقروا الفاتحة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a678" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>وسوّو غدا ذبايح و</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a679" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>وحفلة بعد ما سوّا الغدا.. تغدت الاوادم وفات لبّس اللبس هاذي الخطبه </ANNOTATION_VALUE>
