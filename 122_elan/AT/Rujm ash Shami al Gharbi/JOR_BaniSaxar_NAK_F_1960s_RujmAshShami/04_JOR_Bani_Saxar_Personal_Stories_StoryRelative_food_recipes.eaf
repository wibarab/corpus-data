            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a691" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>لانه كنا كلنا متساويينequal  يعني.. يعني ما في واحد زايد  commandعن الثاني</ANNOTATION_VALUE>
