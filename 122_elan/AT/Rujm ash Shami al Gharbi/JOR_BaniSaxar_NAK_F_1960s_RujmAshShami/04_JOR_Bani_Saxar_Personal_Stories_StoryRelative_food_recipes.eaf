        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a719" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>العرسيا همالالي العرس ... ذبايح وسهرة من الاحد للخميس وهم يغنون </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a720" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>وبعدين يجون يزفون العروس الخميس ويسوون عشا وثاني يوم يسوون يقولون له جرا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
