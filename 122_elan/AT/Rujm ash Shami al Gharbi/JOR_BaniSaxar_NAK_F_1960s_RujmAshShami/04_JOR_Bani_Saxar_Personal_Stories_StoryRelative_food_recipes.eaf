        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a729" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>الزلم يطبخون مناسف واللبن والحريم يطبخون الرز ويخبزن  </ANNOTATION_VALUE>
