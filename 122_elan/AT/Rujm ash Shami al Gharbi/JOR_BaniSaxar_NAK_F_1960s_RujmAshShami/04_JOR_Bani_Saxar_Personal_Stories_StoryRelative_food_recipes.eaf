            <REF_ANNOTATION ANNOTATION_ID="a721" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>ثاني يوم يذبحون ذبايح كمان مرة ويسوون غدا وكل واحد الله يسهّل عليه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a722" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>لا لا شو </ANNOTATION_VALUE>
