                TIME_SLOT_REF1="ts919" TIME_SLOT_REF2="ts920">
                <ANNOTATION_VALUE>at-taṭrīz  ***</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a458"
                TIME_SLOT_REF1="ts923" TIME_SLOT_REF2="ts924">
                <ANNOTATION_VALUE> al-asāsi aswad, ā  al-asāsi aswad aṣ-ṣxariyyāt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a459"
                TIME_SLOT_REF1="ts927" TIME_SLOT_REF2="ts928">
                <ANNOTATION_VALUE>sawde ā</ANNOTATION_VALUE>
