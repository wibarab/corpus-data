        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1320" ANNOTATION_REF="a452">
                <ANNOTATION_VALUE>Ah, there are embroidery frames, my child, there is stitching, there is traditional Palestinian embroidery (fallāḥi stitching), there is an embroidery hoop, there is... ah</ANNOTATION_VALUE>
            </REF_ANNOTATION>
