        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1252" ANNOTATION_REF="a508">
                <ANNOTATION_VALUE>I studied in the high school of ruǧm aš-šāmi, at the beginning it was mixed</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1253" ANNOTATION_REF="a509">
                <ANNOTATION_VALUE>from first class, second class, third, until 4th class, then no, in 4th class, no after it finished, it started (?) middle school, and then high school</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1254" ANNOTATION_REF="a510">
                <ANNOTATION_VALUE>and of course it was girls school... the boys alone and the girls alone / separated </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1255" ANNOTATION_REF="a511">
                <ANNOTATION_VALUE>No, by God I did not.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1256" ANNOTATION_REF="a512">
                <ANNOTATION_VALUE>I got married once I finished hight school, Abu ʕAbdallah bethroted me and I married him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1257" ANNOTATION_REF="a513">
                <ANNOTATION_VALUE>I was 18 years old.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1258" ANNOTATION_REF="a514">
                <ANNOTATION_VALUE>My husband is also from the Xaḏ̣īr, from my relatives (people)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1259" ANNOTATION_REF="a515">
                <ANNOTATION_VALUE>Yes we go sometimes, we go out buying stuff from Amman, going shopping</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1260" ANNOTATION_REF="a516">
                <ANNOTATION_VALUE>Yes, we don't always go to Amman </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1510" ANNOTATION_REF="a1503">
                <ANNOTATION_VALUE>Not always, I mean</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1511" ANNOTATION_REF="a1504">
                <ANNOTATION_VALUE>When it is needed (lit. in time of need) or we go there when we want to a change of scene (lit. change the air), going out, buying things</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1261" ANNOTATION_REF="a517">
                <ANNOTATION_VALUE>But we don't always go to Amman (richiamo del soggetto- sogg a sin con poi pronome che richiama)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1512" ANNOTATION_REF="a1505">
                <ANNOTATION_VALUE>Of the Bani Ṣaxar or mine?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1513" ANNOTATION_REF="a1506">
                <ANNOTATION_VALUE>Fine, for the Bani Ṣaxar the first thing is…
</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1263" ANNOTATION_REF="a519">
                <ANNOTATION_VALUE>[for] the Bani Ṣaxar …the tradition is followed by almost all of us</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1265" ANNOTATION_REF="a521">
                <ANNOTATION_VALUE>It is to say most of the people are engaged with a one of their relatives, usually the girl does not go away [from the family]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1266" ANNOTATION_REF="a522">
                <ANNOTATION_VALUE>and the very most part take the cousin, but if he is not available sometimes she goes away… the important thing is that we are almost all [with] a cousin</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1267" ANNOTATION_REF="a523">
                <ANNOTATION_VALUE>The closer with the closer and the nearer with the nearer</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1268" ANNOTATION_REF="a524">
                <ANNOTATION_VALUE>But thanks God I took one which was not my relative, not my proper cousin,  only from the same branch of the tribe </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1514" ANNOTATION_REF="a1507">
                <ANNOTATION_VALUE>From the same Xaḏ̣īr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1515" ANNOTATION_REF="a1508">
                <ANNOTATION_VALUE>[Before] the people tell him about her, his brothers, and other people</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1270" ANNOTATION_REF="a526">
                <ANNOTATION_VALUE>as first thing they sent a small ǧāha (group), his father, his mother,  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1271" ANNOTATION_REF="a527">
                <ANNOTATION_VALUE>his uncle, I mean from members of his family, they go see the girl</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1272" ANNOTATION_REF="a528">
                <ANNOTATION_VALUE>They talk to her father, of course her father asks her opinion, thanks God for us the opinion is compulsory for the girl, they have to ask the girl, only  few times there are few families who do not ask her opinion, but for the most part they do
</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1273" ANNOTATION_REF="a529">
                <ANNOTATION_VALUE>yes, if the girl agrees, they make the engagement and bring a bigger group of representatives [of the groom’s family] and decide the dowry </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1274" ANNOTATION_REF="a530">
                <ANNOTATION_VALUE>Usually between close relatives the dowry is not that high…</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1275" ANNOTATION_REF="a531">
                <ANNOTATION_VALUE>Oh so between the relatives it is not high, U: yeah, between relatives they are always sympathetic/they take care of each other </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1276" ANNOTATION_REF="a532">
                <ANNOTATION_VALUE>Yes, the dowry is the bride’s share , I mean the dowry of my turn/ period when I got married, around the 94</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1277" ANNOTATION_REF="a533">
                <ANNOTATION_VALUE>It was 1500 of gold [and] 3000 mʔaǧǧal</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1278" ANNOTATION_REF="a534">
                <ANNOTATION_VALUE>and he gave us forniture for the house, he gave the forniture for his house, and the most part live (?) with (within) the family, at his father, and his mother and his parents</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1279" ANNOTATION_REF="a535">
                <ANNOTATION_VALUE>rarely there is one, who builds a house and goes to live alone (lit. went out alone)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1280" ANNOTATION_REF="a536">
                <ANNOTATION_VALUE>Yes, in my time... in the time before '94... since the 90s, they stopped, meaning now it's rare </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1281" ANNOTATION_REF="a537">
                <ANNOTATION_VALUE>they get married in the family unless he builds a house </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1650" ANNOTATION_REF="a1518">
                <ANNOTATION_VALUE>who has a house alone and lives in it alone</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1282" ANNOTATION_REF="a538">
                <ANNOTATION_VALUE>In the time of our ancestors, the father used to build a  tent.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1283" ANNOTATION_REF="a539">
                <ANNOTATION_VALUE>Ah... and he would bring (or prepare) a horse for the boy, and there was a trunk for the bride, meaning they would celebrate her, and the bride wouldn’t know the groom or see him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1284" ANNOTATION_REF="a540">
                <ANNOTATION_VALUE>until the wedding night; they don’t see each other</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1651" ANNOTATION_REF="a1519">
                <ANNOTATION_VALUE>They prepare the trunk for her, the bridal trunk</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1285" ANNOTATION_REF="a541">
                <ANNOTATION_VALUE>meaning they buy her a few things [to put in) it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1286" ANNOTATION_REF="a542">
                <ANNOTATION_VALUE>And that’s it; they didn’t consult them before. It was rare for them to consult them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1287" ANNOTATION_REF="a543">
                <ANNOTATION_VALUE>this is the story before the 70ies.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1288" ANNOTATION_REF="a544">
                <ANNOTATION_VALUE>Yes, but thank God, Lord of the Worlds, most people, thank God, have faith and consult the girl, and they don’t give the girl away unless she agrees and is accepting of the marriage</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1289" ANNOTATION_REF="a545">
                <ANNOTATION_VALUE>They do the wedding, during my time, before, the wedding would last 7 days, from Saturday until Friday </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1290" ANNOTATION_REF="a546">
                <ANNOTATION_VALUE>they pitch up tents</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1527" ANNOTATION_REF="a1523">
                <ANNOTATION_VALUE>Yes 7 days, those who do not do 7 days are rare, unless...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1292" ANNOTATION_REF="a548">
                <ANNOTATION_VALUE>they dance at night, and they sing (lit. they do this dance and this song) and they perform hǧēni and poetry.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1293" ANNOTATION_REF="a549">
                <ANNOTATION_VALUE>Yes, this is at the groom´s, at the groom´s family of course... the bride has a night on Wednesday or Thursday </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1294" ANNOTATION_REF="a550">
                <ANNOTATION_VALUE>they do the ḥinna, the ḥinna of the bride, her female relatives and friends</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1295" ANNOTATION_REF="a551">
                <ANNOTATION_VALUE>They come, make a party for her, give her money (nqūt: giving money to the bride for blessings), congratulate her (lit. bless her). In my time, this is what was done, and before that..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1652" ANNOTATION_REF="a1524">
                <ANNOTATION_VALUE>No, these things were there, of course.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1296" ANNOTATION_REF="a552">
                <ANNOTATION_VALUE>No, there were in my time, how (comes)?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1297" ANNOTATION_REF="a553">
                <ANNOTATION_VALUE>I had a ḥenna party, like on Wednesday, and a wedding for seven days with songs and dancing</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1298" ANNOTATION_REF="a554">
                <ANNOTATION_VALUE>And a group of singers comes ... In my time, before, they sing the hǧēni, performed by the very same people (the same people who were there would perform the hǧēni )</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1299" ANNOTATION_REF="a555">
                <ANNOTATION_VALUE>and then they hold the dinner night... the night of celebration for the groom.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1300" ANNOTATION_REF="a556">
                <ANNOTATION_VALUE>They prepare them dinner, to  the group that goes to bring the bride. The group, of course, refers to the people who go to fetch the bride from her family's house</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1301" ANNOTATION_REF="a557">
                <ANNOTATION_VALUE>to the house of the groom</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1302" ANNOTATION_REF="a558">
                <ANNOTATION_VALUE>cars of course</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1303" ANNOTATION_REF="a559">
                <ANNOTATION_VALUE>celebrate the briden [conduct in solemn procession lit.]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1304" ANNOTATION_REF="a560">
                <ANNOTATION_VALUE>And the next day, Friday, they perform the ǧirā́</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1305" ANNOTATION_REF="a561">
                <ANNOTATION_VALUE>The ǧirā́ is the wedding meal</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1306" ANNOTATION_REF="a562">
                <ANNOTATION_VALUE>they make a big meal, it means the father slaughters for him 10 - 11 pieces of livestock </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1307" ANNOTATION_REF="a563">
                <ANNOTATION_VALUE>Yes, of course, they invite them and send the invitation about two weeks before the wedding or something to the relatives</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1308" ANNOTATION_REF="a564">
                <ANNOTATION_VALUE>The relatives invite them personally, while the people from outside send them wedding cards... invitations.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1309" ANNOTATION_REF="a565">
                <ANNOTATION_VALUE>This is what happened (lit. the story) in my time in the 90s and before the 90s</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1310" ANNOTATION_REF="a566">
                <ANNOTATION_VALUE>Before that no, from the time of...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1311" ANNOTATION_REF="a567">
                <ANNOTATION_VALUE>Before the 70s and before that, there were no invitation cards or anything</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1533" ANNOTATION_REF="a1531">
                <ANNOTATION_VALUE>No</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1655" ANNOTATION_REF="a1532">
                <ANNOTATION_VALUE>About my engagement?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1314" ANNOTATION_REF="a570">
                <ANNOTATION_VALUE>There was an acquaintance, of course; our relatives knew each other... we know each other... I mean, he knows me and I know hi</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1315" ANNOTATION_REF="a571">
                <ANNOTATION_VALUE>They came and proposed to me, he sent his uncle and father</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1316" ANNOTATION_REF="a572">
                <ANNOTATION_VALUE>sent his cousin (patrilinear), he becomes my sister's fiancé</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1317" ANNOTATION_REF="a573">
                <ANNOTATION_VALUE>and his female cousin becomes my brother's wife</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1318" ANNOTATION_REF="a574">
                <ANNOTATION_VALUE>They sent them and asked me (my hand), and of course, my father consulted me and they consulted me... and we agreed</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1319" ANNOTATION_REF="a575">
                <ANNOTATION_VALUE>the engagement lasted 14 days; there wasn't a lengthy engagement period</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1320" ANNOTATION_REF="a576">
                <ANNOTATION_VALUE>During my time, some people would have an engagement for a year, six months... I mean, no one would stay engaged for more than a year.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1321" ANNOTATION_REF="a577">
                <ANNOTATION_VALUE>No, we (did it) immediately, 14 days, and we got married</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1322" ANNOTATION_REF="a578">
                <ANNOTATION_VALUE>We spent 14 days preparing for the wedding (Lit. 14 days of course, it was the preparation for the wedding)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1323" ANNOTATION_REF="a579">
                <ANNOTATION_VALUE>He probably came to us twice... once, he brought me the dowry, the payment of the gold (?)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1324" ANNOTATION_REF="a580">
                <ANNOTATION_VALUE>And once, he came to chat/spend the evening chatting. So, he only came to us twice while I was engaged</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1325" ANNOTATION_REF="a581">
                <ANNOTATION_VALUE>Of course, during the 14 days, I went to buy things to prepare the bride's trousseau/ attire</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1326" ANNOTATION_REF="a582">
                <ANNOTATION_VALUE>he prepares the household necessities </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1328" ANNOTATION_REF="a584">
                <ANNOTATION_VALUE>I mean clothes, a bedroom</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1329" ANNOTATION_REF="a585">
                <ANNOTATION_VALUE>That is it, I did not live with family, in my time</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1330" ANNOTATION_REF="a586">
                <ANNOTATION_VALUE>Yes, I lived with his family, in their house, in a room, and the kitchen is shared, and the bathroom is shared</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1332" ANNOTATION_REF="a588">
                <ANNOTATION_VALUE>He had, Mashallah, two brothers, and his father was an old man, and his sister... his sister got married before I did, I mean</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1333" ANNOTATION_REF="a589">
                <ANNOTATION_VALUE>she didn´t stay long, I mean, 6 months we stayed/lived together</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1334" ANNOTATION_REF="a590">
                <ANNOTATION_VALUE>For the wedding or...?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1336" ANNOTATION_REF="a592">
                <ANNOTATION_VALUE>U:By God, at a wedding, manāsif. In the old days, did not we say it, they would celebrate the wedding for seven days. Sometimes they would make rušūf, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1543" ANNOTATION_REF="a1540">
                <ANNOTATION_VALUE>They would make fuwwīr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1338" ANNOTATION_REF="a594">
                <ANNOTATION_VALUE>To make fuwwīr, they boiled soured milk</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1339" ANNOTATION_REF="a595">
                <ANNOTATION_VALUE>They boiled soured milk, milk from goats</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1340" ANNOTATION_REF="a596">
                <ANNOTATION_VALUE>they boiled this soured milk over a flame , and they added to it fried chopped onion</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1341" ANNOTATION_REF="a597">
                <ANNOTATION_VALUE>finely chopped, which they had fried in a little ghee</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1342" ANNOTATION_REF="a598">
                <ANNOTATION_VALUE>after boiling the soured milk, they put it (= the fried onion) into it, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1343" ANNOTATION_REF="a599">
                <ANNOTATION_VALUE>and crumbled  the bread, they chop up the šrāk bread</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1344" ANNOTATION_REF="a600">
                <ANNOTATION_VALUE>and add it to the boiled sour milk,and they eat it. That’s what they call ‘fuwwīr’</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1345" ANNOTATION_REF="a601">
                <ANNOTATION_VALUE>They also make rušūf</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1346" ANNOTATION_REF="a602">
                <ANNOTATION_VALUE>The sweets, the groom's mother would bring (them) if she is present.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1347" ANNOTATION_REF="a603">
                <ANNOTATION_VALUE>She brings nuts and regular sweets.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1348" ANNOTATION_REF="a604">
                <ANNOTATION_VALUE>So the sweets and things like these (referring to sweet-tasting items served at celebrations) are mixed and put into bags, and they are distributed during the evening gathering.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1349" ANNOTATION_REF="a605">
                <ANNOTATION_VALUE>The gathering (التعليلة) lasts for seven days, and on the first day, sweets are distributed to everyone present.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1350" ANNOTATION_REF="a606">
                <ANNOTATION_VALUE>Some people distribute to the men, and some do not.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1351" ANNOTATION_REF="a607">
                <ANNOTATION_VALUE>Sometimes they distribute (them) to the men, sometimes no, only to women</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1352" ANNOTATION_REF="a608">
                <ANNOTATION_VALUE>For he men they prepare 'lazaqi', they make things like that</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1353" ANNOTATION_REF="a609">
                <ANNOTATION_VALUE>Lazāgi are one of the sweet dishes which the Bedouin make.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1354" ANNOTATION_REF="a610">
                <ANNOTATION_VALUE>They knead the dough, which is flour,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1355" ANNOTATION_REF="a611">
                <ANNOTATION_VALUE>Just flour alone with a little salt and water; they soften it(?), they make it soft</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1356" ANNOTATION_REF="a612">
                <ANNOTATION_VALUE>So the dough's water is light, not like bread dough</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1665" ANNOTATION_REF="a1541">
                <ANNOTATION_VALUE>They make it on the ṣāǧ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1357" ANNOTATION_REF="a613">
                <ANNOTATION_VALUE>Then they cut it and put sugar and ghee or sugar and oil on it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1358" ANNOTATION_REF="a614">
                <ANNOTATION_VALUE>Like bread, it should be thin, like šrāk bread, but the dough is liquid, not solid</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1359" ANNOTATION_REF="a615">
                <ANNOTATION_VALUE>They serve it to people, and people eat from it. They make it at funerals and at celebrations too</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1360" ANNOTATION_REF="a616">
                <ANNOTATION_VALUE>Yes, and there are also some sweets called bačīla. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1361" ANNOTATION_REF="a617">
                <ANNOTATION_VALUE>From our sweets. [for] the bačīla they bring wheat grains.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1362" ANNOTATION_REF="a618">
                <ANNOTATION_VALUE>They clean it, wash it, and sift it from everything in it, and they sieve it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1363" ANNOTATION_REF="a619">
                <ANNOTATION_VALUE>And they roast/heat it, heat, just enough for the wheat to cook, but they only roast it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1364" ANNOTATION_REF="a620">
                <ANNOTATION_VALUE>They grind/crack it in a grinder or take it to the mills</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1365" ANNOTATION_REF="a621">
                <ANNOTATION_VALUE>Before, there were steam mills where they would grind the wheat (to make) flour, and... before, there were no bakeries; they would bake at home</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1672" ANNOTATION_REF="a1553">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1367" ANNOTATION_REF="a623">
                <ANNOTATION_VALUE>So bakeries started here in ar-ruǧm around the 1980s, I think,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1368" ANNOTATION_REF="a624">
                <ANNOTATION_VALUE>Even after the 80s</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1369" ANNOTATION_REF="a625">
                <ANNOTATION_VALUE>Yes, aound the 90s</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1673" ANNOTATION_REF="a1545">
                <ANNOTATION_VALUE>Before that, they  bake and knead at home, either farrā​n bread or ṣāǧ bread</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1370" ANNOTATION_REF="a626">
                <ANNOTATION_VALUE>Rarely... rarely I mean one would go on a trip to Saḥāb (a place) to buy market bread</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1371" ANNOTATION_REF="a627">
                <ANNOTATION_VALUE>we call it market bread... it's rare to find people who don't bake; everyone bakes, there's no one who doesn't (NOT SURE)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1675" ANNOTATION_REF="a1554">
                <ANNOTATION_VALUE>All know how to bake and knead</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1372" ANNOTATION_REF="a628">
                <ANNOTATION_VALUE>The wheat, let´s finish with the bačīla. They roast wheat over heat</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1373" ANNOTATION_REF="a629">
                <ANNOTATION_VALUE>on something big, on a hotplate (ṣāǧ), on something. When it is cooked, they take it off the heat and grind it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1374" ANNOTATION_REF="a630">
                <ANNOTATION_VALUE>this bačīla.  Then they heat some water, and they put… they knead it with sugar, with water and sugar,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1375" ANNOTATION_REF="a631">
                <ANNOTATION_VALUE>and knead it until it becomes soft, and decorate it with homemade ghee and raisins which they put on the top, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1376" ANNOTATION_REF="a632">
                <ANNOTATION_VALUE>and they eat it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1559" ANNOTATION_REF="a1555">
                <ANNOTATION_VALUE>Yes, with spoons…. with their hands, there were no spoons.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1666" ANNOTATION_REF="a1556">
                <ANNOTATION_VALUE>Yes, in the old days there were no spoons…only rarely… but now it is eaten only  with spoons.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1377" ANNOTATION_REF="a633">
                <ANNOTATION_VALUE>It’s really delicious.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1667" ANNOTATION_REF="a1557">
                <ANNOTATION_VALUE>Yes, delicious.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1378" ANNOTATION_REF="a634">
                <ANNOTATION_VALUE>The lazāgi is delicious</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1379" ANNOTATION_REF="a635">
                <ANNOTATION_VALUE>We mentioned the rušūf, they cook the rušūf</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1574" ANNOTATION_REF="a1567">
                <ANNOTATION_VALUE>Sweets? These sweets, they buy the sweets (from) Čāsbān, they purchase sweets from the market, (such as) licorice and other similar items.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1380" ANNOTATION_REF="a636">
                <ANNOTATION_VALUE>But these are the main types of sweets, such as lazāgi and bačīla. They also make hayṭaliyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1705" ANNOTATION_REF="a1568">
                <ANNOTATION_VALUE>The hayṭaliyya is from milk, they milk</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1381" ANNOTATION_REF="a637">
                <ANNOTATION_VALUE>And they bring ǧarīša (cracked wheat), which is a type of wheat, but the ǧarīša must be </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1382" ANNOTATION_REF="a638">
                <ANNOTATION_VALUE>(thoroughly) washed or ground</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1383" ANNOTATION_REF="a639">
                <ANNOTATION_VALUE>this means it contains starch - wheat starch</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1384" ANNOTATION_REF="a640">
                <ANNOTATION_VALUE>they soak it in hot water and continue pressing/squeezing it until they extratc the starch from it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1385" ANNOTATION_REF="a641">
                <ANNOTATION_VALUE>Then they add it to the milk, they put sugar of course with the milk. As the milk boils, they keep stirring it until it thickens, becoming firm like hayṭaliyya, similar to kāstard, like mḥalabiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1386" ANNOTATION_REF="a642">
                <ANNOTATION_VALUE>but this hayṭaliyya is more delicious because it...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1575" ANNOTATION_REF="a1569">
                <ANNOTATION_VALUE>Because it contains milk, because it is made with craked wheat</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1387" ANNOTATION_REF="a643">
                <ANNOTATION_VALUE>Because it's made with cracked wheat, not starch... they don't add starch to it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1388" ANNOTATION_REF="a644">
                <ANNOTATION_VALUE>They make it with ckacked wheat, and it tastes delicious. They extract the starch from the cracked wheat, they wring it out</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1389" ANNOTATION_REF="a645">
                <ANNOTATION_VALUE>make with it the hayṭaliyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1576" ANNOTATION_REF="a1570">
                <ANNOTATION_VALUE>The winter food how important was, they store wheat, they store...they grow lentils, and grow...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1577" ANNOTATION_REF="a1571">
                <ANNOTATION_VALUE>There was not, they cook... they were, how did they preserve [things]? They developed their method to store with them the things/ items </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1391" ANNOTATION_REF="a647">
                <ANNOTATION_VALUE>For example, the meat</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1392" ANNOTATION_REF="a648">
                <ANNOTATION_VALUE>They made the gišīm </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1578" ANNOTATION_REF="a1572">
                <ANNOTATION_VALUE>This gišīm, they melt the sheep fat</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1393" ANNOTATION_REF="a649">
                <ANNOTATION_VALUE>The fat, as soon as/after slaughtering the sheep, they collect the fat, melt it down, and add special spices to it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1394" ANNOTATION_REF="a650">
                <ANNOTATION_VALUE>It becomes yellow, like the ghee, when the fat melts, and they store it in jars</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1395" ANNOTATION_REF="a651">
                <ANNOTATION_VALUE>They would put pieces of meat in it, if they want to preserve it. This was back in the day, before the 1970s. Now we have refrigerators and they preserve </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1396" ANNOTATION_REF="a652">
                <ANNOTATION_VALUE>I mean that before refrigerators, they place it (the meat there), and preserve it in inside,  and when they wanted to cook, they take it out from it and cook</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1397" ANNOTATION_REF="a653">
                <ANNOTATION_VALUE>Also very good</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1579" ANNOTATION_REF="a1573">
                <ANNOTATION_VALUE>This is like the ghee, the local ghee, the fat, I mean they cook in it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1398" ANNOTATION_REF="a654">
                <ANNOTATION_VALUE>The dihn is the one from the cattle, from..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1682" ANNOTATION_REF="a1583">
                <ANNOTATION_VALUE>They cook in it everything</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1399" ANNOTATION_REF="a655">
                <ANNOTATION_VALUE>Everything they cook in it is delicious, yes, they cook lentil soup and also prepare the ḥelwiyya </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1400" ANNOTATION_REF="a656">
                <ANNOTATION_VALUE>The ḥelwiyya is also a type of wheat, ground but finely</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1401" ANNOTATION_REF="a657">
                <ANNOTATION_VALUE>Finely ground, and they cook it with tomatoes. They crush the tomatoes or use tomato water, tomato paste this is what they call it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1402" ANNOTATION_REF="a658">
                <ANNOTATION_VALUE>They cook with it, and eat it, it is good</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1403" ANNOTATION_REF="a659">
                <ANNOTATION_VALUE>I mean with the wheat</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1586" ANNOTATION_REF="a1584">
                <ANNOTATION_VALUE>Before they rarely cook rice, most of their food/ dishes were with wheat</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1404" ANNOTATION_REF="a660">
                <ANNOTATION_VALUE>Now it is all with rice, now people rarely eat wheat, they cook burgul</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1405" ANNOTATION_REF="a661">
                <ANNOTATION_VALUE>They cook mǧi(e)ddarat of burgul, these were the winter dishes, hey also cook potatoes with,I mean the vegetables were seasonal back then unlike today [where] they're always available.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1406" ANNOTATION_REF="a662">
                <ANNOTATION_VALUE>They use to dry tomatoes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1407" ANNOTATION_REF="a663">
                <ANNOTATION_VALUE>When tomatoes were in season, they would slice them, sprinkle salt on them, [place them] on a large trays (sdūr) , and dry them in the sun</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1408" ANNOTATION_REF="a664">
                <ANNOTATION_VALUE>once [the tomatoes] fully dry, they would store them.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1587" ANNOTATION_REF="a1585">
                <ANNOTATION_VALUE>They stay/remain dried, then, when they wanted to use them, they pour hot water over them, press them, and continue mashing them.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1409" ANNOTATION_REF="a665">
                <ANNOTATION_VALUE>When they make it, in other days when was the liban season, mahin (?) they make ghee in summer</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1410" ANNOTATION_REF="a666">
                <ANNOTATION_VALUE>They made ghee and marīs </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1411" ANNOTATION_REF="a667">
                <ANNOTATION_VALUE>They made the labaniyya, this is the one with olive oil</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1412" ANNOTATION_REF="a668">
                <ANNOTATION_VALUE>Yes this, hey store it like provisions, so when it's no longer available, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1413" ANNOTATION_REF="a669">
                <ANNOTATION_VALUE>They eat from it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1414" ANNOTATION_REF="a670">
                <ANNOTATION_VALUE>The ghee itself, of course the milk is the basis of everything.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1686" ANNOTATION_REF="a1590">
                <ANNOTATION_VALUE>Yes, it is milk that one makes ghee from it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1415" ANNOTATION_REF="a671">
                <ANNOTATION_VALUE>They make butter from it, the yogurt, the marīs, the labana</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1416" ANNOTATION_REF="a672">
                <ANNOTATION_VALUE>That we call gaṭīʕ not labana</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1417" ANNOTATION_REF="a673">
                <ANNOTATION_VALUE>Yes it is a little sour, this, they first milk the milk</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1689" ANNOTATION_REF="a1591">
                <ANNOTATION_VALUE>They ferment it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1690" ANNOTATION_REF="a1592">
                <ANNOTATION_VALUE>They make the rayeb</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1418" ANNOTATION_REF="a674">
                <ANNOTATION_VALUE>They add rawba, which is old rayeb yogurt theayy had/ they saved from the day before</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1419" ANNOTATION_REF="a675">
                <ANNOTATION_VALUE>They let it ferment, meaning they allow the fermentation process and make rayeb yogurt.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1420" ANNOTATION_REF="a676">
                <ANNOTATION_VALUE>Before, they prepare saʕin and girgaʕa depending on the milk it had</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1421" ANNOTATION_REF="a677">
                <ANNOTATION_VALUE>The girgaʕa is big</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1422" ANNOTATION_REF="a678">
                <ANNOTATION_VALUE>made from a ram or something big, which means  it is large, it holds a significant amount of milk</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1423" ANNOTATION_REF="a679">
                <ANNOTATION_VALUE>For those who have only a few sheep, it is saʕin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1424" ANNOTATION_REF="a680">
                <ANNOTATION_VALUE>The saʕin they take /make it from the skin of the she-goat, they prepare it, they skin it carefully without tearing it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1425" ANNOTATION_REF="a681">
                <ANNOTATION_VALUE>They skin it, tan the hide, they make it with the tanning agent</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1610" ANNOTATION_REF="a1598">
                <ANNOTATION_VALUE>The tanning agent is bought from the spice vendor/ herbalist and turns its color in red</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1426" ANNOTATION_REF="a682">
                <ANNOTATION_VALUE>to prevent spoilage, they first sprinkle salt on it, and prepare it the process is lengthy</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1427" ANNOTATION_REF="a683">
                <ANNOTATION_VALUE>they bring alum and sprinkle it on, and then they tan it with the tanning agent</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1428" ANNOTATION_REF="a684">
                <ANNOTATION_VALUE>then they clean it, add rayeb yogurt, and continue to churn it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1611" ANNOTATION_REF="a1599">
                <ANNOTATION_VALUE>No, they put rayeb yogurt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1429" ANNOTATION_REF="a685">
                <ANNOTATION_VALUE>They fermet the rayeb</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1612" ANNOTATION_REF="a1600">
                <ANNOTATION_VALUE>The rayeb, they bring the milk, strain it after milking, and then strain it again.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1430" ANNOTATION_REF="a686">
                <ANNOTATION_VALUE>They heat it over the fire, heat it but not too high,  they add a bit of rayeb yogurt that has been kept overnight, this yogurt is called rowba</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1431" ANNOTATION_REF="a687">
                <ANNOTATION_VALUE>They put it on it, cover it, and let it sit for 4 to 5 hours, depending on the weather. If it's warm, it does not take long</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1432" ANNOTATION_REF="a688">
                <ANNOTATION_VALUE>They obtain the rayeb, similar to the buttery rayeb</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1613" ANNOTATION_REF="a1601">
                <ANNOTATION_VALUE>They obtain it, and put it in the saʕin</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1433" ANNOTATION_REF="a689">
                <ANNOTATION_VALUE>They keep churning it, and when they churn, what happens? the butter rises/goes up and the yogurt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1434" ANNOTATION_REF="a690">
                <ANNOTATION_VALUE>this rayeb becomes butter</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1614" ANNOTATION_REF="a1602">
                <ANNOTATION_VALUE>and yogurt, they take it and rassemble/collect it, of course the butter they separate (it) before </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1435" ANNOTATION_REF="a691">
                <ANNOTATION_VALUE>They gather it and keep it for about a month, during which no one is allowed to eat any of the butter.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1436" ANNOTATION_REF="a692">
                <ANNOTATION_VALUE>They distribute the first churning, this is called the first churning. They churn and share it with all the neighbors</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1437" ANNOTATION_REF="a693">
                <ANNOTATION_VALUE>They put a piece butter and a bit of yogurt, and of course, we, the children, would take it and distribute it to all the neighbors</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1438" ANNOTATION_REF="a694">
                <ANNOTATION_VALUE>Yes, we distribute yogurt and butter to the neighbours</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1615" ANNOTATION_REF="a1603">
                <ANNOTATION_VALUE>This is the first churning, they say to you the first churning is distributed/shared</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1439" ANNOTATION_REF="a695">
                <ANNOTATION_VALUE>Then the housekeeper (wife of the owner of the house), gathers the butter. For example, today she takes (some), put to churn a little butter refrigerator.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1440" ANNOTATION_REF="a696">
                <ANNOTATION_VALUE>or in the one she stores in it, she churns, she churns, she churns until she gathers, she holds a large quantity stored away</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1441" ANNOTATION_REF="a697">
                <ANNOTATION_VALUE>They make the grāniyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1616" ANNOTATION_REF="a1604">
                <ANNOTATION_VALUE>This grāniyya, they gather yogurt, I mean they do for the season of churning, the one who was rich for examploe, slaughters sheep, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1442" ANNOTATION_REF="a698">
                <ANNOTATION_VALUE>two sheep, one sheep, depending on their means. For that who cannot, he prepare rušūf</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1443" ANNOTATION_REF="a699">
                <ANNOTATION_VALUE>What is the rušūf?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1444" ANNOTATION_REF="a700">
                <ANNOTATION_VALUE>Now, they haven't gathered the butter yet</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1693" ANNOTATION_REF="a1605">
                <ANNOTATION_VALUE>They pour the yogurt into jars/containers</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1445" ANNOTATION_REF="a701">
                <ANNOTATION_VALUE>the yogurt, which is not in large quantities, they out it in white cloths, a white cloth sewed, they hang it up, allowing the water to drain</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1446" ANNOTATION_REF="a702">
                <ANNOTATION_VALUE>the water from it, the whey and </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1447" ANNOTATION_REF="a703">
                <ANNOTATION_VALUE>the yogurt itself that remains, gathers inside, what do they do with this yogurt that thickens?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1448" ANNOTATION_REF="a704">
                <ANNOTATION_VALUE>We do not obtain butter an yogurt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1617" ANNOTATION_REF="a1606">
                <ANNOTATION_VALUE>This yogurt, what, it doesn´t it remain and drain, and its whey comes out</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1449" ANNOTATION_REF="a705">
                <ANNOTATION_VALUE>With the remaining yogurt, they do the marīs</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1450" ANNOTATION_REF="a706">
                <ANNOTATION_VALUE>If they leave it loose, and if they want it to be marīš, they let it  longer, I mean, for example</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1618" ANNOTATION_REF="a1607">
                <ANNOTATION_VALUE>Two or three weeks</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1451" ANNOTATION_REF="a707">
                <ANNOTATION_VALUE>I mean, less, something in between, according to the weather as well</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1452" ANNOTATION_REF="a708">
                <ANNOTATION_VALUE>The rest... of course also according to the amout of sheep you have, I mean the one who has a lot of sheep</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1453" ANNOTATION_REF="a709">
                <ANNOTATION_VALUE>make, God has willed it, big cloths, that are white cloths sewed like this,  the water drains from them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1454" ANNOTATION_REF="a710">
                <ANNOTATION_VALUE>This is whey, there are people who drink it, it is good for the kidney stones, in the past, they used it to wash away dirt and dark stains. 

</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1455" ANNOTATION_REF="a711">
                <ANNOTATION_VALUE>One says to you "to whiten" (lighten the skin)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1456" ANNOTATION_REF="a712">
                <ANNOTATION_VALUE>And it makes a person completely different... this whey</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1619" ANNOTATION_REF="a1608">
                <ANNOTATION_VALUE>Then the one that stays/remains on the cloth solidifies the milk, what solidifies</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1457" ANNOTATION_REF="a713">
                <ANNOTATION_VALUE>It is called gaṭīʕ (curd), some people make it into a curd, they place it and eat it, and they add oil or a bit of butter and eat it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1458" ANNOTATION_REF="a714">
                <ANNOTATION_VALUE>They dip it with a cloth, like lebana... and some people let it solidify halfway, not too much, and they make 'libaniyya,' which they roll into balls and put in oil.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1459" ANNOTATION_REF="a715">
                <ANNOTATION_VALUE>This is called labaniyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1620" ANNOTATION_REF="a1609">
                <ANNOTATION_VALUE>Yes, and some people leave it, of course, and add a little salt to it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1460" ANNOTATION_REF="a716">
                <ANNOTATION_VALUE>They take it out, add a little salt, and make it into marīs</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1637" ANNOTATION_REF="a1629">
                <ANNOTATION_VALUE>Of course the ǧamīd this is ǧamīd, what they call ǧamīd, we call it marīs</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1461" ANNOTATION_REF="a717">
                <ANNOTATION_VALUE>because they cure it, and they store it; once it dries, they sell it on plates, or in bags, or in something</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1462" ANNOTATION_REF="a718">
                <ANNOTATION_VALUE>when it completely dries... yeah... they put it in their bags... the bags that are like</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1463" ANNOTATION_REF="a719">
                <ANNOTATION_VALUE>white sacks, they tie them up and store them, and they put the marīs in them, of course, they add a lot of salt to it, to prevent it from spoiling... so it doesn't rot or get damaged</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1464" ANNOTATION_REF="a720">
                <ANNOTATION_VALUE>Now we come to the butter that we extract from the milk... yeah... it has some specific spices, they are called ḥawāyiǧ... and they use it to make what? ghee</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1465" ANNOTATION_REF="a721">
                <ANNOTATION_VALUE>Yeah, the spices are ḥawāyiǧ but these ḥawāyiǧ include ground spices like fenugreek, meaning each one has its own spices.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1466" ANNOTATION_REF="a722">
                <ANNOTATION_VALUE>Most of the spices are the same thing</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1467" ANNOTATION_REF="a723">
                <ANNOTATION_VALUE>Some people add something, and some reduce the (amount of) fenugreek</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1638" ANNOTATION_REF="a1630">
                <ANNOTATION_VALUE>The fenugreek and the ground spices, they pick them in the spring and dry them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1468" ANNOTATION_REF="a724">
                <ANNOTATION_VALUE>it comes as a green herb, with yellow flowers.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1469" ANNOTATION_REF="a725">
                <ANNOTATION_VALUE>a little spice... fenugreek, they roast (the fenugreek), then grind it... yeah...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1470" ANNOTATION_REF="a726">
                <ANNOTATION_VALUE>then they put it on the fire</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1471" ANNOTATION_REF="a727">
                <ANNOTATION_VALUE>they bring a little wheat or cracked wheat, the same cracked wheat we said we squeeze to make 'libna,' the 'hayṭaliyya,' which is starch</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1472" ANNOTATION_REF="a728">
                <ANNOTATION_VALUE>some people do it like that, and others use flour </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1473" ANNOTATION_REF="a729">
                <ANNOTATION_VALUE>whoever has cracked wheat available






</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1639" ANNOTATION_REF="a1631">
                <ANNOTATION_VALUE>they don't use flour... cracked wheat is, of course, tastier. This is called 'gišda'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1474" ANNOTATION_REF="a730">
                <ANNOTATION_VALUE>It is tasty, and then its flavor is delicious... they put butter on top of it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1475" ANNOTATION_REF="a731">
                <ANNOTATION_VALUE>and this butter keeps boiling on the fire, on low heat, of course, and they skim off the foam from the top and discard it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1476" ANNOTATION_REF="a732">
                <ANNOTATION_VALUE>it produces foam, and they let it continue to boil and add the spices to the butter</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1477" ANNOTATION_REF="a733">
                <ANNOTATION_VALUE>and the cracked wheat or flour is added, and then they stir it until the butter turns yellow




</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1478" ANNOTATION_REF="a734">
                <ANNOTATION_VALUE>from the spices that we added.





</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1640" ANNOTATION_REF="a1632">
                <ANNOTATION_VALUE>I mean, until the butter melts.






</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1641" ANNOTATION_REF="a1633">
                <ANNOTATION_VALUE>And when it boils, it should take a light simmer like this.






</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1479" ANNOTATION_REF="a735">
                <ANNOTATION_VALUE>then they strain it.. from the spices and the gišda






</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1480" ANNOTATION_REF="a736">
                <ANNOTATION_VALUE>and they put / place it in jars or metal containers.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1642" ANNOTATION_REF="a1634">
                <ANNOTATION_VALUE>These containers are the same ones we use for storing cattle cheese and the same ones we use for</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1643" ANNOTATION_REF="a1635">
                <ANNOTATION_VALUE>But these are square jars/containers called 'samin' jars</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1481" ANNOTATION_REF="a737">
                <ANNOTATION_VALUE>They call them gəṣṣiyāt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1644" ANNOTATION_REF="a1636">
                <ANNOTATION_VALUE>No, smaller, smaller, like the ones of the goat cheese, where they put the goat/cattle cheese</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1482" ANNOTATION_REF="a738">
                <ANNOTATION_VALUE>They put it in these buckets and close it; of course, this is used for winter</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1703" ANNOTATION_REF="a1645">
                <ANNOTATION_VALUE>What else do you want (to know)? what else did they do?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1704" ANNOTATION_REF="a1646">
                <ANNOTATION_VALUE>The ghee, this is how we do it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1487" ANNOTATION_REF="a743">
                <ANNOTATION_VALUE>By God, they are truly admirable, brave, and created with honor from God. 






</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1488" ANNOTATION_REF="a744">
                <ANNOTATION_VALUE>they love guests, and, God willing,  since the time of their ancestors their homes have always been open to guests</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1489" ANNOTATION_REF="a745">
                <ANNOTATION_VALUE>Thanks and praise be to God.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
