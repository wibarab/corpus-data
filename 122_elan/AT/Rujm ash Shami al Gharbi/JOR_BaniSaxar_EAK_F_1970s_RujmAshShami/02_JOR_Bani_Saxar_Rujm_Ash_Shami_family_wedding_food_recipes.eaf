        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a994" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>First thing first, tell us your name</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1493" ANNOTATION_REF="a1490">
                <ANNOTATION_VALUE>The complete (one)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1494" ANNOTATION_REF="a1491">
                <ANNOTATION_VALUE>Your full name</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a998" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>*** how? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1499" ANNOTATION_REF="a1496">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1500" ANNOTATION_REF="a1497">
                <ANNOTATION_VALUE>From the Xaḏ̣īr of the Bani Ṣaxar. How old are you?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1001" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>Where do you live?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1003" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>And have you always lived in the same place? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1004" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>Where did you study? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1007" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>Did you go to the university or not?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1009" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>How old where you when you got married?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1010" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Where is your husband from? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1011" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>Do you go to Amman? Do you go sometimes? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1012" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>Ah, not always </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1509" ANNOTATION_REF="a1502">
                <ANNOTATION_VALUE>When it is needed (lit. in time of need) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1013" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Fine, let's talk about the engagement and the wedding of the Bani Ṣaxar </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1014" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>I mean, the one you want, you are a Ṣxariyya, I mean [let’s] talk about the engagement…</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1015" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>Which are the traditions?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1020" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>from the same branch of the tribe, [ā] Xaḏ̣īr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1021" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>From the same Xaḏ̣īr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1024" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>Ok.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1026" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>How much is the dowery? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1027" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Oh so between the relatives it is not high</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1520" ANNOTATION_REF="a1516">
                <ANNOTATION_VALUE>So the dowry is the bride’s share </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1649" ANNOTATION_REF="a1517">
                <ANNOTATION_VALUE>This was before?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1033" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>he builds a house for himself </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1034" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Which is better, living alone or with family</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1036" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Never? / at all?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1040" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Before the 70ies?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1041" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Fine and now?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1042" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>From Saturday until Friday, 7 days </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1045" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>This is at the groom´s place, the wedding of 7 days</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1047" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>they come and have the party at home.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1525" ANNOTATION_REF="a1521">
                <ANNOTATION_VALUE>There was nothing</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1048" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>But there weren´t during your time</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1526" ANNOTATION_REF="a1522">
                <ANNOTATION_VALUE>It means you did the ḥenna party?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1059" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>It means they invite all their relatives</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1061" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>This was before?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1064" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>There was nothing?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1065" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>A: Okay, so what is there... I mean, now, your engagement, so tell us about yourself.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1653" ANNOTATION_REF="a1528">
                <ANNOTATION_VALUE>Your engagement, did you see my father?  Did you spend time with him [sit with him] before the engagement? Was there...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1654" ANNOTATION_REF="a1529">
                <ANNOTATION_VALUE>Ok</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1072" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>But for you and my father was quick</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1079" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>So, what do you prepare, like what I mean?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1656" ANNOTATION_REF="a1530">
                <ANNOTATION_VALUE>Ok</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1081" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>You lived with my father and his family?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1083" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>How many brothers did he have? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1085" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>she didn't stay with them long</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1086" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>So,  what kind of food is specific to the Bedouins, to the bani ṣaxar?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1087" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>A: for the wedding or in general, what was the food?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1089" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Rušūf</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1657" ANNOTATION_REF="a1534">
                <ANNOTATION_VALUE>What is this fuwwīr?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
