    <TIER ANNOTATOR="Antonella" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="JOR_Bani_Saxar_RAH_M_1970s_Nahda_Transcription"
        PARTICIPANT="JOR_Bani_Saxar_RAH_M_1970s_Nahda" TIER_ID="JOR_Bani_Saxar_RAH_M_1970s_Nahda_Translation">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>The word wigg we say wiǵǵ, it is to say to look</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>The word is lāyaʕan</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>meet someone, I mean I am walking, and someone, a certain person I mean</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>he came to me, we met, this is an old word between the bani Ṣaxar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>To go back</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>yiriʕi is also an old word, means come back</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>You call a person, come back come back, menaing return</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a397">
                <ANNOTATION_VALUE>it is b-raxxa, for example</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>you want to come to me </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>for example, you want to come to me, and I am not free in that moment, I tell you b-raxxa, b-raxxa means wait a little, and come to me </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a471" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>
                    When it comes to food, we say 'may their generosity/prosperity increase.'"
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>
                    Or may God bestow His blessings upon them.
                    
                    
                    
                    
                    
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a472" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>
                    And the most commonly known expressions are 'may their generosity increase' or 'may their goodness multiply.'"
                    
                    
                    
                    
                    
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a473" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>May their generosity increase</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a474" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>Ydann-i al-fāṭir</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a475" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>Ydann-i al-fāṭir</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a476" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Ydann-i al-fāṭir means something like when I scold you, and you start crying … </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a458" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>oh, it means, for example, he starts crying, like "ydann-i al-fāṭir"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a459" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>You're overdoing it, you're overdoing it, like you're going too far... you're pushing it. How? For example, you're talking about me</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a460" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>It means you’ve crossed the line, crossed the line by talking about me, speaking about me. I’m telling you, you’ve gone too far.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>boy or girl, man or woman, when you address a girl, what do we say? Oh, 'tarā-ć azhafti' for the feminine, and for the masculine, 'tarā-k azhaft' means you've crossed the line. Well done, Abu Hattān.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a477" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>I told them all, all of them, I said ykaṯir xēr-aham</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a427" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Maʕać ʕilć, the gum we chew, how do you call it in English? Chewing gum.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a478" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>We call it gum, and when someone gets engaged with a girl, I mean you get enhaged with another (f.), you tell her "do you have a chewing gum"? </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a479" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>--------------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a480" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>-----------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a481" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>I told her</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a482" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>Dinni al-fāṭir who cries.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a428" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>Ydinnīn al-fāṭir</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a483" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>Take your time.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a484" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>B-raxxa, irtax, wait a little</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a485" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>irtixi</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a486" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>Irtixīn, tuwaššaʕan</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a487" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Tuwaššaʕan means he came closer to me</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a488" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>
                    It’s like when you’re sitting, and I get closer to you, that’s what tuwaššaʕan means.
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a500" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>
                    It’s like when someone unwanted gets close to another person.
                    
                    
                    
                    
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a457" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>For fem pl you: tuwaššaʕtan - instead of final in&gt; an beacause of ʕ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a501" ANNOTATION_REF="a499">
                <ANNOTATION_VALUE>tuwaššaʕtan</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a502" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>do you (f.s.) want the offspring of the she camels?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a503" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>Ladle</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a504" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Sickle, plow</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a505" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Plowshare</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a506" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>We say sikak al-miḥrāṯ plowshare</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a507" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Whip</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a508" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>Well, cistern</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a461" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>aćil</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a509" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>Chicken coop</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a510" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>What does sāqiye mean?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a511" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Chicken pool</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a512" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>Cattle-shed</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a513" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>mazraʕa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a559" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>baraks bugar, and the stable is (i)sṭābil al-xiyūl</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a560" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>Beehive is beyt an-naḥal or manḥala</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a561" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>to water (arwa, siga), plow</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a562" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>plow, harvest</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a563" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>threshing wheat - (he understood to study)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a564" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>What is the difference between straw and grains? Grains, we say šaʕīr, and wheat is wheat. The straw is tibin. Do we separate them from each other? I do not know</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>We sift them, no we thresh, first of all we thresh, we thresh the straw, first it is called threshold, one moment.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Before the threshold, first of all we harvest,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>
                    then we pile it up - we put them in a pile-, and later it is threshed.
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>After you thresh it, before, they used to thresh with donkeys, and put a piece of iron like this, and mount it on top of them, and the donkey would keep turning around.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>
                    Then they separate the straw from the... they sift it, and they call it ḏirri.
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Itḏirri, yḏarri</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Shop is diććān, shop - maḥāl is baqqāle</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a565" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>-------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a566" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>The one who works oin the shop is the seller</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a567" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>To buy is ištara, money is gurūš</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a568" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Change is fraṭa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Client is zubūn</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a569" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Dowery is mahar, syāg</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a570" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Siyyāra, bāṣ, ḥāfila are the same for us</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a571" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Cart is karrūza</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a572" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Karrūza is horse-drawn</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a573" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Camion is šāḥine or trēlla for us</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a574" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>What is the zammār?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a575" ANNOTATION_REF="a540">
                <ANNOTATION_VALUE>The horn, zammūr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a576" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>The steering wheel is maqwad, istring or string</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>How do they call it in Saudi? darkasūn, ṭāra, at ours, the Bedouin used to say darkasūn.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a577" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>The clutch?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a578" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>It is klač.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>The speed of the car we say gīr.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>The rear gear is called reverse, and in Saudi Arabia, they call it reverse. Among us Bedouins, it is also called reverse. Brakes are referred to as brake; we say brake.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>The exhaust pipe is ikzist.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Ikzist or šikmān, but in our dialect we say ikzist.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>
                    We call the car tire ʕaǧil, while in Saudi Arabia, they call it kifr. We’re not in Saudi Arabia; we say ʕaǧil.
                    
                    
                    
                    
                    
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>
                    The spare tire is called sbīr and the spare is sbīr when it’s not mounted.
                    
                    
                    
                    
                    
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a579" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>
                    Flat tire or tire malfunction is binšar al-aṭār.
                    
                    
                    
                    
                    
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a580" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Accident is ḥādiṯ, oil station is kāziyya.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>---------------------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>
                    Put it, put a pillow for him. Move him away from John, move him away from John. He's coming, come, come, he's coming.
                    
                    
                    
                    
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>Wine al-wiski</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>----------------------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>We do not drink wine, but beer, Yā gaṭaʕ aṭ-ṭāri</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a581" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>-----------------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a717" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Stamp ṭābaʕ al-barīd, phone talafūn</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>-----------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
