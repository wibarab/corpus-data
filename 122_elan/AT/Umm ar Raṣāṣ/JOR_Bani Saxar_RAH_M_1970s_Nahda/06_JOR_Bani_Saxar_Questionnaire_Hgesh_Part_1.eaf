        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a599" ANNOTATION_REF="a207">
                <ANNOTATION_VALUE>To swim, to stand up</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a600" ANNOTATION_REF="a208">
