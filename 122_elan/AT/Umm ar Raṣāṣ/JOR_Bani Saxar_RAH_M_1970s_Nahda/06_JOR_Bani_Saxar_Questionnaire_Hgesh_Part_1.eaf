    <TIER ANNOTATOR="Antonella" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="JOR_BaniSaxar_MAH_M_1980s_UmmArRasas_Transcription"
        PARTICIPANT="JOR_BaniSaxar_MAH_M_1980s_UmmArRasas" TIER_ID="JOR_BaniSaxar_MAH_M_1980s_UmmArRasas_Translation">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a497" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>Tuwaššaʕan</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a529" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Whip</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a530" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>You skipped the word sāqiye</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a531" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>What does sāqiye mean?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a532" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>We say ganāt mayye,nabaʕ mayye - hydraulic wheel</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a533" ANNOTATION_REF="a169">
                <ANNOTATION_VALUE>No it is xumm ad-daǧāǧ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a534" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>No, it is called baraks for the cattle</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a705" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE>to buy or to shop</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a706" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>Oh boy (typical expression)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a320" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE>-------------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a321" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>--------------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a707" ANNOTATION_REF="a703">
                <ANNOTATION_VALUE>------------------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a708" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>And don't follow me. Do you know what 'don't follow me' means? It means don't stand behind me, like I'm sitting behind Raed. Don't stand behind me just because I'm your older brother, it's fine.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE>------------</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
