            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>To go back (the vowel a in the last raǧaʕ is similar to u)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>
                    The day you get upset with her, you say, may you stumble, and may you not see the way. (like ktibat same resyllabification)
                    
                    
                    
                    
                    
                    
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a594" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>To come back</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
