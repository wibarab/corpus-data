                <ANNOTATION_VALUE>معتش علتش </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a535" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>سوط هيو تحت سوط.. اه مطرق</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a536" ANNOTATION_REF="a166">
                <ANNOTATION_VALUE>دقيقة دقيقة تعدّيت كلمه انت ، ساقيه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a537" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>وشنهي ساقيه؟.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a538" ANNOTATION_REF="a168">
                <ANNOTATION_VALUE>ساقيه قناة ميّه، نبع ميّه، حنا نقوله قناة ميّه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a539" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>لا بركس بقر </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a709" ANNOTATION_REF="a171">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a710" ANNOTATION_REF="a172">
                <ANNOTATION_VALUE>يا همالالي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a711" ANNOTATION_REF="a173">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a712" ANNOTATION_REF="a174">
                <ANNOTATION_VALUE>يا همالالي كيف؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a713" ANNOTATION_REF="a703">
                <ANNOTATION_VALUE>، شو معنى همالالي ماله توالي؟..لأ؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a835" ANNOTATION_REF="a175">
                <ANNOTATION_VALUE>و لا تقفّاني ، عارفة شو يعني لا تقفّاني ؟.. يعني لا تقف وراي ، مثل انا قاعد ورا رائد ، لا تقف وراي بس لاني اخوك الكبير عادي </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a470" ANNOTATION_REF="a176">
                <ANNOTATION_VALUE> طيب شق طريقه ما تجي مثلاً فتح طريقه! لأ، صح؟ </ANNOTATION_VALUE>
