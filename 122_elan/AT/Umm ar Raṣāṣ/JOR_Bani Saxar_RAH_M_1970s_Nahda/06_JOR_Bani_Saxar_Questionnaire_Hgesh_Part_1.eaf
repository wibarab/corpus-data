            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a718" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Paint</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a719" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>To go</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a720" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>To follow, go away</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a322" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE> I go, he goes, 'don't call the one who's gone' it means don't call the person who has left. (form 4 preserved)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a587" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>To walk</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a588" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>To walk slowly</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a589" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>To walk slowly</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a590" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>To go, leave, depart</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a591" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a592" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>he leaves (to the kids: don’t fight, what’s wrong with you? They’re messing around, just let them)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a593" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>To set off</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a721" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>We do not have it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a323" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>They mean all the same</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a324" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>To enter</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a325" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>For example, Mhanna enters our place, he wants to enter some people´s (Beoduins) place </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a722" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>To go out</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a723" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>To go down</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a724" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>To descend something</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a725" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>To go, to the city, to the market is rāḥ or inḥadar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a836" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>To go to the market</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a837" ANNOTATION_REF="a177">
                <ANNOTATION_VALUE>To go on the street, to  mount</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a838" ANNOTATION_REF="a178">
                <ANNOTATION_VALUE>to  mount</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a839" ANNOTATION_REF="a179">
