    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker28_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker28" TIER_ID="SAU_2022_Speaker28_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a20" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>الحداوة إيش؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a21" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>اي قبل بس</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a22" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>برّكت حيران عبس..اه.. برّكت حيران عبس ، هاذي حداه على، يومن يحدون على البيار ، بعد يوم يسقون،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a23" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>، يقول برّكت حيران عبس، بركت حيران عبس حيران، صغار ، برّكت يعني ربطن ابن النوق،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a24" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>، برّكت حيران عبس بين ظل و بين شمس ، برّكت حيران عبس بين ظل و بين شمس و يسقون...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a25" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>وش غير بعد.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a26" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>اي يا...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a27" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>لو الله شالو، يوم يشدّون يشيلون عالبعارين ، يشيلون يبا(يريدون) يمشون</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a28" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>يشيلون اغراضهم على الابل يبا يمشون شادّين عن الموقع هذا يبون موقع ثاني</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a29" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>لو الله شاله، لو الله شالو  ، بدو اللي جرّوا حالو ، بدو اللي جرّوا حالو، بدو اللي جرّوا حالو، ها من هذا الكلام </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a30" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>وش غير تبين؟... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a31" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>اي نعم نعم الولد، البنت في الغنم تسرح و الولد مع الإبل و الجمال اللي عليها الشيل عند ابوه عند امه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a32" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>قصيد و لا وشّو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a33" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>... مِثل!، اللهم يا رب لك كلنا.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a34" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>مثل يقول سنّع أهلكو لو اني انا أعجز... طيب... سنّع أهلك و سنّع حقنا و سنّع الحلال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a35" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>... انا مني(لست) شاعر بس احفظ شعر الناس، خلق الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a36" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>الشعر انا والله اني شعّار ما اقدر اتكلم و الناس عندي هانا.. اللي شفته غبصت  انا خلاص</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a37" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>انا راوي، انا نص راوي بعد ما في راوي كامل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
