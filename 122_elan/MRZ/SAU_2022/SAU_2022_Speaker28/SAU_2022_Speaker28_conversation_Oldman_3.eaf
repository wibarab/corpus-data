    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Phrases "
        PARTICIPANT="SAU_2022_Speaker28" TIER_ID="SAU_2022_Speaker28_Transcription-txt">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>wēš, wēš baʕad yā duktūra?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>wēš fī kalām tabġeyn?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>awwal walad mowt, w ṯāni walad mowt, w ṯāliṯ walad mowt, w ṯāni bint mowt, w ṯāni bint mowt, w ṯāliṯ... sādis bint mowt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>w l-ḥamdilla hāl-ḥīn mawǧūdīn ʕišrīn, ʕišrīn min ġeyr haḏōla, haḏōlāk mowt, w ʕišrīn # al-ḥamdi l-illa w iš-šikir</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>tizawwaǧt marra ṯānya, tizawwaǧt marra ṯānya w b-xeyr, w illi minn-i bass, w salāmat hā-l-wiǧh</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts17">
                <ANNOTATION_VALUE>waḷḷa ana adawwar marra law inn-i algā-l-i waḥda ərdiniyya maḏ̣būṭa walla, walla,  ḥatta law alga saʕūdiyya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts21">
                <ANNOTATION_VALUE>yuba # muštahī-ha s-saʕūdiyya mā-ʕand-i ġeyr hāda ʕaǧūz, illi bass tinsil</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>hā, hā yā duktūra, wēš fī suwāl ṯāni?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>al-gibāl fī-ha ḏiyāba tara, tara l-gbāl il hnā? ḥarr, fī-ha ḏiyāba, ḏiyāba  </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>li-ḥatta l-ḥīn fī-ha ḏiyāba bass mā-hī miṯil awwal galīla ḏiwā</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>w taxāf min is-siyyārāt w taxāf min...</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>fī-ha, ʕand-ana klāb, klāb, ay, kalb yākul iḏ-ḏīb, iḏā, yaḏbaḥ-a</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>klāb w ʕind-ana barūd narmī-_́,  barūd</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>kull wāḥid, kull beyt, maʕā-h, ʕind-a barūda, yaḏbaḥ aḏ-ḏīb ʕala ṭūl</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>lā, lā, lā, lā, lā b-xeyr, min yowm ṭalaʕt ana l-i ṯmānīn ḏuwā, ṯmānīn sana,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>min yowm ṭalaʕt w ḥinna b-xeyr l-ḥamdu l-illa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts49">
                <ANNOTATION_VALUE>iy waḷḷa l-ḥamdu l-illa, min faḏ̣l alla</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>lā, lā, lā, mā-_́xāf, ana arūḥ amriḥ il-ḥāl-i b-siyyārt-i hāl-ḥīn, mā-fī, mā-fī xowfa, mā-fī xowfa l-ḥamdu l-illa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>al-ḥamdillaḥ mā-fī xowf, iywa, ḥinna b-xeyr, naḥmad aḷḷa, w dīrat-na, w dīrat-na trabbiʔ ((#why ʔ)) l-mawāši, trabbi l-ibil #, taʕīš fī-ha subḥān aḷḷah, mā-yarḏ̣a arḏ̣, taʕīš fī-ha l-muwāši w taġaḏḏa fī-ha taġaḏḏa</ANNOTATION_VALUE>
