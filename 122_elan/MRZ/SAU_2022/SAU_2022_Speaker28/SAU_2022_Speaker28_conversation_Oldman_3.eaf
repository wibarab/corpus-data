    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker28_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker28" TIER_ID="SAU_2022_Speaker28_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a20" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>وش بعد يا دكتوره </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a21" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE> وش في كلام تبغين </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a22" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>أول ولد موت، و ثاني ولد موت، و ثالث ولد موت، و ثاني بنت موت ، و ثالث،  سادس بنت موت، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a23" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>و الحمد لله الحين موجودين عشرين 20، من غير هذول ، هذولاك موت، و عشرين الحمد لله و الشكر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a24" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>تزوجت مرّه ثانيه، و بخير ، و اللي مني بس وسلامة هالوجه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a25" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>و الله ادوّر مرّه لو اني الاقي وحده أردنيه مضبوطة ولّا حتى لو ألقى سعوديه..سعودية؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a26" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>؟... يُبا، مشتهيها السعوديه ما عندي غير هالعجوز اللي بس تنسل </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a27" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>ها يا دكتوره وش فيه سؤال ثاني ؟.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a28" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>الجبال فيها ذيابه ترا... ترا الجبال اللي هنا حرّ فيها ذيابه، ذيابه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a29" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>لحتى الحين فيها ذيابه بس ما هي مثل أول قليل ذوا،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a30" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>و تخاف من السيارات و تخاف</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a31" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>في  عندنا كلاب، الكلب ياكل الذيب، يذبحه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a32" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>.. و كلاب و عندنا بارود نرميها، بارود </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a33" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>  كل واحد كل بيت معه، عنده باروده، يذبح الذيب على طول</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a34" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>... لا لا بخير من يوم طلعت انا لي 80 ثمانين ذوا، 80 سنه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a35" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>سنه طلعت و حنا بخير الحمد لله </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a36" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>ايه الحمد لله، الفضل لله.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a37" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>لا لا ما أخاف أنا اروح امرح لحالي بسيارتي هالحين، ما في خوف الحمد لله،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a38" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>، ايوه حنا بخير ، نحمد الله  ديرتنا و ديرتنا تربي المواشي تربي الابل تعيش فيها سبحان الله ما هي ارض، ارض تعيش فيها المواشي و تغذّى فيها، تغذّى </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
