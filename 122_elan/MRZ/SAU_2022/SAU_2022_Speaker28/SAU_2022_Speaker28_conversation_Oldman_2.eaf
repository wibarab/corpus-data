        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>b-il-bādiya, nʕīš b-il-ġanam, w il-ibil, w išiddūn badu </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>yāxḏūn, yāxḏūn b-il-mowgiʕ il-wāḥid, yimkin šahar, ximsṭaʕš yowm, gālu d-dīrah, haḏīk fī-ha rabīʕ fī-ha ʕišib, akil w ġanam w-al-ibil</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts9">
                <ANNOTATION_VALUE>yšīlūn yǧībūn ʕala l-gmāl </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts10" TIME_SLOT_REF2="ts13">
                <ANNOTATION_VALUE>ʕala t-tamar w bass w-al-ḥalīb bass, yšīlūn ʕala l-ǧimāl w yšiddūn ʕal-ibil, šift int al-ǧimāl il-...</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts17">
                <ANNOTATION_VALUE>iy, iywa, yšīlūn ʕala l-ʕafšu. il-beyt, il-beyt šaʕar w yšiddūn w yinzilūn b-il-maḥall al-flāni yaʕni, zayy-mā tgūlīn xamsṭaʕš kīlū, ʕišrīn kīlū, b-il-mowgaʕ al-, w yaǧlasūn fī-_́, tigahwi, tigahwi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>beyyen # yaṭīḥ min ál-maṭar ar-rabīʕ, yiǧi min aḷḷa subḥān w taʕāla </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
