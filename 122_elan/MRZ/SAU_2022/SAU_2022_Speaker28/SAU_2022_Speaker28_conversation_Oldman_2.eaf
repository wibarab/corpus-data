                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>yiǧi w ygūlūn tara l-mawgiʕ al-flāni fī-h rabīʕ, išiddūn l-al-badu yrūḥū-l-ah </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
