                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>fī-h baʕad, al-beyt al-ǧadīd, yā duktūra aḷḷa yʕāf-ič anti w min yasmaʕ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>ysawwunn-ah l-ḥarīm, min šaʕar ál-ġanam, taʕrifīn šaʕar ál-ġanam</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts109">
                <ANNOTATION_VALUE>šaʕar ál-ġanam, yiḏillūn-ah, yiḏillūn-a, ygiṣṣūn-a #</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>aššaʕ-... aṣ-ṣūf?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts114" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>aṣbar yā-_́xu-y, aṣbar!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>as-sadu ysawwin yabaninn-h awwal, yġazzlinn-ah ġazil ysawwinn-ah, tagūlīn makāyin māšaḷḷa šuġul-hin, tugūlīn yištaġlin b-makkīna w hī badu</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>ysawwi ē-..., ysawwi xyūṭ kiṯīra xyūṭ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>w ysawwi sadu, is-sadu zayy hāḏi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>lā, baʕd il-ʕirs, baʕd il-ʕirs ysawwūn-ah ṭawwāli, w ysawwūn beyt-ha, w ysawwūn beyt-ha, w xalāṣ hāḏa beyt iflāna xalāṣ, ṯumm ysawwūn il-ʕirs</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="SAU_2022_Speaker28_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker28" TIER_ID="SAU_2022_Speaker28_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker28_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker28" TIER_ID="SAU_2022_Speaker28_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a42" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>ي بالباديه نعيش بالغنم و الإبل، و يشدّون بدو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a43" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE> ياخذون، ياخذون بالموقع الواحد يمكن شهر ، 15 خمسطعش يوم، و قالو الديرة هذيك فيها ربيع ، فيها عشب ، أكل للغنم و الابل </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a44" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>يشيلون ، يجيبون على الجمال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a45" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>على التمر و بس ، حليب بس، يشدّون على الجمال، يشدّون على البل، شفتي انتي جمال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a46" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>ايه يشيلون عليه العفش، البيت، بيت شعر و يشدّون، ينزلون  بالمحل الفلاني، يعني زي ما تقولين 15 كيلو ، عشرين 20 كيلو بالموقع و يجلسون فيه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a47" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>، بيّن ربيع يطيح من المطر الرّبيع يجي من الله سبحانه و تعالى </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a48" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>، يجي يقولون ترا الموقع الفلاني فيه ربيع يشدّون له البدو يروحون له</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a49" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>لا غلّق الربيع، قالو الربيع في الديرة، يشدّون،يشيلون على الابل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a50" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>الابل يشيلون على الابل و يروحون ايه، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a51" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>؟... يا قبل في فرد عشرين، و في فرد، ما هو سوى، كثير ناس قبايل الله اعلم فيها بحرن</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a52" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>كلنا الله سبحانه و تعالى عارفن عيشته و عارفن</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a53" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>انا؟ طلعت ، كل الناس انزلت الهجره قليل اللي الحين في البادية، قليل اللي في الباديه الحين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a54" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>نزلت في القرى الحمد لله، و يوم حكم ابن سعود و حرّر الديره</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a55" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>جلسوا الناس و تريّحوا، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a56" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>و راحت الباديه و في بدو لليوم في بدو، في بدو لكن تعلموا سواقة السيارت و عندهم سيارات ، هالحين، الحين البرّ اللي حنا ساكنين فيه من اول، اول ما فيه غير الذيب، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a57" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>، الذيب ، هالحين الحمد لله كلّه سيارات و كلّه.. ايه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a82" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>تزوجت كل الامور تحسنت شوي </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a83" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>يعني كنّا نبتع حلال و غنم، شوي الجمال شوي، شوي شوي،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a84" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>، تزوجت، زوّجني واحد من جماعتي </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a85" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>من الرجال اللي، زوجّني</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a86" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE> و الحمد لله خلّفت عيال و الحمد لله و أرزاق و تاخذ شوي لين صرنا هالحين بخير من الله سبحانه، الحين كل، ايه نعم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a87" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>الزواج دوريلي مره و اعلمتش كيف يصير الزواج</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a88" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>، العرس يقولون ترا في عرس يذبحون ذبيحه، هاك الحين ذبيحه واحده بس</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a89" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>، يذبحون ذبيحه و يعزمون الجيران</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a90" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>الله يحييكو على عرس فلان تزوّج فلانه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a91" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>و يذبحون و يرقصون، البدو يرقصون، شفتي انتي تصيرين مطربه(singer) ،الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a92" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>الله، و يرقصون و بخير و يصبحون بخير </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a93" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>و نستملك عند الملك و خلصنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>ما هي كبيرة، لا لا ما هي كبيرة </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>كبيرة اللي يجي الاقارب العمّان (الأعمام) و الجماعه عسى عرسكو مبارك و كذا الكلام، بسم الله...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>ها، يا حليلكو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a97" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>؟... الكل يعيش بالبرّ بدو ايه، بدو والناحه من دونهم..ها، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a98" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>في البيت الجديد يا دكتوره، الله يعافيتش انتي و من يسمع،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a99" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>يسّوونه الحريم من شعر الغنن، الشعر تعرفين شعر الغنم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a100" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>، شعر الغنم يذلونه، يثلونه، يقصّونه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a101" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>؟ الشعر، الصّوف</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a102" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>اصبر يا خوي اصبر </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a103" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>السدي يبننه اول، يغزلنه غزل يسووّنه، تقولين مكاين ما شاء الله شغلهن، تقولين يشتغلن بمكينه و هي بدو، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>يسوي خيوط كثيرة، خيوط،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a105" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>و يسوي سدو، سدو زي هاذي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>الي(مباشرةّ) و يسوّون بيتها و يسوّون بيتها و خلاص هذا بيت فلانه خلاص ثم يسوّون العرس..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
