                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>lā ġallaq ar-rabīʕ, gālaw r-rabīʕ f-il-garya, yšiddūn, yšīlūn ʕala l-abil</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
