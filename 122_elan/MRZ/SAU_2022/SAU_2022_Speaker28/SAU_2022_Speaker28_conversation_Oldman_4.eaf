        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>iḏ̣-ḏ̣urūriyya ḥinna nsannaʕ al-ġanam, in tikāṯar, nsawwī-ha,  nxallī-ha tikāṯar w nǧammaʕ-ha w nxallī-ha tikāṯar w nāxiḏ min-ha l-ḥalīb w al-bagal, taʕrifīna l-ḥalīb w il-bagal?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>w nāxiḏ min al-bagal wa-ḥalīb, w yaǧmaʕūn-a w is-saman, yā ḥaṣalu s-saman, s-saman il-barri</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>yā ḥaṣalū-h rāḥu ybīʕūn-a f-il-aswāg fī l-midīna w f-xaybar</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
