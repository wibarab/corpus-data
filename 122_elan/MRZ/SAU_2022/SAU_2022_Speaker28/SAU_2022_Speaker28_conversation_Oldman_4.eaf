    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker28_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker28" TIER_ID="SAU_2022_Speaker28_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a23" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>الضرورية حنّا نسنّع الغنم ان تكاثر، نسوّيها، نخليها تكاثر و نجمعها و نخليها تكاثر و ناخذ من الحليب و البقل(منتج ألبان مجفف و حامض يشبه الجميد الأردني) تعرفين الحليب و البقل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a24" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>، ناخذ من الحليب و البقل ، و يجمعونه و السمن لا حصّلو السمن، السمن البرّي </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a25" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>لا حصّلوه راحو يبيعونه في الاسواق في المدينه و بخير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a26" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>، يجيبون أكل، يجيبون،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a27" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>حنطه، و دخن، و ايه ، و رز و يجيبون من السمن و يبيعون البقل، مثل الغنم </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a28" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>هذا يبيعوها، هاذي فيها فايده تجيب قروش و هاي يبيعون، شاه شاهتين، خمس، عشر ،هه تجمّع ، يهبطون مجموعة يعني مثل ناس يروحون للبلد يبيعون</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a29" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>كلن يبيع خمس شاه، اربعه شاه و يجمّع لأهله يجيب الأرزاق </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a30" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>و الأكل، ايوه و سلامتك على الله ، اسألي بعد وش فيه؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a31" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>؟... يشترون ملابس، يشترون قهوه مُرّه، القهوه المُرّه، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a32" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE> و يشترون تمر و يشترون الأكل، الرز، و القهوه، الشاهي(شاي) لا الشاهي لا، هاك الحين ما في شاهي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a33" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>و يجمعونه و يجيبونه، يجيبون حب يطحنونه بالرَّحا، عندهم رحا، رحا طحّانه، زي الطحّانه للقهوه، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a34" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>، يطحنونه و مسنعين حالهم الناس سبحان الله العظيم </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a35" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>، ايه يحط فيها رحا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a36" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>يقولون حطن فيها، يعبونّها، و يطحنونها و تطحن الحب، سبحان الله ، ايه حجر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a37" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>طحنالنا بورطة(اي وقعنا في مشكله)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a38" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>؟.. لا بس تسأل ، يا خي شف قلت يطحنون في الرحا كذا،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a39" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>قالت طيب فيها اغنيه، فيها شي؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a40" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>... اصبر اصبر و انا اردّه انا الحين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a41" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>ايه شواهد.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a42" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>أول في يقولون، فيها اغنيه فيها اغنيه يقولونها و حنا نطحن</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a43" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>و الله ان فيها اغنيه لكن.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a44" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>و الله اني دايمن فرد فيها اغنيه ما  ((i dont agree with salsabeel))</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a86" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>هذا على البير يقولون، يجلبون </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a87" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>جلب البير يقولون</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a88" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>يقولون يجلبون هذا دلو هان يقول لو الله شالو، لو الله شالو، بدو اللي جرّوا حالو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a89" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>... ايه يا راعية الغنم، الغنم قاهرتها الغنم تشرب، هه انتي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a90" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>هه انتي شفتيها البير في المقاطع</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>، و يقول صب الهوى صب، الجمال ، يجو يسقونهم ايه اثنين، واحد كذا و واحد كذا، و دلو حقت مويه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a105" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>مويه يوردها،يقول صب الهوى صب، صب الهوى صب، يا وجه الضب يا وجه الضب</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>و على كذا و يسقون و يروون وش اسمه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a107" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>الرواوي، قِربه، حقّت مويه، قربه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a108" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>قربه و يعبّون وعلى بعارينهم و لّا على حميرهم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a109" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>و يصدرون لأهلهم عن المويه هذا شوي مشوار</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a110" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>، يمكن 5 خمسه كيلو،10 عشره كيلو و يصدرون و </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a111" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>لا جو البيت تقهوو و انزلو </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a112" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>و لا خذوا اسبوع ، اسبوعين شدّوا من المحل هذا ، و شالو على بعارين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a113" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>بعارين ايه و سلامة هالوجه.. وش الرحا، وش يقولون</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a114" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>، الرحا هاذي وش يقولون ، حدايته كيف؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a115" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>و الله انها زانت</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>هذا لا شالو عدول ، عدول مليانات تمر و لّا شي </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>شي و يقولو، يشيلونها اثنين يعني معبيّنها تمر، معبينها </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>معبينها و يقولو اربعه شالو جمل و الجمل ما شالهم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>عرفتي كذا، سجّل هذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>... اريعه شالو جمل و الجمل ما شالهم، ها يتساعدون يعني.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>اربعه يشيلون الجمل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>، يحدون ايه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
