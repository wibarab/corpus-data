        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
                TIME_SLOT_REF1="ts70" TIME_SLOT_REF2="ts73">
                <ANNOTATION_VALUE>lā fī-h maʕlūma bass arīd aʕallm-ak...</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a66"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ṭayyib, aḷḷa yṭawwil ʕumr-ak, ana ab# ḥil bidāl-ik ana bidāl-ik, ab asʔal</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>ana b-asʔal w yitkallam </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68"
                TIME_SLOT_REF1="ts82" TIME_SLOT_REF2="ts85">
                <ANNOTATION_VALUE>aywa, aywa, bass fī ḥāǧāt, al-ḥarra li intu ʕayšīn ṭibīʕat-ha wišši? il-ḥarra li intu ʕāyšīn fī-ha? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69"
                TIME_SLOT_REF1="ts86" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>hī manṭaqa burkāniyya?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts90" TIME_SLOT_REF2="ts93">
                <ANNOTATION_VALUE>waʕrah al-manṭaqa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts97">
                <ANNOTATION_VALUE>fī-ha d-daxal, fī-ha duxūl?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts101">
                <ANNOTATION_VALUE>taǧri l-miyyāh min taḥt il-arḏ̣, miǧāri l-il-miyyāh min taḥt il-arḏ̣</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts102" TIME_SLOT_REF2="ts105">
                <ANNOTATION_VALUE>tamši taḥt al-arḏ̣</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74"
                TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts109">
                <ANNOTATION_VALUE>kuhūf hāḏi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts113">
                <ANNOTATION_VALUE>kamm ṭūl al-kahfa l-wāḥid f-il-manṭaqa hāḏi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76"
                TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts121">
                <ANNOTATION_VALUE>ṭayyib</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a77"
                TIME_SLOT_REF1="ts122" TIME_SLOT_REF2="ts125">
                <ANNOTATION_VALUE>alḥina, hal-ḥina waqt aš-, aṛ-ṛabīʕ w aš-, aṛ-ṛabīʕ waqt aṛ-ṛabīʕ, ant trabbi ēš min al-māšiya, wēš ʕand-iku min al-mawāš?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78"
                TIME_SLOT_REF1="ts126" TIME_SLOT_REF2="ts129">
                <ANNOTATION_VALUE>wēš tākil min-a, ġeyr aṛ-ṛabīʕ w-al-ʕišib? hal tištirūn la-ha burma?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a79"
                TIME_SLOT_REF1="ts130" TIME_SLOT_REF2="ts133">
                <ANNOTATION_VALUE>iywa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a80"
                TIME_SLOT_REF1="ts136" TIME_SLOT_REF2="ts139">
                <ANNOTATION_VALUE>ṭayyib hal-ḥīna ḥālat-kum, al-byūt aš-šaʕar hāḏi, al intum mustaxdimīn-ha ka-badu, mneyn taṣnaʕūn-_́a?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81"
                TIME_SLOT_REF1="ts140" TIME_SLOT_REF2="ts145">
                <ANNOTATION_VALUE>ṭayyib, hal-ḥīna simiʕna inn ál-bint, inn ál-bint al-awwala, al-yatīma, illi umm-uha mātat, yiʕāwn-in-ha grībāt-ha fī ṣināʕat al-beyt, w titaxxar f-iṣ-ṣināʕa, amma ál-bint illi ʕand-aha umm, taṣnaʕ-al-ha l-beyt mubakkir</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a82"
                TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts149">
                <ANNOTATION_VALUE>hāḏa l-ḥasās yaʕni</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a83"
                TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>ṭayyib </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="SAU_2022_Speaker1_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker1" TIER_ID="SAU_2022_Speaker1_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker1_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker1" TIER_ID="SAU_2022_Speaker1_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a84" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>.. الله يرضى عليك هي تبغى حياتك في الطفولة تسرح ، الصبح يوم يسري الصبح وين تروح</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a85" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>.. المويه كيف تستخرجه من البير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a86" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>... اسمعني اسمعني... ايه.. انت يا ابو </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a87" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>الله يرضى عليك وين كنتو تعيشيون انتو؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a88" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>ب حرّة النار هاذي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a89" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>حرّة بني رشيد </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a90" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE> هذا الموقع الأساسي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a91" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>الحين الحرّه اتجاهها المنطقة ارتفاع هي عن مستوى سطح البحر  بألف وثمنانمية 1800 متر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a92" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>ألفين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a93" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>معروف</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>رح رح واصل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>؟.. لا فيه معلومة بس بس اريد اعلمك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>طيب الله يطوّل عمرك... انا أبا أحل بدالك ، انا بدالك، ابا اسأل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>، انا بسأل و يتلكم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>ايوه ايوه بس في حاجات، الحرّه اللي انتو عايشين فيها طبيعتها وشّيّ؟...الحرّه اللي انتو عايشين فيها؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>هي منطقة بركانيّة؟.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>... وِعره المنطقة؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>... فيها دحل، فيها دحول</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>تجري المياه من تحت الارض مجاري للمياه من تحت الارض.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE> تحت الارض</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>كم طول الكهف الواحد في المنطقة هاذي؟.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>... هالحينه وقت الربيع، وقت الربيع انت تربّي ايش من الماشيه وش عندك المواشي؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>... وش تاكل منه غير الربيع و العشب؟ هل تشترون لها برمه؟(غذاء الماشية) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>طيب هالحينه حالتكم البيوت الشعر هاذي..  اي يا ابوي..  اللي انتو مستخدمينها كَ بدو.... اي نعم... منين تصنعونها؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>طيب، هالحينه سمعنا انه البنت الأوله، اليتيمه اللي امها ماتت، يعاوننها قريباتها في صناعة البيت ...نعم نعم...و تتأخر في الصناعة...على طول... أما البنت اللي عندها أم تصنعلها البيت مبكّر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>.. هذا الحساس </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
