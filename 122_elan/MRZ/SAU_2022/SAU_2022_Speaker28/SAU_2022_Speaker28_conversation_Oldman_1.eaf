                <ANNOTATION_VALUE>tiʕīš ʕala ṭāl ʕamr-ak, ʕala rīʕī-ha ḥagg al-maṭar illi ǧāʔ, b-awwal al-wagt w tarʕa min il-gšūʕ w min al-xaṣāb w ant taʕrif dīrat-na fī-ha ḥamḏ̣ w fī-ha šindi w fī-ha xaṣāb w fī-ha ʕawsaǧ, tākl-a l-ġanam min-a w tiʕīš</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts137">
                <ANNOTATION_VALUE>w baʕḏ̣ al-awgāt tingiṭʕ al-amṭār tiwaxxar w yaṣīb al-ʕarab, nigṣān b-al-amwāl w al-ḥalāl w l-ġanam w baʕd-ēha, w awgāti aḷḷa subḥān aḷḷa w taʕāla yarzig-hum b-ir-ribīʕ w ʕāyša ad-dinya ʕala kiḏa </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts138" TIME_SLOT_REF2="ts141">
                <ANNOTATION_VALUE>naṣnaʕūn-ha min ġazal ál-ġanam, min ġazal ál-ġanam, ay</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts142" TIME_SLOT_REF2="ts143">
                <ANNOTATION_VALUE>ʕala ṭūl</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts144" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>mā-yixtāǧ hāḏa kiḏa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts148" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>iy naʕam naʕam, w-..., iy uxū-ya aḥna b-is-siwālif</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="SAU_2022_Speaker28_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker28" TIER_ID="SAU_2022_Speaker28_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker28_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker28" TIER_ID="SAU_2022_Speaker28_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a37" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>مثل ايش يا دكتوره؟.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a38" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>الحياه، مات ابوي و انا لي اربع 4 سنين،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a39" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>، و ماتت امي و انا لي عشر 10 سنين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a40" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>و عشت يتيم </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a41" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE> يتيم مع الخوال و العمّان(الأعمام)  و ترعرعت لين الحمد لله، الله سوّاها و صار الوقت، الناس كلها زينه و الاقارب زينه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a42" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>و ترعرعنا و شوي شوي لين حنا رزقنا الله و توّظفنا و تعلمنا شوي شوي من علم الناس ما، علم أُمّيه ما هو علمن، لكن اسلوب ، اسلوب.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a43" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>عن المويه بير بير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a44" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>الله يجزاك خير  ايه يا اخويا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a45" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>حنا نعيش بالحرً</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a46" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>... ب حرّة النار نعم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a47" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>حرّة بني رشيد </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a48" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>... اي نعم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a49" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>أنا و لا لك لا قاطع ،رحت مع واحد مدرّس، مدرّس ...معروف.. تعرفونه.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a50" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>تعرفونه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a51" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>و قاس و عدّينا..ها؟.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a52" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>... و يقول المقاس خسّ بالمقاس هذا يقول مرتفعه عن الوطن هذا ثمنطعش 18 كيلو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a107" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>جبال الله يسلمك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a108" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>؟... بركانيه نعم.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a109" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>؟.. اي وعره ما يحتاج</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a110" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>فيها دحول</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a111" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>... نعم نعم فيها دحول، فيها دحول غير تولّع بضوّ تخشّ (تدخل) فيها </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a112" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE> تحت الارض</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a113" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>كهوف هاذي دحول و فيها مويه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a114" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>؟... و الله في كهف في الميتين 200طال عمرك حول</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a115" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>، و في كهف طال عمرك ، كهوف واجد واجد كثير </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>حنّا روّحنا فيها بغينا نغدي مره</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>اربّي الغنم، و الإبل بس هذا اللي حنّا نربيه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>لا لا ما نشتريلها و لا حاجه تعيش على</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>حاجه تعيش على - طال عمرك- على ريعها حقّ المطر اللي جا بأول الوقت و ترعى من القشوع(بقايا النباتات او المراعي القليلة) و من الخصاب(وصف لغنم تسرح و تأكل من المراعي المتاحه سواء كانت خصبه او شحيحة و هو كناية عن الرعي و التنقل في الطبيعة) و انت تعرف ديرتنا فيها حمض(نباتات لرعي الغنم) وفيها شندي(موسم الرعي الجيد) و فيها خصاب(أرض خصبه) و فيها عوسج(نوع من انواع نباتات الحمض)  ،تاكل الغنم منه و تعيش </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>تعيش و بعض الاوقات تنقطع الأمطار، توخّر و يصيب العرب نقصان بالاموال و الحلال و الهنا و بعديها، و اوقات الله سبحانه و تعالى يرزقهم الربيع و عايشه الدنيا على كذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>نصنعها من غزل الغنم.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>ما يحتاج هذا كذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>اي نعم نعم.. ايه ياخوي احنا بالسوالف</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
