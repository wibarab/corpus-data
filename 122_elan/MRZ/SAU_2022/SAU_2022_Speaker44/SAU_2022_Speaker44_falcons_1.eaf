        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts63">
                <ANNOTATION_VALUE>ʕaṭ-na xalfiyya, mita ygarrnis, mita thiddūn-a, mita yaʕni al-alfāḏ̣ illi intu, il-mufradāt illi intu taʕrifūn</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62"
                TIME_SLOT_REF1="ts66" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>ṭayyib, tʕallim-na miṯāni il-ǧināḥ wišši?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63"
                TIME_SLOT_REF1="ts70" TIME_SLOT_REF2="ts73">
                <ANNOTATION_VALUE>yaʕni l-ǧināh anwāʕ?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64"
                TIME_SLOT_REF1="ts74" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ṭayyib w iḏā ṭāḥ wēš maʕnā-h?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts81">
                <ANNOTATION_VALUE>yaʕni aṣbaḥ ǧāhiz l-il-...</ANNOTATION_VALUE>
