                <ANNOTATION_VALUE>ʕind-iha dirāsat..., ʕind-iha taḥḏ̣īr risālat id-dukturā fī lahǧat qabāʔil ar-rašāyda</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>wa-ant aḥad al-mašāyix illi nastaṭīʕ an taǧri maʕa-k liqāʔ ʕan al-lahǧa w tḥaddiṯ-na ʕan iṭ-ṭeyr </ANNOTATION_VALUE>
