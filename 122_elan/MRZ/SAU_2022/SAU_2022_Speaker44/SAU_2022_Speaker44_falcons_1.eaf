    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker44_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker44" TIER_ID="SAU_2022_Speaker44_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a37" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>مرحبا و مسهلا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a38" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>؟.. الحمد لله بخير ، عافاك الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a39" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>ابشر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a40" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>.. بسأل وش تبون (ماذا تريدون) عن، مشان الصيد و لّا الطير و لّا... أيّا؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a41" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>الطير هذا اسمه شلال حرّ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a42" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>نوعيته حرّ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a43" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>حرّ، ما هو تفريخ ... ايوا ايوا .. لأن بعض الطيور فيها تفريخ و فيها يعني مهجّن و بعضها لأ، أصيل... هذا من نوع الأصيل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a91" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>الأصيل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a92" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>هذا؟...اه..هذا لونه طال عمرك احَمَر، احَمَر مغتري</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a93" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>هذا نوعيته احسن نوع.. طيب انت .. و يصيد وله مِعي أزود من خمسطعش سنه 15</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>اي نعم الحمد لله،له أزود تقريباً أزود من 15 سنه تقريباً او أكثر و هو معي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>لا و الله شاريه.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>..اشتريته لا من رجّال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a97" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>تقرناسه طال عمرك طارش النموس ، مهو نموس مثاني الجنحان أول ما يطش من الريش مثاني الجناح </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a98" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>له تقريباً اربع ايام</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a99" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>يعني النصّ منه، ما هو راس الجناح، النص، النصّ من الجناح</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a107" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>الجناح انواع في نموس ، و النايفه، و الثالثه و يا لآخره، يا النصّ، هذا يا آخر ما يطيح من الريش الطير النموس ، ينقالها نموس، نسميها نموس</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a108" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>خلاص، انتهى يقرّنس كمْل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a109" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>اصبح جاهز ..ياخذله، لا ياخذ تقريب شهرين و يكمل النموس و ينتهي و يبدّ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a110" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a111" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>الهدد يعني للصّيد، الهدد للصيد،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a112" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>و الله تختلف الاوقات اختلفت الاوقات تختلف، لا جا ، دخل الشتا، بأول الشتا يهدّ الطير، أما بالقيظ ما يهدّ، بالقيظ رابطينه، الحينه انا رابطه عندي بمظلّه و اعلّفه(إطعام الحيوانات يسمى علف)  للقرناس يقرنس،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a113" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>يطشّ سبحان الله الريش اللي عليه هذا كله ما يبقى عنه، عنده فيه و لا شي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a114" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>ينشّيله (ينشأ له) رب العالمين ريش جديد.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a115" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>... ايوا اذا قرنسّ طش الريشة تبدأ ريشة جديده تطلع له ولا(اذا) اكملت طاحت الثانية اللي وراها </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>و لا كملت طاحت اللي وراها و لآخره حتى يكمل ريشه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>الطير هذا يصيد الحبارى(طير)، و الارنب و السمجان (طير) هذا اللي يصيده</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>لا و الله أصبح قليل و الحكومه الله يعزّهم حموا بعض المناطق و ان شاء الله يكثر الخير و عسى الله يعزهم و يطول اعمارهم و لهم بالصيد </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>في سباق عند الحكومة بس انا ما رحت</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>في سباق ايه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>السباق فيه طيور و يتسابقون وياخذون جوايز(جوائز) عند الحكومة يسجلون و يسابقون الطيور و الطير السبوق ياخذ جائزه، راعي الطير السبوق ياخذ جائزه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>..ياخذون فلوس ما قصّرت الدولة ما قصّرت الله يعزّهم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>؟.. شلال.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>شلّال، شلّال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>... بس ما هو على كل حال انه.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>...ايه شلّال، شلّال، شلّال، الحينه لو انه بوقت نزوله وقت هداد على طول يطمر على يدي، لكن الحين لأ متكفّي و مغدّيه انا ..مغدّيه.. اليوم مغديه غدا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>ايه يطالع بيتي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>كيف</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>ايه ايه.. أخذ ازود من كيلو و اصوّتله(اناديه)  يجي، أزود من كيلو ايه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>بس ما هو هالوقت هذا، لأ، وقت هدد الطيور </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>كيلو عنه، كيلو كامل أروح أنا كيلو و فيه تلواح </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>و ادعيه و يجي من بعيد حين يشوفني يجي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>التلواح ريش حباري و ريش سمجان اه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>و الله صارت الحمد لله من حياتي لي أزود من ستين سنه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>.. أزود من 60 سنه نحمد الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>... و الصيد واجد هاك الحين و هو  يتنى (ينتظر) بالطيور</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>و نربيهن و نشبكهن يوم الشبك ما هو ممنوع و لّا الحينه ممنوع</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>حنّا اخذنا من جدّك ..يعني هاذي الهوايه... حنا أخذنا من أبونا من الأب</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>جدّك ما هو بطّال، جدك طيّب و من الطيبين و من الشجعان .. نعم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>و يوم قبل الله يعزّ الدولة ، حكومتنا يوم الجهاله ، الناس كلها تغزي على بعض و كلنا نهب و كلن يذبح،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>لكن اليوم... استقرّ الحكم... استقرّ الحكم و الدولة الله يعزّها على عبد العزيز </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>و  اسلمو الناس  و هوّنو عن، و هدو(هدءوا) و استقروا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a185">
                <ANNOTATION_VALUE>و كلّه غدو(أصبحوا) و كل القبايل كلها كأخوه.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a186">
                <ANNOTATION_VALUE>يوم الدب</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a188">
                <ANNOTATION_VALUE>أكبر يوم الدبه اعتبر رفيج(صديق) إلنا و فزعلها و قامو يترامون و انصاب (أُصيب)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a189">
                <ANNOTATION_VALUE>و ذِبح جيش و صوَّب (أطلق النار ) ناس و صابوه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a190">
                <ANNOTATION_VALUE>ألّا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a191">
                <ANNOTATION_VALUE>... يا طويل العمر بزمين (تصغير زمن) من الزمنات يوم الصيد واجد اخوي علي الله يرحمه تعرفه!.. الله يرحمه... الأول مقانيص يوم يقنص </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a192">
                <ANNOTATION_VALUE>جو (أتى شخصان) واحدين اثنين و قالو، تخافتو بينات مطمنين الكلام(يتحدثون بنبره منخفضه) عنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a193">
                <ANNOTATION_VALUE>واحد قال لواحد هرّ(هنالك) فيه حباري يمّتنا(بجانبنا) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>انا صدّيت(اشاح بالنظر إلى جهة أخرى)عنهم و اتسمّع لهم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a195">
                <ANNOTATION_VALUE>و اخذت كلامهم سكّتّ وما سألت </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a196">
                <ANNOTATION_VALUE>و يوم راحو و أنا أعمد علي قلتله يا علي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>عمدت علي حنا جاهزين طيورنا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a198">
                <ANNOTATION_VALUE>رحت له</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a199">
                <ANNOTATION_VALUE>صوّتّ له </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a200">
                <ANNOTATION_VALUE>قلت السالفة ثنتين حباري مذكورات يمّتنا قاله فلان و فلان و مخفّيين الكلام عنّي </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a201">
                <ANNOTATION_VALUE>ركبنا و سرينا ، انا قلت لعلي: يا علي، يا علي جونا ثلاث حسوس</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a202">
                <ANNOTATION_VALUE>و قالو ورا فلان ثنتيني، حباري يعني</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a203">
                <ANNOTATION_VALUE>و يا علي صار خبر مدسوس و هيّنْا بنطقها هجيني</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a204">
                <ANNOTATION_VALUE>سمعت و إلى آخره و نسري طال عمرك و نلقاهن و نهدّ عليهن الطيور و نطرحهن و نرجع </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a237">
                <ANNOTATION_VALUE>يوم رجعنا و ان يا يخوي هذاك اللي كامينهن راحو لهن يوم جو و انهن مطروحات</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a238">
                <ANNOTATION_VALUE>حنّا اللي صايدينهن</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a239">
                <ANNOTATION_VALUE>الطير لا و الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a240">
                <ANNOTATION_VALUE>في في قصيد، يقول واحد يقول يوم قلّ الصيد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a241">
                <ANNOTATION_VALUE>يقول طال عمرك: يا شاري الطير و الترواح</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>و هوّنت عن نقلته مربع </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a243">
                <ANNOTATION_VALUE>و ابيع انا الطير و ابا ارتاح و ياليت خيره كِفى شرّه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a244">
                <ANNOTATION_VALUE>يوم قِضى الصيد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a245">
                <ANNOTATION_VALUE>ترا هو تضايق هالشكل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a246">
                <ANNOTATION_VALUE>لا لا هاذي الزاينه ما هي خشنه لا لا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a247">
                <ANNOTATION_VALUE>هاذي زينه و هاذي اللي مقرنس الطير عليه و نحطّه عليه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a248">
                <ANNOTATION_VALUE>عليه و بالمجلس هاذي اهداها واحد عليه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a249">
                <ANNOTATION_VALUE>الله يشفيه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a250">
                <ANNOTATION_VALUE>ايه اعلمك، جدّك يا طويل العمر قبل ما في صقّارين ما غيره هو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a251">
                <ANNOTATION_VALUE>بنفسه و الرويضان الله يرحمه بعد (أيضاً) صقّار </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a252">
                <ANNOTATION_VALUE>و يقولون أبو الطيور أبو الطيور و صرنا ذوي طيور كلّه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a253">
                <ANNOTATION_VALUE>الحينه، الحين الامير عبدالعزيز اللي هذيك صورته ، الله يطوّل عمره و عمر السّامعين </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a254">
                <ANNOTATION_VALUE>ما يقولي غير يا ابو الطيور مرّه ، ما يقولي غير يا ابو الطيور.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a255">
                <ANNOTATION_VALUE>و يوم جيته اول ما صقر معنا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a256">
                <ANNOTATION_VALUE>دوّر صقّارين دوّر صقّارين و قالو ما بي إلا ابو الطيور و ارسلّي طال عمرك ، أرسلّي واحد و رحت له  - he was looking for falconeers and they said there is no one better than ab aṭ-ṭyūṛ etc. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>و جيت عنده و اختبرني اختبار، ما يعرفني </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a258">
                <ANNOTATION_VALUE>و اعطاني طير، وحش توّه مشبوك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a259">
                <ANNOTATION_VALUE>قال يا أبو الطيور في طيرن عندنا عجز انا و اخوي  عنه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a260">
                <ANNOTATION_VALUE>تقدر تاخذه، فلت حاضر طال عمرك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a261">
                <ANNOTATION_VALUE>و جابه لي طال عمرك و يوم اخذته على يدي يوم تمزّع، وحش </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a262">
                <ANNOTATION_VALUE>توّه مطروح </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a263">
                <ANNOTATION_VALUE>، يوم جا ، ثالث يوم و انا اطق برقعه طال عمرك ما يتحرك ، قال صح انت ابو الطيور</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="a302">
                <ANNOTATION_VALUE>العلاقه بين ..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="a303">
                <ANNOTATION_VALUE>الطير و صاحبه...هاذي طال عمرك هوايه في الطير </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="a304">
                <ANNOTATION_VALUE>و هالحينه كل الناس، كلن له هوايه بعضه هوايته في الابل و بعض هوايته في الغنم و بعض هوايته في المزارع و بعض هوايته بعد ،إلى آخره</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="a305">
                <ANNOTATION_VALUE>حنا هوايتنا في الطيور</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a306">
                <ANNOTATION_VALUE>الله الله... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="a307">
                <ANNOTATION_VALUE>نعم نعم و الطير يعرف صاحبه الطير يعرف راعيه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="a308">
                <ANNOTATION_VALUE>، انا لا صرت، لا صار الطير في المظلّه و مرّيت منّاك(من هناك) و ندبته باسمه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="a309">
                <ANNOTATION_VALUE>قام ينغط و يكفخ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a338" ANNOTATION_REF="a310">
                <ANNOTATION_VALUE>و قبل يومنّا (يوم اننا بمعنى عندما كُنّا) في بيوت الشعر في واحد غدر راعيه.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a339" ANNOTATION_REF="a311">
                <ANNOTATION_VALUE>في واحد غدر طيره و دسّوله بيت الشعر يوم البدو، الباديه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a340" ANNOTATION_REF="a312">
                <ANNOTATION_VALUE>قال يا الرَّبع ما عينتولنا طير.. دسّوه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a341" ANNOTATION_REF="a313">
                <ANNOTATION_VALUE>و هو شاك انه عندهم يوم ازهمه باسمه يقعد ينغط، قال اه، ها يقعد يكفخ و يقعد ينغط، قال ها هذا هو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a342" ANNOTATION_REF="a314">
                <ANNOTATION_VALUE>هو و الطير يعرف راعيه، نعم و بعض الناس ما يخلّيه يقضبه(يمسكه)... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a343" ANNOTATION_REF="a315">
                <ANNOTATION_VALUE>نعم غير صاحبه.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a357" ANNOTATION_REF="a316">
                <ANNOTATION_VALUE>و ولع(حب) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a358" ANNOTATION_REF="a317">
                <ANNOTATION_VALUE>و من قال ومن يقول</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a359" ANNOTATION_REF="a318">
                <ANNOTATION_VALUE>في اشياء وايد(كثير) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a360" ANNOTATION_REF="a319">
                <ANNOTATION_VALUE>في اشياء وايد(كثير) عن الطير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a361" ANNOTATION_REF="a320">
                <ANNOTATION_VALUE>قبل الطير الصيد واجد و كل شي و الطير مسموحن بيه و ديار ما هي ممنوعة </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a362" ANNOTATION_REF="a321">
                <ANNOTATION_VALUE>و كثرة الصيد و نستفيد منه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a363" ANNOTATION_REF="a322">
                <ANNOTATION_VALUE>حنّا طال عمرك أول يوم الطيور و الصيد واجد </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a364" ANNOTATION_REF="a323">
                <ANNOTATION_VALUE>لا جا القيظ ،حنا معنا طيور </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a365" ANNOTATION_REF="a324">
                <ANNOTATION_VALUE>نهدّ بيها لا جا القيظ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a366" ANNOTATION_REF="a325">
                <ANNOTATION_VALUE>الهدد على الصيد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a367" ANNOTATION_REF="a326">
                <ANNOTATION_VALUE>نروح نقنص و نهدّ على صيد و نصيد و نجي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a368" ANNOTATION_REF="a327">
                <ANNOTATION_VALUE>و لا جا القيظ تقرناس الطير يعني انتهى لانه له وقت محدد الطير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a375" ANNOTATION_REF="a328">
                <ANNOTATION_VALUE>ما هو دايم مدّ الحياه و هو يهدّ لا جا القيظ خلاص ما بي صيد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a376" ANNOTATION_REF="a329">
                <ANNOTATION_VALUE>يطش(يتساقط) ريشه الريش هذا اللي عليه يطشّه رب العالمين و ينشيله ريش جديد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a393" ANNOTATION_REF="a377">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a378">
                <ANNOTATION_VALUE>لا جا القرناس، الجبال اللي عندنا فيها طيور نروح نهدّه  و لا جا وقت الهداد و وقت المقاريس نروح نشقّه و نقيض فيه و نصيد فيه و ها كذا.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a395" ANNOTATION_REF="a379">
                <ANNOTATION_VALUE>شلال.... لو ما هو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a396" ANNOTATION_REF="a380">
                <ANNOTATION_VALUE>لو ما هو، لا، مقصده لو انه بوقت غير هالوقت هذا، خم يدي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a397" ANNOTATION_REF="a381">
                <ANNOTATION_VALUE>نقز على يدي و جا، و يجي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a398" ANNOTATION_REF="a382">
                <ANNOTATION_VALUE>لكن متعشّي ما هو باغن (لا يحتاج شيء) و الطير يصير قرناس، شبع.. اي نعم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a399" ANNOTATION_REF="a383">
                <ANNOTATION_VALUE>انا إلي أزود من عمري الحمد لله، نحمد الله حول التسعين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a400" ANNOTATION_REF="a384">
                <ANNOTATION_VALUE>أو أزود من التسعين و تولعي(حبي لها) بالصقور أزود من ستين سنه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a401" ANNOTATION_REF="a385">
                <ANNOTATION_VALUE>حول سبعين حولها من يومني صغير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a402" ANNOTATION_REF="a386">
                <ANNOTATION_VALUE>تعال، تعال هني(هنا).. ايوه.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a403" ANNOTATION_REF="a387">
                <ANNOTATION_VALUE>اي تحنْ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a404" ANNOTATION_REF="a388">
                <ANNOTATION_VALUE>،  و الطير ينغط</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a405" ANNOTATION_REF="a389">
                <ANNOTATION_VALUE>نغيط هذا ينقاله نغيط، ينغط</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a406" ANNOTATION_REF="a390">
                <ANNOTATION_VALUE>صوته، هذا صوته،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a407" ANNOTATION_REF="a391">
                <ANNOTATION_VALUE>كل شي له صوت و الكلاب تكرمون لهن صوت و الذيب له صوت و الطير له صوت و الغنم لها صوت و الابل لها صوت وكل شي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a408" ANNOTATION_REF="a392">
                <ANNOTATION_VALUE>؟.. و الله اسألو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
