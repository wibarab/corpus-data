        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts15">
                <ANNOTATION_VALUE>al-ḥamdu l-illa, b-xeyr ʕāfā-k allah</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts23">
                <ANNOTATION_VALUE>abšir</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>isʔalu wēš tabġūn ʕan, min il-, mšān iṣ-ṣeyd walla aṭ-ṭeyr walla, walla, eyya?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts31">
                <ANNOTATION_VALUE>aṭ-ṭeyr hāḏa isma-h ēš, šallāl, ḥurr</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts35">
                <ANNOTATION_VALUE>nowʕīt-a ḥurr</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts39">
                <ANNOTATION_VALUE>ḥurr, mā-hū tafrīx, laʔ, lən baʕaḏ̣ aṭ-ṭyūr fī-ha tafrīx w fī-ha yaʕni mhaǧǧan w baʕaḏ̣-ha laʔ, aṣīl, hāḏa min nowʕ al-aṣīl</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts40" TIME_SLOT_REF2="ts43">
                <ANNOTATION_VALUE>al-aṣīl</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts44" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>hāḏa? hāḏā lown-a ṭāl ʕumr-ak aḥamar, aḥamar muġtari</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts48" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>ay muġtari, hāḏa nowʕit-ah aḥsan nowʕ, w yaṣīd, w l-ah miʕ-i azwad min xamsṭaʕaš sana</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts53">
                <ANNOTATION_VALUE>ay, naʕam, ḥamdu l-illa, l-ah  azwad tagrīban azwad min xamsṭaʕaš sana tagrīban akṯar, w hū miʕ-i</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts54" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>lā waḷḷa šāri</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts58" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>ištarayt-a lā min raǧǧāl</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>tgarnās-a ṭāl ʕamr-ak ṭārš an-nmūs, mā-hū nmūs min... maṯāni al-ǧinḥān awwal-mā yiṭišš min ir-rīš, miṯāni al-ǧanāḥ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts67">
                <ANNOTATION_VALUE>l-ah tagrīban arbaʕ ayyām</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts71">
                <ANNOTATION_VALUE>yaʕni n-nuṣṣ min-a, mā-hū rās il-ǧanāḥ, in-nuṣṣ, in-nuṣṣ min al-ǧanāḥ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts72" TIME_SLOT_REF2="ts75">
                <ANNOTATION_VALUE>il-ǧināh anwāʕ, fī nmūs w in-nāyfa w iṯ-ṯālṯa w yā l-axiri-hi, yā án-nuṣṣ, hāḏi yā āxir mā-yaṭīḥ min rīš aṭ-ṭeyr in-nmūs, yingāl-ha nmūs, nsammī-ha nmūs</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>xalāṣ intaha, ygarrnis, kamil</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts80" TIME_SLOT_REF2="ts83">
                <ANNOTATION_VALUE>aṣbaḥ, aṣbaḥ ǧāhiz, yāxiḏ-l-ih, lā yāxiḏ, yāxiḏ, yāxiḏ tagrīb šahreyn w yakmil in-nmūs w yintihi w yibidd</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts84" TIME_SLOT_REF2="ts87">
                <ANNOTATION_VALUE>w yistifād min-a</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>al-hadad yaʕni l-aṣ-ṣeyd, il-hadad l-aṣ-ṣeyd</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>walla tixtilif al-awgāt, ixtilifat al-awgāt, tixtilif, lā ǧā daxal áš-šitāʔ, b-awwil áš-šitāʔ yahidd aṭ-ṭeyr, amma b-il-geyḏ̣ mā-yhidd, b-il-geyḏ̣ rābṭīn-ah, hal-ḥīna ana rābṭ-a ʕind-i muḏ̣alla w aʕallif-a l-il-girnās ygarnis</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>w yiṭišš sibḥān alla, ir-rīš illi ʕaley-h hāḏa kill-a mā-yabga ʕann-a, ʕind-a huwwa fī-_́ wa-lā šī</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
                <ANNOTATION_VALUE>yanaššīl-a rabb al-ʕālimīn rīš ǧidīd</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts100" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>aywa, lā (law) garnas ṭašš ar-rīša, tabda rīša ǧidīda taṭlaʕ l-ih, w lā (law) ikmalat ṭāḥat iṯ-ṯānya illi warā-ha</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>w lā (law) kmalat ṭāḥat illi warā-ha w l-āxir-ihi, ḥitta yakmal rīša</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>iṭ-ṭeyr hāḏi yṣīd al-ḥibāra, w-al-arnab, w as-simǧān, hāḏa illi yṣīd</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts110" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>lā wallah aṣbaḥ gilīl, lā wallah aṣbaḥ gilīl w il-ḥukūma hāḏa yʕizz-hum ḥamū baʕḏ̣ al-manāṭiq w inšaḷḷa yakṯar al-xeyr w ʕasa aḷḷa yʕizz-hum w yṭawwil aʕmār-uhum w la-hum b-iṣ-ṣeyd </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts120" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>fī sbāg ʕand il-ḥukūma bass ana mā-raḥt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts124" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>fī sibāg, iy, fī sibāg, fī sibāg</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>as-sbāg fī-h iṭ-ṭyūr, sbāg w ysābgūn w yāxḏūn ǧiwāyiz ʕind il-ḥukūma ysaǧǧilūn wa-ysābgūn iṭ-ṭyūr, w iṭ-ṭeyr is-sibūg yāxiḏ ǧāʔiza, rāʕi ṭ-ṭeyr is-sibūg yāxiḏ ǧāʔiza </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>yāxḏūn iflūs, mā-gaṣṣarat id-dowla mā-gaṣṣarat alla yʕizz-hum </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>šallāl</ANNOTATION_VALUE>
