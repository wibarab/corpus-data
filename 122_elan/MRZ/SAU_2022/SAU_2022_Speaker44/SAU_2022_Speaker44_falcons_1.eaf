    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker9_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker9" TIER_ID="SAU_2022_Speaker9_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a78" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>تصوير، ودك تصوير </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a79" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>.... شوي شوي اصبري شوي اباها (أريدها) تصوِّرك و انت تفتح عليه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a80" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>نبدأ ؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a81" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>مسّاك الله بالخير يا عم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a82" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>شلونك طال عمرك؟.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a83" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>هاذي الباحثة كويندا .. و النِّعم... من دولة النمسا من اوروبا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a84" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>عندها دراسة، عندها تحضير رسالة الدكتوراه في لهجة قبائل الرشايده</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a85" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>و أنت أحد المشايخ اللي نستطيع ان تجري معك لقاء عن اللهجه و تحدثنا عن الطير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a86" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>اول شي الطير هذا وشسمه(ما هو اسمه)؟.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a87" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>....اي نوع من انواع الطير؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a88" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>.نوع حرّ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a100" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>الأصيل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a101" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>وش انقال اللون، هذا لونه؟..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a102" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a103" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>طيب سؤال أنت شابكه أنت و لّا مشتريه؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>مشتريه اشتراء</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a105" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>عطنا خلفيه، متى يقرّنس، متى تهدّونه متى يعني الالفاظ اللي انتو، المفردات اللي انتو تعرفونها.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>طيب، تعلّمنا مثاني الجناح وشيّ!(ما هي)... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>... يعني الجناح انواع.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>طيب و اذا طاح وش معناه؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>يعني اصبح جاهز؟..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>و يستفاد منه للهدد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>، وش معناهته الهدد؟.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>طيب متى مواسمه، المواسم اللي تهدّونه فيها؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>يعني كل ما قرنسّ ها!, بدا ينمو له ريش جديد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>ايه طيب وش تستفيد منه بالصيد وش يصيد إلك؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>هل ما زال الصيد موجود عندنا هني اللي تصيدونه، و لّا أصبح قليل؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>للطيور؟ ، لأ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>تقول هل في سباق للطيور؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>...لكن في سباق؟...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>وش تسمّيه؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>اسمه شلال ناديه خلنا نشوف وش</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>ما تناديه إلا بظرف معيّن</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>يطالع(ينظر إلى) بيتك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>التلواح وشّي؟ (ما هي؟) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>هواية الطير متى صارت معك؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>وش تعطينا نُبذه عن فروسيّة جدّي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a210">
                <ANNOTATION_VALUE>لكن هو كان له دور و كان له فعل ... ايه نعم... كان معروف.. نعم... و من، أنا بقولك، من الاشياء اللي عرفتني شجاعته يوم الدَّبه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a211">
                <ANNOTATION_VALUE>صحيح</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>طيب ما عندك بيتين و لا قصيدة عن الطير؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a213">
                <ANNOTATION_VALUE>عطنا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a214">
                <ANNOTATION_VALUE>عمدت علي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a215">
                <ANNOTATION_VALUE>عمدت علي يعني ذهبت له رحت له</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a291">
                <ANNOTATION_VALUE>طيب ما تعرف شي عن قصيد الاولين عن الطير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a292">
                <ANNOTATION_VALUE>طيب هاذي اللي حاطه الغطا هذا، مهي خشنه على كفّه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a293">
                <ANNOTATION_VALUE>.. طيب جدّي ليش سمّوه ابو الطيور؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a294">
                <ANNOTATION_VALUE>و عمرك يطول ان شاء الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a295">
                <ANNOTATION_VALUE>هو صادق</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a296">
                <ANNOTATION_VALUE>يعني العلاقة اللي بين الصقر و راعيه وش تفسّر، وش تقول عنه؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a344">
                <ANNOTATION_VALUE>..الطير و صاحبه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a345">
                <ANNOTATION_VALUE>لكن هناك محبه بين الطير و صاحبه علاقه.. الله الله... هو يعرف صاحبه و </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a356" ANNOTATION_REF="a346">
                <ANNOTATION_VALUE>نعم ، إلا صاحبه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a369" ANNOTATION_REF="a347">
                <ANNOTATION_VALUE>هاذي علاقة وفاء و ودّ.. نعم و ولع(حب) .. متبادله.. ولع يعني ودّ ما بين الطرفين.. الله الله.. محبه، ولع يعني محبه.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a370" ANNOTATION_REF="a348">
                <ANNOTATION_VALUE>الله يعطيك العافية يجزاك خير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a371" ANNOTATION_REF="a349">
                <ANNOTATION_VALUE>عندك شي تسألينه؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a372" ANNOTATION_REF="a350">
                <ANNOTATION_VALUE>عطنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a373" ANNOTATION_REF="a351">
                <ANNOTATION_VALUE>وش كانت مهمة الطير يعني بالزمن القديم، الآن يمكن اهميته قلّت و قلّ الصيد، لكن وش كانت اهميته عند راعيه قديماً؟... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a374" ANNOTATION_REF="a352">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a415" ANNOTATION_REF="a409">
                <ANNOTATION_VALUE>... يعني كل سنه يطش؟.. كل سنه و يقرّنس من جديد.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a416" ANNOTATION_REF="a410">
                <ANNOTATION_VALUE>جافل(خائف)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a417" ANNOTATION_REF="a411">
                <ANNOTATION_VALUE>ستين سنه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a418" ANNOTATION_REF="a412">
                <ANNOTATION_VALUE>و صلّى الله و سلّم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a419" ANNOTATION_REF="a413">
                <ANNOTATION_VALUE>باقي عندك شي تعلمنا عنه؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a420" ANNOTATION_REF="a414">
                <ANNOTATION_VALUE>... يا هلا و مرحبا مستيتس بالخير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
