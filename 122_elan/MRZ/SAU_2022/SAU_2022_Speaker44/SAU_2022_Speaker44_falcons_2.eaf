    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2022_Speaker44_Transcription-txt"
        PARTICIPANT="SAU_2022_Speaker44" TIER_ID="SAU_2022_Speaker44_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a31" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>يريونهن و يقنصون فيهن</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a32" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>... صقور كويسه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a33" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>كل بلد .. كل .. الكثير من الأبلد(البلدان)  عندها صقور.. مصر عندها صقور، المغرب عندها صقور ، باكستان عندها صقور.. و ايران </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a34" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>و الفارس ، فارس طيور فارس، هذا من طيور فارس ..ايه هذا فارسي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a35" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>... و الحين هذا له مِعي تقريب خمسطعش 15 سنه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a36" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>و قبله عاد مدري كم عمره مدري </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a37" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>صيد صايد ، حبارى على طول ، ارنب ،سِمك، غراب  كل شي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a38" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>الحينه بس هذا،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a39" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>اول كان عندي طيور الأمير حول خمسه و عشرين 25 </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a40" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>25 طير </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a41" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>هذا الامير معزبنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a42" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>انا واحد </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a43" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>نروح معه للخارج نروح لباكستان و المغرب و مصر و الخليج و كله نروح معه كلنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a44" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>هذا طير كويس هذا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a45" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>لا و هو كبير </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a46" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>هذا ما ينتج عندنا بيت، هذا ما ينتج</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a47" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>ينتج و في ناس يفرّخوه، تفريخ، تهجين </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a48" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>مدري وش(ماذا) يسوّون له و بعدين يحطونه بهاذي، بمكاين(جمع ماكينه و هي machine ) و على طول يطلع فرخ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a49" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>بس ما هو شكل هذا ، غير شكل، غير يختلف</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a50" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>، ولّا هذا، هذا بالبرّ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a51" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>بالبرّ يفرّخ بجبال و يكبرن عياله و يطيرن كله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a52" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>ينتج انتاج(تكاثر) يعني ...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a53" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>اه اربّيه ما في مشكله ، آخذه انا وحش</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a54" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>كذا؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a55" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>؟ شبك(صيد) الطير أول فيه أسلاك، ما تورّينا منها يا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a56" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>.. اي هيهن معلّقات عندك بغرفة امك عطنا وِحده بس</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a57" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>الحبل! أنا آخذ الطير هنا و الحبل اربط الطير فيه بالسبوق... بالحبل هذاك... بالحبل الصغير... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a58" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>افكّه من الطويل هذا و احطه هنا، احطه على ايدي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a59" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>مثل نوبه اطلع برّه و بهدّه على طول</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a60" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>و الكفّ هذا عن لا (كي لا) يغرّشني</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>كفّه هذا زي الشوك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>، زي المسمار، لو يمسكني هالشكل قطع ايدي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>لكن هذا...لا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>خشمه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>... منقار</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>منقوره،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>و هذا ايديه كفّه و هذا ريشه، جنحانه، جناح ايمن، جناح ايسر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>و اللي تحت هذا ذِنّابه،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>وهذا من هنا صدر، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>؟...رجليه هذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>لأ، الدجاجه ما، هذا الطير لو يقضب(يمسك) هالشكل قطع اليد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>قطع اليد زي السكّين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>هاذي كل هذول نسويهن زي هذا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>و بعدين احطّ هذا بالحمامه،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>حمام حقيقيه،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>هذا ورا جناحها من هنا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>وهذا الثاني بعد من هنا و هاذي على ظهرها فوق، جا الطير على طول</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>اي الحمامه تموت يمسكها الطير يذبحها </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>هكذا بس هذا اللي كل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>بحبل، بخيط من هنا شويه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>ثقيل بالارض، ...ثقّاله شي حادّ شويه.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>لا لا بعض الاوقات نطلقها تطير حمامه تطير، بس لحّق الطير ، الطير عاد يطيح بالأرض ما يقوى</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>.. نوب(مرّه) في ثقّاله نوب بدون ثقّاله بس اذا ارتخت، اذا امسكت الطير هاللون، تكعفل(تعثّر) الطير تعب ما يروح بيه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>... و معرفتهم و شغلتهم و اهتماماتهم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>و شطرتهم في ال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
