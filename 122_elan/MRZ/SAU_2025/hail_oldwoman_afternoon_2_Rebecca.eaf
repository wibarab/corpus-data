                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>wa-mn-al-baga ar-rigg mā-la-h gabl-ah; ʕeyn-i taxaṣṣa l-farāgīni; yā mā-rammāt-ni ʕala ḏalla</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>mā-dām nafs-i tagwī-ni; ḥalaft ʔanna mā-_́xaḏ al-xibla</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts10">
