    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2025_Speaker10_Transcription-txt"
        PARTICIPANT="SAU_2025_Speaker10" TIER_ID="SAU_2025_Speaker10_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a19" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>... يا بنت حطيلها مركى</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a20" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>هاذي اختي انا... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a21" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>من مالتي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a22" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>اي و الله... فيها رشايده و فيها عوامره و فيها العنوز، ما شاء الله بيها كل شي، بس مسلمة، عرب</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a23" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>ما تعرف كلمة مروبع</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a63" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>هاذي راعية غنم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a65" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>انا راعية بل </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a66" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>... و نروح للعراق و نروح لمصر و نروح ليبيا، لا لشسمها ، سوريا، ها؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a69" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>الحين حنا كبرنا، غدينا(أصبحنا) قاعدين.. قبل يومنّا بدو.. و العيال رايحين مع الغضين الطرش ومع بنات same same</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a70" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>، يركبن الخيل يهذبن عليه، و يلعبن ، و يعطن خمسمية ألف500,000، ثلاثمية ألف 300,000، اربعمية ألف 400,000 و الناقة نبيعها بمليونين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a71" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>الغنم ألف راس نبيع منها ألوفن حصايد ما هو </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a72" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>... و يوم حصاة قحطان هنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a73" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>البل معها سوداني سوداني</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a77" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>و الغنم معها صبيان ، يوم العرب بالديره و حنا يا الكبار قعدنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a78" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>لا لا تجوزنا حنا نركب البل و نروح، لكن الحين تشبرنا، كبرنا ما نقدر نركب الحين ما نحتمل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a80" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>نركب الفرس ، نركب البعير لاء، الحينه ما نقدر، نطيح (نسقط) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a81" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>من عنا كبره</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>... و الله ما هم سوى(ليسوا متساويين) ، منهم معه ألف راس1000</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>بعضهم معه ألفين2000</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>، بعضهم معه ميتين 200 ، بعضهم ثلاث إمية 300 بعضهم ميّة 100ما يعرف سوى</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>... لا شخص واحد، ما هو شخص إلا كل الحلال عليه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>لأ ما هو بس وشخص، بس لشخص واحد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>مكلفةٍ ،تكليف ، هاي بنتي في هذا كل واحد و الواحد معاه ثلاث إمية300 راس بعير، جمال،بل، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>معه عشر خيل، معه ثلاث3 خيل ، معه اربع 4 خيل، الخيل تسابقون عليه انتي يقولتش ثلاثمية، اربعميه تطلعين عليهم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>قبايل قبايل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>رشيدي ، حربي، شمري،عنزي، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>... بس قبايل، لكن ما تعدّين سبع ساعات طيّارة لهنا، السعودية عن السعودية</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>؟ نمشيها ع الغنم بس ما نصل اقصاهاا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>) بس يا بنتي أهل سوريا ما يعرفون بعير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>ما يعرفون جمال، حمار، خيل يشيلون حلالتهم عليها</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>مساكين وغنيمتهم و كله،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>مزارع و زينين بس يعني ما هم مثل السعودية، السعودية.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>على الحميرات... السعودية..جحوش(جمع جحش و هو صغير الحمار) و على خيل كدش ما هي خيل، كدش </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>كدش ما هي خيل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
