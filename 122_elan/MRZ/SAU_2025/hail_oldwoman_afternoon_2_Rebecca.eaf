    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2025_Speaker11_Transcription-txt"
        PARTICIPANT="SAU_2025_Speaker11" TIER_ID="SAU_2025_Speaker11_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a51" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>يَا مَحْلَى الْهَقنِ وَالْهَقينِي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a52" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>
يَا مَحْلَى الْهَقنِ وَالْهَقينِي
وَمِنَ البق الْرقِّ لَه مَا لَه قَبْلَه
عَيْنِي تَخصُّ الْفَرَاجِينِي
يَا مَا رَمَاتْنِي عَلَى ذلَّه
</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a53" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>
مَا دَامَ نَفْسِي تَقْوِينِي
حَلَفْتُ أَنَا مَا آخذ الْخبْلَة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a54" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>... ايه يا سناء ما كل حينه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a55" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE> تنشدين عن </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a56" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>لا لا مَقْعِد (ما أجلس) لِلّه(بمعنى لا)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a57" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>اي و الله ،منين انتي جايه؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a58" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>منين جايه؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a59" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>؟..  اماراتيه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a60" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>من ليبيا، هه ليبيا كلها رشايده </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a61" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>..... اي حنا تاريخنا مهو، تاريخنا قبل نركب الابل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a62" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>و نسري والغنم و البيوت المروبعات (بيت الشعر المقسم أربع أقسام)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a64" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>إلا و الله بيوت الشعر هذا يا زينهن،خيام الشعر هذا زينهن</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a67" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>اسرح بالغنم قبل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a68" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>انا اسرح بالغنم و هي تسرح بالبل... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a74" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>قبل لا طاح الربيع يمّ(بجانب) العراق ربّع يمّ العراق، قبل يومنّا بدو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a75" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>و لا طاح يمّ سوريا ربّعنا بسوريا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a76" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>و يوم حصاة قحطان هنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a79" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>،.. حنا تزوجنا خلاص رحنا على أهلنا.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>؟.. وش كثر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>هاذي قبيلة بني رشيد مني كلها خير و جمال </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>من هالحجاز هاذي كلها من المدينة و جاي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>و على  السمد على جدّه هاذي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>اي السعودية كلها متخالطة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>على رجلينا ...قبل ما نعرف السيارات، اذا شفناها قلنا الحنتور يوه يوه هذا الحنتور</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>هذا الترنبي(على الاغلب تقصد نوع من انواع السيارات)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>البدو السعودية، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>، البدو نجد هذا كله بدو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>لكن الحين مين انتي جايتن معه؟.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
