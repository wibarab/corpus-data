    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2025_Speaker43_Transcription-txt"
        PARTICIPANT="SAU_2025_Speaker43" TIER_ID="SAU_2025_Speaker43_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a85" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>ما عنديش مشكلة تفضلي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a86" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>لا هالحين نقوّش(نغلي) المويه، اول شي نحط مويه مقلي(مغلي)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a87" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>)، بعدين نحط كوب من القهوة على حسب الرغبة اللي انتي تبين(تريدين)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a88" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE> مثلاً نص فنجال، فنجال، نفس الفنجال هذا، احط انا قهوة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a89" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>أخلها تطبخ، تطبخ لين ما تزين و أحط شوي هيل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a90" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>برّا الهيل احطه بترمس (Thermos، حافظة حرارة) لحال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a91" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>و احط معه شويه، و أحط مع القهوة نفسها يوم تطبخ ، الموي اليقلي، احط شوي معه قرنفل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a92" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>لا(إذا) حطيته و خلّصت قلت(غلت) شوي يعني خمس دقايق كذا تقلى، بعدين أصبّ، احطه بالترمس ، اصبّه بالترمس </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a93" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>، لا صبّيته بالترمس عاد أقدّمها للضيوف،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>اي اللي باليمين و الفنجال، ما أملاه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>اخلّه كذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>، لأ ،حنا نسمي عندنا اذا ملينا الفنجال يعني خلاص تقهوى و خلاص امشي، لأ عيب، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a97" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>كذا ، تفضلي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a102" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>حنا عندنا للضيف ذبيحة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a103" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>، أول ما يجينا الضيف إكرامه، نكرّمه، أول نقدمله القهوة و الشاهي (الشاي) و التمر </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>حنا عندنا كذا، لا خلّصهن رحنا طبخناله، مقسوم الله، يعني مثلاً ذبيحة اللي عندنا موجود</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a105" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>و زينّا الذبيحة يعني حطيناه، ذبحنا ذبيحة و قطّتناها</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>حطيناها بالقِدر و طبخناه و قدّمناها للضيف</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a107" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>نقول حيّاك الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a108" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>، الله يبارك فيك</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a109" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>اي الله، كذا ويسلّم غاليك بعضهم كذا، لا خلّص الضيف يقول كرّمك الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a110" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>اي كذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a111" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>سمّي؟(تفضلي و للرجال يُقال سمّ، او تجي بمعنى عفوا؟pardon) لازم تعرفين، لهجتنا حنّا يا الرشايده.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a112" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>يعني لا جت الحرمه هالحين جتنا مثلاً، جتنا بالبيت نقول حياتس الله ، شخبارتس، شلونت، شلون صحتش </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>تشرفنا بمعرفتج، كذا، و نسعد حتى بجية (بقدوم) الضيف تسعدنا يا ربي لك الحمد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>، نكرمه و نسعد ان دخل بيتنا ، بصير مثل اخوانّا(أخواننا) مثل اهلنا بعد</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>، يعني يا ربي لك الحمد كذا، هذا حنا عندنا سلم الضيف </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>نكرّمه يقعد عندنا ثلاث أيام ،يومين حنا ما عندنا مشكله، حيّاه الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>قبل الحياه أصعب</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>الحياه أصعب مثلاً تبي تروح تقدر ما تروح للييت</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>الحرمه أول ما تروح</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>تِلد مثلاً تبا(تريد) تولد، تولد برّ، عندها حرمه فاهمه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>تشوف الورع(الطفل الصغير) تزهمله(تجهزه و تنظفه) الصغير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>الحرمه تقعد يقهوونها(يشربوها قهوة) و يجيبلّها الحريم القريبه،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>، ما تقعد مثلنا هالحين أربعين يوم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>ما كانت تقعد، يومين، ثلاث ايام يكفّنها خلاص </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>تمشي الحرمه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>، الحين لا، اربعين يوم، الحين، فرق</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>أول عن هالحين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>الحين تولد عند أهلها</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>، اطبا (أطباء) ، احسن   (either (with regards to) the doctors, they are better or they are the best of doctors)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>، الحين نفس كذا </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>الحين تجلس عند أهلها يمكن أربعين يوم، أربعين يوم عاد خلص تروح بيتها</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>الحين الحمد لله في شغّالات</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>عند اهلها</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>عند اهلها</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>لا لا... عند امها، نفس امها، تجلس عند امها و خواتها، تجلس ببيت أبوها، والدها و تاخذ اربعين يوم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>، تجلس عندها، في حريم يوجّبن، في حريم يجين </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>مثلاً ، يمكن في ناس تفترق عن ناس، مثلاً انتي سلبتس(اسلوب) غير، حنا اسلوبنا غير يعني كذا،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a145" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>اول لا ما تروح لاهلها </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>، تجلس عند بيت الرجل(زوجها)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a147" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>هذا الرجل تجلس عنده يمكن تقريب، تاخذ يومين جالسه  يمكن ،بعدين خلص تروح تشتغل، تسوّي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a148" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>تجيب لحف،و تجيب كل شي، تجيب حطب تجيب، مو نفس الحاله هالحين</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a149" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>، هالحين أكيد تطوروا الناس ، الناس الحين دفّايات*كلمة غير مفهومة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>* في اشياء يعني غير ، هالحين ، الحين المره كل شي موفرّلها  مثلاً بغت(ارادت) شغّاله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>، بغت خادمه، اللي تبيه يبجيبلها</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>يعني حتى الحين في توصيلات، توص، يوصلولها </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>، ينظفون ايّا شي أول لأ ما فيه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>، أول يعني تعب عالحرمه تعب، الحين لأ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>الحين هي الحرمه بالعكس هي مرتاحه </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>الحين اذا بغت شي على طول تطلب من مواقع التواصل </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>على طول يجيها </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>عفواً يا حبيبتي يا مالي(ريتك) العافيه يا حياتي.. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>.. اي نعم يا حياتي تشرفنا حتى حنّا بمعرفتس و نتمنى انتس تزورينا ثاني مرّه،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>، و الحينه انتي عندنا مثل اختنا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a161" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>، دخلتي بيتنا و حياتس الله بأيّا وقت و الله يسعدتس يا حبيبتي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>لا قلنا حيّك الله، قال كرّمك الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>، الله يعطيتش العافيه يا حبيبتي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>، حنا و انتي يا حبيبتي و الله</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
