        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>w yḥuṭṭ-a ʕ-an-nār, yḥuṭṭ il-gahwa kiḏa w taṭbax taṭbax biʕdēn yḥuṭṭ il-gurunfal, ir-rwēdi, w baʕdēn lā min-h istawat ## iǧīb il-mišġāla hāḏi w yzill-ha kiḏa, yḥuṭṭ il-xeyl, w yaṭbax il-xeyl</ANNOTATION_VALUE>
