        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a114"
                TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
                <ANNOTATION_VALUE>waḷḷa, mašaḷḷa, tabārik aḷḷa, waḷḷah yā wlēd-i illi ġeyr muslim miṯil il-bihīmah yowminn-ah māt..., il-bahāyim il-ġanam yaʕni, il-ġanam il-bihīma, taʕrifīn-ha anti? il-bihīma, taʕrifīn-ha?</ANNOTATION_VALUE>
