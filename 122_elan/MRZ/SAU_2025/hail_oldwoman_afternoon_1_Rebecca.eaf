    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="SAU_2025_Speaker10_Transcription-txt"
        PARTICIPANT="SAU_2025_Speaker10" TIER_ID="SAU_2025_Speaker10_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>شوفي، حنّا أهل طرش ، بل، معلوم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>!, حنّا أهل خيل، حنا أهل غنم، غنم معلوم!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>موجود كبير، حنا أهل كرم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>كرم بيوت، تجون(تأتون) ذبايح، و كرم رجال، ونذبح البل، للبل، للطرّقي، للضّيف ذبحله بل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>و حنا أهل شسمه، بيوت شعر، معلوم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>!... وحنا اهل نخوة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>نخوة يعني شجاعة، ايه شجاعة، وحنا اهل ، حنا سعودية، و حنا من السعودية رشيدية، معلوم! </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE> و حنا أهل، بقر ما في ، هذا عند، عند الناس اللي مو حنّا،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>عند الحضر و عند البقر و عند هذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>، مزارع ما في حنا بدو، نرحل نضعن(الضعن هو كل ما في رحيل البدو) ، معلوم! نضعن مع السحاري(جمع صحراء) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>نربّع جنوب، و نربّع شمال و نربّع مصر، و نربّع بسوريا ، نربع بحصاة قحطان، نربع ...أهل طرش نمشي، معلوم! خيل و طرش</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>و ضين(ضأن) يعني غنم، غنم ، غنم بس مو مثل الغنم هاللي المدري شنهو، غنم كبار ، زينة(جيدة).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>)... نربّي للحليب و الفلوس ،نجلب جلَب</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>، نبيع ميتين200 ، نبيع ثلاث إميه 300، نبيع بميتين ألف 200,000 نبيع والناقة نبيعها بمليونين  </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>، مليونين، و نسابق بخمسة ملايين 5,000,000 و نسابق بسبعة ملايين 7,000,000 على الجيش</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>على الجيش ، اي الجيش السعودي و الخيل نسابق عليهن</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a145" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>، يعني مثقّفين ما حنّا يعني هه،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>في بالديرة عمارات و في بالديرة هاللي مثل كُبري أنا يخلونها بالكبر، يروحن البنات يروحون عيال، يروحون مع البيوت مع الطرش، يروحون اللي كُبري أنا تعتبر إميره تقعد بالبيت، اميره يقولون اميره، معلوم!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a148" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>! و هذا وش اسمه، وهذا البنات اللي كبرتش اللي مع الطرش مع الجيش يسابقون و يسابقون و الغنم يبيعون منها مية 100 راس بميتين ألف </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a149" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE> إيه ما هو شوي(ليس قليل) ما هو شوي، البل تلقينه ثلاثمية... ثلاثمية ناقه، الغنم تلقينها ألف 1000 راس و ألفين2000</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>و ها، ما حنّا يعني بشويش ، انا اشوف عندي بهالتلفزون هذا، التلفزون اللي هني(هنا) لو أورّيكي الناس الحوج(المحتاجه) اللي هنا و هذا،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>اهلن(اهله) مهو بزين، و لا عندو جمال، ما عندو جمال ، خيل و حمير تكرمون</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>، حمير و كِدش ما هو خيل ، كِدش</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>زي الفرس و ما هو فرس، كدش يركبون عليهن و يجيبون عليهن حطب، هاللي الدنيا هاذي اللي ما نعرف وشّو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>ها؟.. لا لا مي(ليست) موجودة عندنا، لا لأ مهي موجودة عندنا حنّا خيل، طرش، جيش</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>، و تكرمن الحمير مع الغنم، يروحن مع الغنم مع الصبيان، مع الصبيان، يعني بي الصبيان ما هو أجناب، سودان، و يمنيين، سوريين، عراقيين، صبيان للحلال يمشون،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>الغنم تمشي ، أي يمشي للعراق يمشي إليا سوريا يمشي إليا أدنى ايران إليّا (إلى) حصاة قحطان، يمشي إليّا...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>ها؟...من قبل، من قبل من عرفتي انا صغيره كُبر هذا، هذا اللي حنا نشينا(نشأنا) عليه يا السعودية، اللي حنّا نشينا عليه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>، انا راعية بل</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>، انا راعية بل، أنا، راعية بل، نعم، من كُبر هذا حتى قعدت انا راعية بل ، أسابق على البل ، أسابق على الطرش، أسابق على الخيل ، أسابق على كل شي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>اي يا بنتي انا ما يعني</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a161" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>... و الله عمري يمكن الحمد لله، عمري سبعه و ثمانين 87</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>نعم عمري 87 الحمد لله على ، بس الحينه ما اعتبر اني بسابق و لا شي اخاف إني أطيح(أسقط) ، و جلست عند عيالي بالبيت اللي هنا، و اللي مع الطرش  مع الطرش</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>، كلكم جميلين...و انتم وش عندكم انتم يا أهل ، شسم (شو اسم : ما اسم) ديرتكم(بلدكم) ؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>وشّي(ما الذي؟) عاد اللي عندكم، ايش اللي عندكم، وشّي مالتكم (خاصتكم)؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>ها؟..صغيرة.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>كُبر الرياض</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>لأ الجزيرة اللي انتو فيها، اللي انتم حاكمين، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>؟..الجزيرة ، انتم اللي ، انتم اللي انتم فيها، مساحتها كم؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>من أهلها ، من حاكمها؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>لا(إذا) اختارو هذا خلّو هذا، لا اختارو هذا خلّو هذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>اه، تحت الانجليز؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>اه غميضة هاذي، انتم إسلام؟ مسلمين انتم؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>؟ تونس فيها إسلام واجد(كثير)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>بس تزوجون، تجوّزون، ملكو، و يذنون، حنّا لأ، الجزيرة كلها مسلمة، اللي ما هو مسلم يطرد ما يقعد بجزيرتنا، الجزيرة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>، الجزيرة منيكم حنا الجزيرة اللي حنا فيها الحينه، كم الجزيرة اللي حنا فيها؟ للطيارة سبع ساعات، ما تقطع</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>تقطع للطيارة عشر ساعات ما تقطعها كلها، اذا الطيارة عشر ساعات ما تمشين عليها للسيارة لازم(يجب) طيّارة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>مكّة من محلنا هذا ثلاثتالاف 3000 كيلو</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>امي، هلا؟ تبي (تريدين) تمشين؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>والله ما اقطع يومنك تدقّين عليّ يجعل يوم مبروك انك تدقيّن عليّا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>..شوفي وانا أمك حنّا مسلمين مرّه(كثير)، و اللي ما هو مسلم يجازونه، يجازونه حتى يسلم </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>يجازونه يسجنونه، سجن حتى يسلم.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE> يسجنونه سجن، و في واحد يقوّم، يطلع مثل ما تقولين نايب، نايب يطلع اللي ما صلّو، يشوف اللي ما صلّو يدخلو البيوت ، يدخلو، مين اللي ما صلّى وين فلان ما صلّى،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>، هذا عندنا موجود ، و الزلام(الرجال) عندنا، العار عيب ،العار عيب، المرا ما تمشي إلا بحكم رجّالها، يعني الاسلام يعني حكم محمد صلى الله عليه وسلم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>، ايه إلا بمحرم ما تمشي، أزود من ثمانين كيلو ما تمشي، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>، المره و الرجل ما يروحون مع بعضهم لازم، ما بينهم إلا الشيطان لأ، لازم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>الوجه متغطّي، المره متغطّيه غير(إلا) هه(تعبير يستخدم لمقدار بسيط من الشيء)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>.. في ها و لا هذولاك مثل البهايم بس انه ما ياكلون شعير</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>، هذولا مثل البهايم بس انه ما ياكلون شعير ، غير المسلم وشّو، وش يبغابه( ماذا يريد به)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>وش حياته، بس بهيمة ياكل كذا مثل البهايم مثل البل مثل البقر مثل ال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>ما في وش يخليه ينام و يموت و يصير للنّار، ليه، ليه اخلّي نفسي للنار! ، ليه!، حرام</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>صلّي وضّي(توضّأ) ، يجيب العاقبة الصالحة، يجيب أكل، عيشه هنيه، أكل حلال، اشرب حلال، أنام حلال، اتزوج حلال،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>، خنزير ما ناكله، هالياكلونه، اشوفهم ياكلون ، ما ناكله حنا ما نقبله، و لا نشريه، و لا يقعد بديرتنا و لا يوجد بديرتنا،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>هذولاك اشوفهم ياكلون حتى الهوا اي شي ، ديدان ياكلونه، لا لوه فايده(ليس له فائده) ، اسم الله علينا و على ما حوالينا، و الله ما هم اوادم ، بس بهايم </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>هالحينه الحيّين ياكلون، بكره مواقد النار ، ليه يخلّون نفوسهم هااللون، ليه يخلون نفوسهم </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>لو يجينا هالحينه واحد ما يصلي ما خلّيناه ياكل معنا من الطعام</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>.. ليه ما تاكلين يا بنتي ليه؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>يا بنتي ليه ما.. تقهّوين؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>القهوة عندنا ، أُكلي يا وليدي انتي بنتي هالحينه بخلّك تخلين عندنا خمسه يوم، عشره يوم وشهر</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>من عايله، لعايله مثل ما تقولين ، نتساير كذا، نزور بعضنا كذا، المسلم يزور المسلم وهذا ياخذ بنت هذا، و هذا ياخذ ولد هذا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>، اللي غير المسلم ما نجوّزه، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>، ايش الدخان يشربونه، الدّخان هذا اللي يعمرونه، هاذي يشريونه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>لكن ما يخرّبهم، يصلّون، اي ما يخرّبهم، يصلّون سِنّه على السِنَّه، </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>والجزيل(الكثير) في السعوديه محترمين انه ما في قبايل مثلهم</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>، ما في قبايل مثل السعودية  ما في مثل السعودية لأ، ما في مثل السعودية،</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>لو كان انهم ودّو(ارسلو)، ودّو ماليزيا، ودّو آسيا، ودّو كل شي, ودّوهم اخطبه، ودّهم مساجد ، ودّو كل شي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>، ها هالحين سمح للعرب كلهم  يحجّوا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>، و اللي ما يصلّي وش يحجّ له، لأ، لا يحجّ لأنه ما مقبول منه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE> كِلّش(بتاتاً) ، يسعل(يسأل) الانسان ليصار(إذا صار) يصلّي و مات، ها؟ </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>، يسعل إذنّه(إذا إنه) يصلّي، نظر فيه, في تالي(باقي) أعماله، ما يصلّي خلص لجهنّم يروح، ايه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>لجهنّم يروح، للنّار يروح، لا(إذا) قالو يصلي، لقوه(وجدوه) يصلّي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>ينظر باقي أعماله ينهضه(يرفعه) الله و يجعل النار هنا، للجنه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>هاذي الدنيا منقطعه يا بنتي، ما، الدنيا منقطعه يا بنتي ما هي باقيتلنا لا، شويه، إلا</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>إلا منهم يعطيه الله عمرن طويل، يعطيه الله اعمالن طيبه، ومنهم لو انه مسلم لازم يحوش(يحصل)ذنب ، يعذب شويه و يجمع ليه(له) ما في خلاف يا بنتي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>، ما شاء الله ، تبارك الله، و الله يا وليدي اللي غير المسلم مثل البهيمة يومنّه(يوم إنه) يموت، البهايم الغنم يعني، البهيمه، تعرفينها انتي ؟ البهيمة، تعرفينها؟</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>اي الغنم، و البل هذا  لأنه ما حمل الامانه، و لا البني آدم حمل الامانة</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>معطيه الله ذهن معطيه سبع احساس كلهن في ضميره، يعرف يصلّي، يعرف يصوم، يعرف يتوضا، يعرف يشتغل، يعوّش غداه يعرف يعرف، في الحلال</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>في الحلال، ايه، هذا بهيمه، اللي غير مسلم بهيمه</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>خنزير ياكله حرام ياكله، حرزه ياكلها، مره(امرأه) يجيها بدون ملكه(خطبه) </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>هذا يعني ما هو زين، هذا وشّو بهايم، مثل الغنم يومنها تقارع(تتزواج)، اكلي يا وليدي، اكلي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>، انتي هالحينه، انتي لهّيتك، تبيني اعلمك، وانتي تلهيتي، كلي يا وليدي </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>، سلمي ع البنات هذيلي</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>تنشدّ عن الجيش يوم نركبهن.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
