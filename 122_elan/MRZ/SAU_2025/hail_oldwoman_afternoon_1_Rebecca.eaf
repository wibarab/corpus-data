                TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
                <ANNOTATION_VALUE>salām ʕaley-ki, yā marḥaba yā hala, yā hala keyf il-ʕamm ṭayyba? wi-šlōn-ik šlōn ḥāl-ik? yā-ḷḷa yḥayyī-ha, keyf ḥālik?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a128"
                TIME_SLOT_REF1="ts252" TIME_SLOT_REF2="ts254">
                <ANNOTATION_VALUE>āh, yā maḥala l-hegin w l-hgēni; wa-min b-ár-rigg l-ah mā l-ah gabl-a; ʕeyn-i taxaṣṣ il-farāgīni; yā mā ramāt-ni ʕala ḏalla; mā-dām nafsi tagwī-ni; ḥalaft ana mā-āxaḏ al-xibla  ((ǧ as g))</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
