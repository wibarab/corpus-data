    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Phrases "
        PARTICIPANT="SAU_2025_Speaker7" TIER_ID="SAU_2025_Speaker7_Transcription-txt">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>šaġġal, šaġġali b-ṣowt w kill šay, ṣowt w ṣūra</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>niǧi l-iz-zibda, hāḏi zibda, mustaxraǧa mnēn? mnēn mustaxraǧa? min íl-liban </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>yumxaḏ̣ al-laban, al-ġanam, w taṭlaʕ minn-ha z-zibda w yḥuṭṭūn-ha #. yitsaxdimūn-ha, gidūʕat# tamra walla maʕa īdāmāt w m_́-īdāmāt, xubza w idām, liban w zibd</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>baʕd-a, baʕd-mā yistaxraǧ iz-zibda min hāḏa, al-laban illi yabga, irakkbūn-a tarkīb, ism-a rakīb, ḥatta yistiwi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>w yṭallʕūn min-ah hāḏa, yǧammdūn-a yxallū-a ǧāmid w #, ism-a ʕagd, aw bagal</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts13">
                <ANNOTATION_VALUE>bagal aw ʕigd</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts17">
                <ANNOTATION_VALUE>ī ism-a maʕa n-nās ## wāḥad badu ygūl-l-a ʕagd, w in-nās ygūl-l-a bagal</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>lā waḷḷa bagal</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>w # yistaxdam hāḏa yistaxdam baʕad al-īdāmāt, šarāba wa-# yišrabūn-a ygawwi l-ḥeyl w yaʕni, mustaxdam, ḥamdilla, hāḏa kān ǧiddān-na w šyibān-na maʕa # hāḏa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>tamra, zibda, maʕa ### bass hāḏa al-aġlibiyya ʕeyšat-hum ʕala hāḏi </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>hāḏa ḥayāt-una </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ḥayāt abā-na w ǧiddān-_́a, ḥinna ʕad al-ḥamdilla ## w xeyrāt w in-niʕma, al-ḥamdilla</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>iy waḷḷa, naḥamd-u w niškur-u</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts32" TIME_SLOT_REF2="ts35">
                <ANNOTATION_VALUE>ġanam, aw māʕiz, ġanam aw māʕiz</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>laʔ ál-bil, lā, ál-bil lā, mā-... hāḏi yistaxraǧ min al-ġnām, min māʕiza aw ġanam. ṭabʕan al-abgār w hāḏi mā-..., ḥinna nitkallam ʕan bīyat-na ḥinna</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>ḥinna al-..., bīyat-na w ʕeyšət-na li ʕašna ʕaley-_́a, ál-bil laʔ, ḥalīb w yḥaṭṭ-a b-samīr w yašrab # mā-yimġad#</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts45">
                <ANNOTATION_VALUE>yā hala, yā hala</ANNOTATION_VALUE>
