        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts46" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>minhu? baʕdēn, baʕdēn, baʕdēn. ǧību l-barrādi, xalla yǧīb iš-šāhi. yalla nabi nṣalli bass ʕan-na nṣalli </ANNOTATION_VALUE>
