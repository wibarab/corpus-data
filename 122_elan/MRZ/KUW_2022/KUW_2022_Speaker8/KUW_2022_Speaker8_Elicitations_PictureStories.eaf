        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a76" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>"yšūf" or "yanḏ̣ar" or "yara", they all have the same meaning </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a77" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>What do you mean?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a78" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>Yes "šūfi! unḏ̣uri!" yes "unḏ̣uri!, šūfi!" I saw (ana raʔayt, ana šift), that's how it is </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a79" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>For the masculine? "šūf!", for the woman "šūfi!", for the man "šūf!"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a80" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>A person exchanging something with another person</ANNOTATION_VALUE>
