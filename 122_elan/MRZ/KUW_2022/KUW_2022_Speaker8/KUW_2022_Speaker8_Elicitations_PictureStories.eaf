        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>hāḏa ʕināq, iy miḥabba, hāḏa gaʕid yʕaddi yṭagga#</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>nās rāyḥa tamši, aṣdīqāʔ, yaʕni māsik īd-ah, rāyḥīn mukān aṣdiqāʔ yaʕni</ANNOTATION_VALUE>
