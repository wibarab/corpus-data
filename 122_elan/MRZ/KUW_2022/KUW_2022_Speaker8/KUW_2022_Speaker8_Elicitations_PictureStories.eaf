            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>It shattered?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Good news, I see. And what could that news possibly be?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>What do you call this?</ANNOTATION_VALUE>
