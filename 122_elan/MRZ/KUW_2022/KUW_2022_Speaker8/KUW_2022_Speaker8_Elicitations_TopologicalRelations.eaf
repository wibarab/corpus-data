                <ANNOTATION_VALUE>fī kamān wāḥid, iḏā ʕand-ič waqt walla ṭawwalt ʕaley-č?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184"
                TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts200">
                <ANNOTATION_VALUE>fā mā-adri inti tḥibbīn il-guṣaṣ walla mā-tḥibbīn-ha?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a194">
                <ANNOTATION_VALUE>Where do you see this apple?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>A letter maybe?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>I don't know what you call this, this you put on...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>I don't know</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>And which finger do you think it is?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Ah so this is the reason</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Good, and this? What do you call this? Could you call it an opening?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a181">
                <ANNOTATION_VALUE>What do you call these?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>May God grant you health</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a183">
                <ANNOTATION_VALUE>There is also another one (exercise), if you have time, or have I stayed too long?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a184">
                <ANNOTATION_VALUE>I don't know, do you like stories or not?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
