    <TIER LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Words-txt"/>
    <TIER LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a212" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>If you allow me to ask, how did you get married? Did your mother-in-law notice you and picked you, or how was it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Very well</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>Even if it's from the same tribe, they would consider it far </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>From amongst your paternal cousins, or your maternal cousins, right?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>They say that before the woman would not see the husband before the wedding</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>You did not see him before?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>I see, there wasn't anything like the permissable look</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a213" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>The same system</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Right</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a215" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>Right</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a216" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Right, and how is the wedding celebrated?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a217" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Approximately how much is the dowry?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a218" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Right</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a219" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Could you explain to me in detail what happens on the wedding day?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a272" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>And is it always a Thursday?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a310" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>What is the ziffa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a220" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Right, and do the women dance?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a311" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>In the groom's house?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a312" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Was your wedding in a hall or at home?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a313" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>At home?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a314" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>God bless, I think it is nicer than being in a hall, don't you think?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a315" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Right</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a316" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Of course</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a317" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>Right, and who would come to the wedding? Who is invited?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE>Right. And the food that you eat is it something of the occasion?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a245" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>And who handles the costs?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a246" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>Really?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a247" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>And the gold?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a248" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Must the groom give a ring or something of the sort, or not?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a256" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Nice</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a257" ANNOTATION_REF="a161">
                <ANNOTATION_VALUE>What else do you have for occasions?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a273" ANNOTATION_REF="a162">
                <ANNOTATION_VALUE>Is there also a celebration especially for the "milka"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a163">
                <ANNOTATION_VALUE>And then you do a big party and everyone comes...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
