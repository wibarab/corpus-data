    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="KUW_2022_Speaker8_Transcription-txt"
        PARTICIPANT=" KUW_2022_Speaker8" TIER_ID="KUW_2022_Speaker8_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Speaker8_Transcription-txt"
        PARTICIPANT=" KUW_2022_Speaker8" TIER_ID="KUW_2022_Speaker8_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>Look, we the Rašāyda, as a community, we do not marry from outside</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>We do not marry from outside the Rašāyda, the clan itself look out for the girl, she takes (a husband) from the same clan</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>If there is (interest) from another clan, for engagement or maybe she took too long to get married, it is possible that they marry from another clan, but it has to be a Rašīdi clan</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>Yes, it is rare</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>And they marry but, now they are more open than before</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>Now they marry (from different clans), they know of their jobs ((is this the right translation?#))</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>And they know the women, and they know the brides, the people have become more open</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>Before they were a bit closed off from one another</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>So one who would marry a man from another clan, they would say "Oh! She married a man from far away!" Yes, "She left!", really</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>Even if it's from the same tribe, the clans, and so I took from the same society, from the same clan, from the same clan, yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>##</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>They search (for a spouse) during weddings, they would come to a person, one would ask about another from a household, like that</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>Yes, but close relatives, no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>By God, I did not see him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>By God, I did not see him nor did he see me. Before, we wouldn't even think of seeing each other</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Look, when my son got married two years ago, both my sons married two years ago, they did not see their wives before</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a200" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>This is how it should be </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a201" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>This is the right way</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a202" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>There are people now who would see (the spouse) before, I would see him, he would see her, but only if the wedding is close, not far</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>Yes, he sees her, I see him, it's no problem</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a203" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>But this is in the present, what I told you was our way from before, I did not see him (my husband), I swear, I did not see him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Not even in a photo, I did not see him, but it could be that my son's wife saw a photo of him</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>There is ### nowadays, we also hear about it happening amongst our relatives and our community</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>But I told you about me, there wasn't any pre-marital glance, even when my daughter was engaged, he did not see her</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a204" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>He didn't see her, I swear. # And there was no communication between them, nor any telephone calls or anything</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a205" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>By God, ## I am telling you the truth</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a206" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>In the wedding celebration we have the full marriage ceremony, or it could be that some time before that they present the dowry</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a207" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>Look if they are from the same clan, they are close (to the family), it would be six thousand</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a208" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>If he comes from outside, it could be that it goes up to eight, ten (thousand), if he's a distant relative, it's like that</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a209" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>That's it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a210" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>The women's celebration? The women would attend</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a211" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Before, our weddings used to start after sunset</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a275" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>They would come and drink coffee</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a221" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>And coffee, tea, they would bring people to pour the coffee, I mean workers</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a276" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>This was before, in the nineties</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a277" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>They would bring dinner, slaughtered animals </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a222" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>Appetisers, like the...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a258" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Before it mostly was on Thursday and Friday</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>After a while, it could take place on any day</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a260" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>It could occur on any day and at any time</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a261" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>This is nowadays, from the year 2000 onwards, before no, it would be Thursday and Friday, always Thursday and Friday, the weekend</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a278" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>So that people could attend, and those who are abroad or away could come back, and there would be no work and schools, now no</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a279" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>(The party) could happen over school nights, because the people now travel in the summer time</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a280" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Before it wasn't like this, they would gather and look for each other, now travelling has increased</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a281" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>After the year 2000 the people started going on holiday during the scholastic period and work  (## not sure about this translation)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a282" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>And so they leave the summer period open so that people can travel</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a283" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>Every wedding has a dinner and a party and afterwards they would make the ziffa with the bride and groom</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a284" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>The zaffah is when the bride is taken to the groom</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>He is at his father's house</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a285" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>For example, if their house is small and they have no space, they would take a small apartment and in the ziffa ceremony they would take her (the bride) and put them in it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a286" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>## a kitchen, bedroom, living room, like so</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a287" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>They dance! This is a very nice occasion. They dance #</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a288" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>They bring a ṭaggāga (female performer)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a290" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>Before, in the end of the eighties, they would do this in the houses</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a291" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>It would take place in houses, with a big courtyard</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a292" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>In the nineties...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a293" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>In the house of the groom's father</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a294" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>And sometimes this would be at the house of the groom's father</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>And the women would be in the house of the bride's mother</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>If they are very close, and there are a lot (# translation of zaḥma here?)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>In the beginning of the nineties, people started to develop more, there emerged the halls</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>Wedding halls, hotels became a thing, and so they started booking the halls, and the halls were very comfortable</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>Because they are spacious and nice, and it was nice to celebrate in them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>And so from the year 2000 they started to book the hotels and so, thank God</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>No, it was at home</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>And the men celebrated in a tent</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>A tent outside the house</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>And the women were at the husband's house</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a303" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Yes, it like the weddings during the Corona time</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>The same like the weddings in the Corona time</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a305" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>The weddings that occurred during the Corona time were celebrated in the house</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a223" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>I organised the wedding of my youngest son at home</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a224" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>2021</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a225" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>It was honestly nice</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a306" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>And the people who attended were really the ones that you know well, and you love them and they love you</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a226" ANNOTATION_REF="a79">
                <ANNOTATION_VALUE>The people that you know really well, it was nice</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a307" ANNOTATION_REF="a80">
                <ANNOTATION_VALUE>The invitees are all those who you know #, the relatives, the people from work, someone dear, the neighbouts</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a308" ANNOTATION_REF="a82">
                <ANNOTATION_VALUE>If there is someone dear to you, for example in Saudi Arabia</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a309" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>Or from around, or someone from around who is married here, she would come</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a227" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Buffet, with servers, coffee, tea and the sorts</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a228" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>And then the buffet, it comes with some appetisers, meat and such, yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>And there's the dancing and the drum pla</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a230" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>They usually bring the bride </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a262" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a231" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Or whatever she wants</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a263" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a232" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Whoever wants to greet her would go and greet her</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a233" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>And whoever doesn't... that's it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a234" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>Of course, the apartment has to be ready</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a235" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>The groom would have prepared it two or three months before</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a236" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>The groom</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a237" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>Everything is paid for by the groom</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a238" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>They give them the dowry</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a239" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>They buy the gold, they buy the clothes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a240" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>They buy the gift bag (## what does it mean here?)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a241" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>###</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a242" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a243" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>And the gold</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a264" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a265" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a249" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>That is it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a250" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Sometimes they buy a belt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a251" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Sometimes when the wedding is close, the money would not be enough</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a252" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Then the mother adds (money), the father adds, for example</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a253" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Some of them say "no it's ok we will manage with the dowry", it will be sufficient then</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a254" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a255" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>The occasions, for example when one does the "milka", which is the signing of the marriage contract</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a266" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Yes, before the wedding  (#why mā-fī#)  milka</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>The "milk", do you know?...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a267" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>They organise a nice dinner</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>The relatives come, those who are very close</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a268" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>They dance and enjoy themselves, there would be a dinner for the women and also a dinner at the men's place</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>We also celebrate graduations, this is my son when he graduated two years ago</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a269" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>From the faculty of law at the university of Kuwait</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a270" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>We organised a party, thank God, and we danced and enjoyed it, thank God</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a271" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>(We did) a dinner for the men and a dinner for the women</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Speaker8_Transcription-txt"
