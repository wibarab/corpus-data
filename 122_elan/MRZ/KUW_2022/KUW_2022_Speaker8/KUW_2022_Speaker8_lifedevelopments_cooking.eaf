        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts5">
                <ANNOTATION_VALUE>ḥēyl taxayyarat ḥēyl, ḥēyl, ḥēyl, ḥēyl</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>kill šī taxayyar, yaʕni ḥayāt-na awwal bass yaʕni ʕala t-tilfāz</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts11">
                <ANNOTATION_VALUE>qanawāt maḥdūda, mā-fī aṣlan,is-sāʕa tisʕa msakkir it-tilifizyōn</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>waḷḷa msakkir hāḏa kinna f-iṯ-ṯimānīnāt sāʕa tisʕa xalāṣ al-axbār il-mūwǧiz xalāṣ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>baʕdēn ṣār leyn is-sāʕa ṯ-ṯnaʕaš fī, it-tisʕīnāt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>kān fī musalsalēn, wāḥid yiǧi baʕd al-maġrib w wāḥid baʕd is-sāʕa t-tisʕa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>musalsalāt, musalsal</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>f-it-tilifizyōn, kinna nḥibbu nušāhid-hum, bass</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>yaʕni akṯar šay tiǧi l-musalsalāt il-ʔurduniyya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>musalsalāt il-maṣriyya, kānat is-suʕūdiyya w-il-kweytiyya, yaʕni, l-kweytiyya akṯar</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>ay, w fā kinna nšāhid-ha yaʕni baʕdēn nsakkir it-tilifizyōn lāʔ, mā-fī ḥadd baṛṛa l-beyt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
