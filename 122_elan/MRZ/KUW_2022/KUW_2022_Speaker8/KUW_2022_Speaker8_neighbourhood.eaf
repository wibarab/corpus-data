        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>inšāʔaḷḷah inšāʔaḷḷah ṭabʕan qabīlat ar-rašāyda min al-qabāʔil il-ʕarabiyya il-ʕarīqa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ʕidāt (##why ʕidāt) at-tarīx al-aṣīl, w-, w-il-ḥimdillah yaʕni hī mawǧūda b-ǧamīʕ yaʕni taqrīban il-waṭan il-ʕarabi, fī akṯar min arbaʕtaʔaš dōla</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts9">
                <ANNOTATION_VALUE>iyya w-afxāḏ tindiriǧ taḥta-ha afxāḏ kaṯīra</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts10" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>ahā, hāḏa hū, il-baṭin yaʕni faxaḏ, yaʕni faxaḏ taṭlaʕ min-ha faxaḏ kill-mā kṯarat il-faxaḏ ṭlaʕat min-ha faxaḏ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>w-kill fixiḏ, la-ha yaʕni zayy-mā tgūlīn šēyx, iyya iyya, rayyis qabīla, čiḏi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>w hū kaṯīra w-il-ḥamdi l-illa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>ana antaṣib il-fixḏ il-muqwaʕi min qabīlat ar-rašāyda</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>šūfi kill faxaḏ fī mawǧūd b-is-suʕūdiyya w-b-il-kweyt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>waḷḷa hāḏa hī il-ḥaqīqa li ḥinna naʕrif yaʕni ana fixḏ-i mawǧūda f-il-kweyt w-mawǧūda f-is-suʕūdiyya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>yaʕni min zamān mawǧūdīn hnī f-il-kweyt yaʕni aǧdād-na l-ʕarab, il-ǧadd, xamas ǧadd yaʕni # mawǧūdīn </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>w-mawǧūdīn baʕaḏ̣ f-is-suʕūdiyya il-ǧamīʕ al-afxāḏ mawǧūd min-ha yimkin talgēn faxaḏ aw faxḏēn ṭlaʕat baʕdēn yaʕni baʕad yimkin mā-hī mawǧūda f-il-kweyt, aw qad ikūn mā-hī mawǧūda f-is-suʕūdiyya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>hāḏa hū, hāḏa hū</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts38" TIME_SLOT_REF2="ts41">
                <ANNOTATION_VALUE>itfaḏ̣ḏ̣ali, itfaḏ̣ḏ̣ali</ANNOTATION_VALUE>
