        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE># ǧeyt il-mantaqa, ǧeyt iṣ-ṣabāḥiyya, ay, ḥamdilla. zōǧ-i, ǧī dūra ihnī yaʕni mawǧūd f-il-kweyt m-il-ʕabbāsiyya, muwālīd il-ʕabbāsiyya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>haḏa zōǧ-i mawǧūd, yaʕni muwālīd il-ʕabbāsiyya, baʕdēn taʕrifīn il-aḥmadi baʕdēn intaqalu ṣ-ṣabāḥiyya baʕdēn taʕrifīn tawzīʕ ʕala s-skān </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>ay ʕala l-ʕumur tawzīʕ ʕala s-skān, yaʕni wāḥid yitzawwaǧ, yiqaddim yaʕni ykūn ʕumr-a hāḏa ʕišrīn, xamsa w-ʕišrīn, čiḏa </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>šūfi id-dawla mā-ṭṭawwil, itwazziʕ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>id-dawla twazziʕ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>w iṭṭalliʕ manāṭiq bass in-nās līš ygūl taʔaxxarat? lān (liʔanna) mā-yabi l-manṭaqa hāḏi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>mā-yabi l-manṭaqa hāḏi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>abi l-manṭaqa illi girība min il-mukān il-fulāni, m-il-mukān il-fulāni waḷḷa d-dawla mā-tqassim waḷḷa twazziʕ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>itwazziʕ, yaʕni l-ḥīn fī nās yaʕni b-ʕumur-na, mā-xāḏu byūt ilā lʔān</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts120" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>ay tizawwiǧ w-ʕiyāl-hum hum f-il-aǧarāt fiʕlan yaṭlaʕūn # "mā-ʕind-i beyt", bass hū, mā-xaḏa beyt, yaʕni ṭlaʕat manṭaqa, manṭaqtēn w mā-xaḏa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>hāḏi l-ḥayqīq, ay, hāḏi ṣ-ṣaḥīḥ, yaʕni šūfi ana fahad al-ḥīn wulid-i mitzawwiǧ, yaʕni sanatēn, b-yāxuḏ bēyt al-ḥīn</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts127">
                <ANNOTATION_VALUE>yaʕni b-yāxuḏ beyt inšāʔalla</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts128" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>ay b-nafs il-manṭaqa, f-il-ǧinūb</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>fī nās b-ʕumr-a mā-yāxḏūn, yanṭurūn  (check ##)</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>fā baʕdēn yaʕni, ygūlūn "aḥna mā-ḥaṣalna hāḏi l-beyt"</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46"
                TIME_SLOT_REF1="ts136" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>ay, kill wāḥid iḥibb il-manṭaqa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="KUW_2022_Speaker8_Transcription-txt"
        PARTICIPANT="KUW_2022_Speaker8" TIER_ID="KUW_2022_Speaker8_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Speaker8_Transcription-txt"
        PARTICIPANT="KUW_2022_Speaker8" TIER_ID="KUW_2022_Speaker8_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a76" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>God willing, naturally, the Rašāyda tribe is amongst the most noble Arabian tribes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a77" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>They follow the original historical customs, and thank God, it is found in all, or almost in all the Arabian nations, they are in more than 14 countries.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a47" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>yes, and clans, there are many clans that extend from it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a78" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>This is it, the tribal subdivision is the clan, meaning a clan which comes from another clan, whenever a clan becomes big, another one is derived from it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a79" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>And every clan has, as you would say, a sheikh, a tribal head, like that</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a80" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>And there are many, thank God</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a81" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>I belong to the Muqwaʕi clan within the Rašāyda tribe</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a82" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>Look, every clan is found in both Saudi Arabia and Kuwait</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a87" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>Yes, this a truth that we know. My clan is found in Kuwait and it is also found in Saudi Arabia</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a88" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>Our Arab ancestors have been here in Kuwait for a very long time, from 5 generations ago ##</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a90" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>And they are also found in Saudi Arabia, all of the clans are found there, maybe you can find a clan or two who left and maybe they are not found in Kuwait, or it could be that they are not found in Saudi Arabia</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a91" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>Yes, it's like so</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a92" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>Yes, go on</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a93" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>I was born in '75</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>Time has taken its toll</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a95" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>No, this is new, the Ṣabāḥ al-Aḥmad area is new, its around 10 years old</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>I used to live in Ṣabāḥiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a97" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>Yes, in Ṣabāḥiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a98" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>No, it's around 30 minutes away, around 30 kms away, something like that</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a99" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>I grew up in Ṣabāḥiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a100" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a101" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>I was born in Saudi Arabia</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a102" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>Yes, I was born in Saudi Arabia </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a103" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>I lived there for some time, and then I came here</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>When I was young, yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a105" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>Thank God</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>Yes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a107" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>No, this was after I got married</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a108" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>I came to the area, I came to Ṣabāḥiyya, thank God. My husband came full circle to here, he was in Kuwait, from ʕAbbāsiyya, he was born in ʕAbbāsiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a109" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>This is my husband, he was born in ʕAbbāsiyya, and then you know the Aḥmadi area, and then they went to Ṣabāḥiyya, and then you know, it was according to the distribution of the residential places</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a110" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>It depended on the age, the distribution of the housing units, someone gets married and he would get one, maybe his age is 20, 25, like so </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a111" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Look the government doesn't take long, it distributes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a112" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>The government distributes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a113" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>And it developes areas. But why do the people say that it took long? Because they don't want a place in the particular area offered</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a114" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>They don't want a place in that area</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a115" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>I would want to live in the area that's close to so-and-so place, I swear, the government doesn't break anyone up, it distributes</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>It distributes, there are people right now of our age, they still haven't gotten any houses</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a117" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>Yes they get married and have children and they are in rented places, really, and one would say "I don't have a house", but he didn't take a house (of his own volition), an area after another would be developed and he still would not choose a house</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>This is the truth, look, my son Fahad is married, he got married 2 years ago, and he will get a house now</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a119" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>He will take a house, God willing</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Yes, in the same area, in the south</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a48" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>There are people who wouldn't select a house, they would wait</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>And then they say "we didn't manage to get this house"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>Yes, everyone loves their own area</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
