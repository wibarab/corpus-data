        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts91">
                <ANNOTATION_VALUE>fā min is-saʕūdiyya mubāšaratan ǧīti ʕala ṣ-ṣabāḥiyya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>hāḏa gabal az-zawāǧ walla baʕd-ah?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>w kamm axaḏt wagt ḥatta ḥaṣaltu ʕala l-beyt hāḏa? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts107">
                <ANNOTATION_VALUE>kṯīr liʔannu ygūlūn innu marrāt iṭawwlūn fī tawzīʕ il-ʔarḍ?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts121">
                <ANNOTATION_VALUE>ʕal-ʕašān mā-yibūn manṭaga, al-manṭaga l-fulāniyya</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a123"
                TIME_SLOT_REF1="ts126" TIME_SLOT_REF2="ts129">
                <ANNOTATION_VALUE>min nafs il-manṭaga hāḏi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts137">
                <ANNOTATION_VALUE>bass kwayyis inn-ik tkūn grīb min il-ahal, ṣaḥḥ?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a83" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>And there is more than one clan, right?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a84" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>And tribal subdivisions, what is the difference between the tribal subdivisions and the clans?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a85" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>And who do you belong do?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a86" ANNOTATION_REF="a52">
                <ANNOTATION_VALUE>And where are they found? Because I know that that for example the Siyād clan is found only in Kuwait, but the ʕawīmri clan is found in Kuwait and in Saudi Arabia</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a89" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Really?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>So it's like that</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>And if you allow me to ask </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>When were you born?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>God bless, you are young</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>And have you been in this area for a very long time or is it quite new?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>And have you lived in it for 10 years?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE>In Ṣabāḥiyya</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>It's the one that's not so far from here, right?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>And were did you grow up?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>In Ṣabāḥiyya throughout your life</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE>Right, and you were born there</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>But you didn't live there</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>When you were young</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>So from Saudi Arabia you came directly to the Ṣabāḥiyya area</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a68">
                <ANNOTATION_VALUE>Was this before or after you got married?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>And how long did you wait until you got this place?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>Was it long? Because they say that sometimes they take a long time to distribute the land</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a72">
                <ANNOTATION_VALUE>Because they don't want to be in that particular area </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>In this same area?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>It's nice that you will be close to the family, right?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
