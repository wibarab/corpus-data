        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>Yes, here in Kuwait, in the fifties and in the sixties, there wasn't a house that didn't own a cow</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>In the seventies it started to decrease</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>It decreased, because there came the dairy products, the dairy products, and they were better than what people could make at home</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>They were sterilised, they were better</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>(Cow ownership) decreased, and it ceased to exist in the eighties#(translation meaning), there aren't anymore</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>Yes, life changed, #, the old houses were no longer, the new houses were built</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>You couldn't keep a cow in them, they had to be in the farms, and so it ceased to exist, and the people...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Yes, but only in the desert, but you can still find them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a42">
                <ANNOTATION_VALUE>The sheep and the camels, but not the cows, you can find the cows in the farms, on reserves, like so</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>Because they can profit more from them, the companies take them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a145" ANNOTATION_REF="a44">
                <ANNOTATION_VALUE>We have it, yes, we used to make it before, the sheep...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a46">
                <ANNOTATION_VALUE>The way to prepare it, (first) one would milk the sheep</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a147" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>He would milk the goats and the sheep</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>He puts it in a container, and then he puts it in a container and he turns in on and filter it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>And then he puts it in a fridge, for a day or two</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a50">
                <ANNOTATION_VALUE>Then he puts it in a warm place, ##</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>Yes, with electricity</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a54">
                <ANNOTATION_VALUE>Before it couldn't be done with electricity, they used to make it using other methods</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>But as we came around, in the eighties, there was electricity</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a161" ANNOTATION_REF="a56">
                <ANNOTATION_VALUE>And it started to really develop</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>And its usage became really easy</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a58">
                <ANNOTATION_VALUE>And then the milk increases</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>And they started to make from it the cheese and what they call butter</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a60">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>So they put it in a big bucket</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>And put it over the fire</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>It cooks for around 2 hours</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a64">
                <ANNOTATION_VALUE/>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Speaker8_Transcription-txt"
        PARTICIPANT="KUW_2022_Speaker8" TIER_ID="KUW_2022_Speaker8_Translation-gls-ar"/>
