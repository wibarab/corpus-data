    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Phrases "
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Transcription-txt">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>w in-nās nafs-hūm yaʕni il-ʕarab yrūḥūn walla s-siyyāḥ bass?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a116"
                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts9">
                <ANNOTATION_VALUE>inti trūḥīn marrāt?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>w inti kamān trūḥīn al-baṛṛ?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a117"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts41">
                <ANNOTATION_VALUE>ana kṯīr aḥibb il-ibil w il-xeyl kamān, māni šāṭra b-it-taʕāmul maʕ-hum bass aḥibb-hum</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a118"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts47">
                <ANNOTATION_VALUE>bass b-aṣ-ṣeyf mā-yifāḏ̣ #</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a119"
                TIME_SLOT_REF1="ts52" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>beyt šāʕir</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>min illi yiḥtamm fī-hum? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>in-nās al-awwalīn kānu fallāḥīn fā ḥinna mā-ʕand-ina ibil mā-ʕand-ina, ʕand-ina ġanam w bagar</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a77"
                TIME_SLOT_REF1="ts108" TIME_SLOT_REF2="ts111">
                <ANNOTATION_VALUE>bass al-ġanam lissa mawǧūd?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts119">
                <ANNOTATION_VALUE>w maʕa š-šāhi, yāklūn išī ism-u l-bagil, taʕrifīn-a?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>šū ṭarīq at-taḥḏ̣īra?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a170"
                TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts139">
                <ANNOTATION_VALUE>hāḏa ʕala l-kahraba ykūn...</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Do the Arabs go to the market, or just the tourists?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a121" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Do you go sometimes?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>And do you also go to the desert?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>I really love the camels and the horse, I am not experienced in dealing with them, but I love them</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>But in summer it would be unbearable</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>A camp?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>Who engages with them?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>Our ancestors were farmers, so we don't have camels, we have sheep and cows</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>But are the sheep still kept (at home)?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>They eat something called the "bagil" with tea, do you know of it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>How do you prepare it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a170">
                <ANNOTATION_VALUE>This is done with electricity</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Translation-gls-ar"/>
