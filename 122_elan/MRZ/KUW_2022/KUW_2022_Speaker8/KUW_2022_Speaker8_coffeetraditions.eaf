    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Phrases "
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Transcription-txt">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>w ṭabʕan yaʕni ʕādāt al-gahwa ʕan an-niswān ġeyr ʕand ar-riǧāl?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>min illi yǧīb il-gahwa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>fī šakil kuweyti baʕad?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Words"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Words-txt"/>
    <TIER ANNOTATOR="Rebecca" LINGUISTIC_TYPE_REF="Note"
        PARENT_REF="KUW_2022_Gunda_Transcription-txt"
        PARTICIPANT=" KUW_2022_Gunda" TIER_ID="KUW_2022_Gunda_Translation-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a61" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>And naturally the coffee customs differ from the women to the men right?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a62" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>Who brings the coffee?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a63" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>Is there also typical Kuwaiti form?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
