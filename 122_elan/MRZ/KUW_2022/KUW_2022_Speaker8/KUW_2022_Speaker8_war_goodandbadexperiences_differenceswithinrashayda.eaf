                <ANNOTATION_VALUE>aḥsan min il-hnūd,il-hnūd yiǧī-č mkassar laʔann-hum taʕallimu šafawi </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>mā-taʕallimaw il-qawāʔid w tarīqat tartīb il-ǧumla bass inti mašaḷḷa yaʕni tbeyyin dirāsa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>ay il-ḥamdilla lā maṛṛa mā-... il-ʕarabiyya ʕand-ič mumtāza, mašaḷḷa</ANNOTATION_VALUE>
