        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>ʕ-al-ʕirāq?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>ī kill šay fī-ha yaʕni l-ḥamdilla, yā rabb irǧaʕt il-kwēyt il-ḥamdilla, kānat ayyām saʕba w ḥamdi l-illa </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>wēn? lā, lā, baʕdēn, tizawwaǧt ṯalāṯa w tisʕīn, baʕd al-ġazu</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>lā yaʕni, ʕala l-ʕumur yaʕni, tizawwaǧt baʕdēn, ḥamdilla</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>yaʕni min ey nāḥ # yaʕni </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts46" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>lā l-ḥamdilla mā-ṣār</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>waḷḷa yaʕni, l-ḥamdi l-illa, rabb-i qafūr (ġafūr) raḥīm, rabb-i raḥīm ḥamdilla, yaʕni bass inn-i yaʕni ulid-i fahad rāḥ amrīka, awwal xallaṣ iṯ-ṯānawiyya rāḥ amrīka, ana kint mʕārda </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>ay, lēš? gilt "baʕad-mā txallaṣ il-ǧāmʕa", inna tawwa kān iṣġīr</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>mā-ʕand-a ḏīk il-luqa (luġa) illi yaʕni šāṭir fī-ha, iy, w ana b-aʕraf šay ṣirāḥa ʕan amrīka, mā-_́ʕarf šay </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>w kān awwal wāḥid min ʕiyāl-i fā ihnī al-wagt intabri # l-xōf</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>yaʕni hāḏi marḥala maṛṛeyt fī-ha, yaʕni mā-kint afakkir inn-a yitxarraǧ w yiǧi, lā, bass abī-h yarǧaʕ </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>yaʕni xāyfa ṣarāḥa, hāḏi li agūl-l-ič ana maṛṛeyt fī-ha</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>w fa kān it-tilifūn hāḏ-... il-whatsapp yaʕni huwwa rāḥ ʕām alfeyn w arbataʕaš</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>fa kint ʕala ṭūl it-tilifūn ʕand ras-i "weyn-ik? weyn-ik? weyn-ik? weyn-ik? weyn-ik?"</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>yaʕni waw waw waw, šay yaʕni lā ysadd-ik#, yaʕni taʕabt ḥeyl </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>subḥaḷḷa daras luqa (luġa) w daxal ǧāmʕa sana w ṣār yaʕni ʕind-a šway iḏ̣-ḏ̣urūf, ṣār yaʕni, fī yaʕni mā-fī musāʕada</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>mā-fī yaʕni yā īd ykūn ʕala ḥadd ysāʕid-hum šay yaʕni kānat il-umūr ʕind-a hunāka ḏ̣aʕīfa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>waḷḷa hū šāṭir w kān dāxil ǧāmʕa, xallaṣ it-tōfal (TOEFL exam) illi huwwa l-aylets (IELTS), miǧtāz</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>bass subḥaḷḷa # bass "irǧaʕ xalāṣ, irǧaʕ, irǧaʕ". hāḏi l-fatra l (illi) ana ṣarāḥ ʕanēt fī-ha</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
