        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>waḷḷa yaʕni awwal, yaʕni mā-kān ʕanda-na # taṣwīr w iṣ-ṣuwar, fā mā-ṣawwart illa baʕd mā-tazawwaǧt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>fā mā-... yaʕni mā-kān mawǧūda l-ašyāʔ hāḏi mā-kinna naḥtam fī-ha</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>w ahal-na mā-yxallūn-_́a nṣawwir yaʕni # tṣawwrīn taṭlaʕ aṣ-ṣuwar baʕdēn # bass iḏā fī ǧawāz (zawāǧ) aw šay aw ṣafar, bass</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>mbala aḏkur, kbīra yōm ġazu yaʕni ʕumr-i xumstaʕš sana </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
