        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a521"
                TIME_SLOT_REF1="ts1168" TIME_SLOT_REF2="ts1170">
                <ANNOTATION_VALUE>ē xalaṣ ṯēnk yu, ṯēnk yu!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
