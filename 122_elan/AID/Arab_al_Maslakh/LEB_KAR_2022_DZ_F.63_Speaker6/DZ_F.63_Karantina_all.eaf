                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>bint-ik hōn ši?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5967"
                TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>ma fī ḥadan?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5968"
                TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts11">
                <ANNOTATION_VALUE>barke CL b-tiṭlaʕ ʕind bint-ik, tistafīd minn-a w AID b-tuʔʕud mʕā-ki </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5969"
                TIME_SLOT_REF1="ts20" TIME_SLOT_REF2="ts23">
                <ANNOTATION_VALUE>mīn xuḍur?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5970"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts27">
                <ANNOTATION_VALUE>ʔē ʔē weyn-a?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5971"
                TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>taʔʕdi inti hōn</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5972"
                TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>ʔaw bidd-kun tiṭlaʕu maʕ baʕaḍ hōn m-niržaʕ m-niṭlaʕ yaʕni</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5973"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>ṭayyib, CL tiṭlaʕ la-fōʔ w-inti hōn</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5974"
                TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts53">
                <ANNOTATION_VALUE>lḥamdiḷḷa bi-xēr </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5975"
                TIME_SLOT_REF1="ts54" TIME_SLOT_REF2="ts57">
                <ANNOTATION_VALUE>ʕam tiḥki maʕ ʔisrāʔ?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5976"
                TIME_SLOT_REF1="ts58" TIME_SLOT_REF2="ts61">
                <ANNOTATION_VALUE>šū ṣār ʕind-a wlād?</ANNOTATION_VALUE>
