    </TIER>
    <TIER ANNOTATOR="Ana" DEFAULT_LOCALE="en"
        LINGUISTIC_TYPE_REF="Notes"
        PARENT_REF="LEB_KAR_2022_DZ_F.63_Speaker6"
        PARTICIPANT="LEB_KAR_2022_DZ_F.63_Speaker6" TIER_ID="LEB_KAR_2022_DZ_F.63_Speaker6_EN">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a992" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>How is your mother? How are your sisters?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a993" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>Are your parents good?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a994" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>Yes, thank God, Israa is good</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a995" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>she has a boy</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a996" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>Thank God, and her husband, thank God, is working</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a997" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>Thank God, she said "we have everything here, don't you worry about anything"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a998" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>tomatoes, cucumbers, everything that exists in Lebanon, you can find it up there</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a999" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>No, she cannot now.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1000" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>because her son is still little, and she can work only when her son starts kindergarten</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1001" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>she can study, and after studying, she can work</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1002" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>Israa is twenty five</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1003" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>her son is six months</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1004" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>no, I did not sell it</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1005" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>they say that appartments will get more expensive soon</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1006" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>It's a pity. I, when I first got it, it was around 145</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1007" ANNOTATION_REF="a16">
                <ANNOTATION_VALUE>a thousand dollars</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1008" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>now they are giving me 65</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1931" ANNOTATION_REF="a522">
                <ANNOTATION_VALUE>how am I going to sell it for 65?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1009" ANNOTATION_REF="a18">
                <ANNOTATION_VALUE>yes, but they said they will get more expensive soon</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1010" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>it's a pity. Leave it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1011" ANNOTATION_REF="a20">
                <ANNOTATION_VALUE>no, now here it's better</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1012" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>because here everything is close</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1013" ANNOTATION_REF="a22">
                <ANNOTATION_VALUE>(if) you go to the center, it's close, (if) you go to Arax, it's close, (if) you go to... everything is close</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1014" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>as soon as I go up I need a lot of transport, I need a lot of taxis</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1015" ANNOTATION_REF="a24">
                <ANNOTATION_VALUE>take, son, take</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1016" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>now we are here, thank God, whatever God provides, we eat it, and whatever God provides, we live of. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1017" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>we opened this shop</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1018" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>because your uncle Abu Xaled cannot work outside anymore</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1019" ANNOTATION_REF="a28">
                <ANNOTATION_VALUE>he grew tired and old</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1020" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>so, now in his old age, he comes down to the shop</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1021" ANNOTATION_REF="a30">
                <ANNOTATION_VALUE>He has a wound from the times of the invasion, from (19)82.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1022" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>He suffered an amputation</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1023" ANNOTATION_REF="a32">
                <ANNOTATION_VALUE>and he had surgery on his back, </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1024" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>(of the) spinal cord.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1025" ANNOTATION_REF="a34">
                <ANNOTATION_VALUE>And he had surgery on his intestines, they removed his gullbladder.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1026" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>So he got very tired,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1027" ANNOTATION_REF="a36">
                <ANNOTATION_VALUE>and he is around 65, he may be 67. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1028" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>He cannot work outside anymore. Do you want me to speak? (To M.27)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1029" ANNOTATION_REF="a38">
                <ANNOTATION_VALUE>He cannot work outside anymore. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1030" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>So we help each other</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1031" ANNOTATION_REF="a40">
                <ANNOTATION_VALUE>and we live. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1032" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Thank God. </ANNOTATION_VALUE>
